<Window x:Class="IdeaNest.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:IdeaNest.Views"
        Title="{Binding Title}" Width="1100" Height="700" MinWidth="780" MinHeight="480"
        WindowStartupLocation="CenterScreen" Background="{StaticResource AppBackgroundBrush}">
    <Window.InputBindings>
        <!-- AppShell file commands remain window-level so they work regardless of focus. -->
        <KeyBinding Modifiers="Ctrl"       Key="N" Command="{Binding NewWorkspaceCommand}" />
        <KeyBinding Modifiers="Ctrl"       Key="O" Command="{Binding OpenCommand}" />
        <KeyBinding Modifiers="Ctrl"       Key="S" Command="{Binding SaveCommand}" />
        <KeyBinding Modifiers="Ctrl+Shift" Key="S" Command="{Binding SaveAsCommand}" />

    </Window.InputBindings>
    <views:IdeaNestWorkspaceView DataContext="{Binding Workspace}" ShowMenu="True" />
</Window>
