<Window x:Class="IdeaNest.Views.StartupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="IdeaNest"
        Width="480" SizeToContent="Height"
        ResizeMode="NoResize"
        ShowInTaskbar="True"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource AppBackgroundBrush}"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True">
    <Border Margin="20" Background="{StaticResource SurfaceBrush}" CornerRadius="12" Padding="24">
        <Border.Effect>
            <DropShadowEffect Color="#1F2937" Opacity="0.10" BlurRadius="14" ShadowDepth="2" Direction="270" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="IdeaNestを開始"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       FontSize="16" FontWeight="SemiBold"
                       Margin="0,0,0,16" />

            <Button Grid.Row="1"
                    Content="新規プロジェクトを開始する"
                    Style="{StaticResource PrimaryButtonStyle}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    Padding="16,10"
                    Click="OnNewClick" />

            <TextBlock Grid.Row="2"
                       Text="最近使ったファイル"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="12" FontWeight="SemiBold"
                       Margin="0,20,0,8" />

            <TextBlock Grid.Row="3"
                       x:Name="EmptyHint"
                       Text="まだ履歴がありません。新規プロジェクトを開始するか、起動後に「ファイル → 開く」から読み込んでください。"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="12" TextWrapping="Wrap"
                       Visibility="Collapsed"
                       Margin="0,0,0,8" />

            <ListBox Grid.Row="4"
                     x:Name="RecentList"
                     MaxHeight="220"
                     BorderThickness="0" Background="Transparent"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     MouseDoubleClick="OnRecentDoubleClick">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="Padding" Value="10,8" />
                        <Setter Property="Margin" Value="0,1" />
                        <Setter Property="Cursor" Value="Hand" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="Bd"
                                            Background="{TemplateBinding Background}"
                                            CornerRadius="6"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource HoverOverlayBrush}" />
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#FFE4D2" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel>
                            <TextBlock Text="{Binding DisplayName}"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="13" />
                            <TextBlock Text="{Binding FullPath}"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="11"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Grid Grid.Row="5" Margin="0,20,0,0">
                <Button x:Name="ClearHistoryButton"
                        Content="履歴をクリア" Style="{StaticResource SecondaryButtonStyle}"
                        HorizontalAlignment="Left" IsEnabled="False"
                        Click="OnClearHistoryClick" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="閉じる" Style="{StaticResource SecondaryButtonStyle}"
                            IsCancel="True" Click="OnCancel" Margin="0,0,10,0" />
                    <Button Content="開く" Style="{StaticResource PrimaryButtonStyle}"
                            x:Name="OpenButton"
                            IsDefault="True" IsEnabled="False" Click="OnOpenSelectedClick" />
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
