<Window x:Class="IdeaNest.Views.NoteNestExportOptionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NoteNest向け出力オプション"
        Width="440" SizeToContent="Height"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource AppBackgroundBrush}"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True">
    <Border Margin="20" Background="{StaticResource SurfaceBrush}" CornerRadius="12" Padding="24">
        <Border.Effect>
            <DropShadowEffect Color="#1F2937" Opacity="0.10" BlurRadius="14" ShadowDepth="2" Direction="270" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="NoteNest向け出力オプション"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       FontSize="15" FontWeight="SemiBold"
                       Margin="0,0,0,16" />

            <StackPanel Grid.Row="1" Margin="0,0,0,20">
                <CheckBox x:Name="ChkNote"
                          IsChecked="True"
                          Foreground="{StaticResource TextPrimaryBrush}"
                          FontSize="13">
                    <TextBlock Text="[NOTE] IdeaNestから移行したアイデア を付ける"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="13" TextWrapping="Wrap" />
                </CheckBox>
                <CheckBox x:Name="ChkTodo"
                          IsChecked="False"
                          Foreground="{StaticResource TextPrimaryBrush}"
                          FontSize="13"
                          Margin="0,10,0,0">
                    <TextBlock Text="[TODO] 採用判断 を付ける"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="13" TextWrapping="Wrap" />
                </CheckBox>
                <CheckBox x:Name="ChkMeta"
                          IsChecked="True"
                          Foreground="{StaticResource TextPrimaryBrush}"
                          FontSize="13"
                          Margin="0,10,0,0">
                    <TextBlock Text="タグ・色・作成日・更新日などのメタ情報を含める"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="13" TextWrapping="Wrap" />
                </CheckBox>
            </StackPanel>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="キャンセル" Style="{StaticResource SecondaryButtonStyle}"
                        Margin="0,0,10,0" IsCancel="True" Click="OnCancel" />
                <Button Content="OK" Style="{StaticResource PrimaryButtonStyle}"
                        IsDefault="True" Click="OnOk" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
