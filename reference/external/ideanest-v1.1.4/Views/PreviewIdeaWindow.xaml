<Window x:Class="IdeaNest.Views.PreviewIdeaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="アイデアの詳細"
        Width="720" Height="640"
        MinWidth="520" MinHeight="380"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource AppBackgroundBrush}"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True">
    <Border Margin="0"
            Background="{Binding BackgroundBrush, Converter={StaticResource HexToBrush}}"
            CornerRadius="0"
            Padding="16">
        <DockPanel>
            <!-- Header: pin + title + status badges -->
            <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="★"
                           Foreground="#E0A800" FontSize="22"
                           Margin="0,0,8,0" VerticalAlignment="Center"
                           Visibility="{Binding IsPinned, Converter={StaticResource BoolToVis}}" />
                <TextBlock Grid.Column="1" Text="{Binding DisplayTitle}"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           FontWeight="SemiBold" FontSize="22"
                           TextWrapping="Wrap" VerticalAlignment="Center" />
                <Border Grid.Column="2" VerticalAlignment="Center" Margin="10,0,0,0"
                        Background="{StaticResource ChipBackgroundBrush}"
                        CornerRadius="9" Padding="10,4"
                        Visibility="{Binding IsArchived, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="📥 アーカイブ済み"
                               Foreground="{StaticResource ChipForegroundBrush}" FontSize="12" />
                </Border>
            </Grid>

            <!-- Tags -->
            <ItemsControl DockPanel.Dock="Top" ItemsSource="{Binding TagsList}" Margin="0,0,0,10">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource TagChipStyle}">
                            <TextBlock Text="{Binding StringFormat='#{0}'}"
                                       Style="{StaticResource TagChipTextStyle}" />
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Footer: dates + action buttons -->
            <Grid DockPanel.Dock="Bottom" Margin="0,12,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                    <TextBlock Text="作成: " Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" />
                    <TextBlock Text="{Binding CreatedAtText}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" />
                    <TextBlock Text="  /  更新: " Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" />
                    <TextBlock Text="{Binding UpdatedAtText}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" />
                </StackPanel>
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <Button Content="✎ 編集" Style="{StaticResource SecondaryButtonStyle}"
                                Click="OnEditClick" Margin="0,0,8,0" />
                        <Button Content="📋 コピー" Style="{StaticResource SecondaryButtonStyle}"
                                ToolTip="Markdown形式でクリップボードにコピー"
                                Click="OnCopyClick" Margin="0,0,8,0" />
                        <Button x:Name="PinButton" Style="{StaticResource SecondaryButtonStyle}"
                                Click="OnTogglePinClick" Margin="0,0,8,0" />
                        <Button x:Name="ArchiveButton" Style="{StaticResource SecondaryButtonStyle}"
                                Click="OnToggleArchiveClick" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,8,0">
                        <Button x:Name="PrevButton" Content="← 前" Style="{StaticResource SecondaryButtonStyle}"
                                ToolTip="前のカード (←)"
                                Click="OnPrevClick" Margin="0,0,4,0" />
                        <Button x:Name="NextButton" Content="次 →" Style="{StaticResource SecondaryButtonStyle}"
                                ToolTip="次のカード (→)"
                                Click="OnNextClick" />
                    </StackPanel>
                    <Button Grid.Column="2" Content="閉じる" Style="{StaticResource PrimaryButtonStyle}"
                            IsCancel="True" IsDefault="True" Click="OnCloseClick" />
                </Grid>
            </Grid>

            <!-- Body (scrollable, larger font). Background matches card color so it
                 doesn't look like an editable input field. -->
            <Border Background="{Binding BackgroundBrush, Converter={StaticResource HexToBrush}}"
                    CornerRadius="6" Padding="14">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <TextBlock Text="{Binding Body}"
                               TextWrapping="Wrap"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="16"
                               LineHeight="26" />
                </ScrollViewer>
            </Border>
        </DockPanel>
    </Border>
</Window>
