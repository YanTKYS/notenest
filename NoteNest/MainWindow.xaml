<Window x:Class="NoteNest.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:NoteNest.ViewModels"
        xmlns:conv="clr-namespace:NoteNest.Converters"
        Title="{Binding WindowTitle}"
        Width="1100" Height="720"
        MinWidth="800" MinHeight="520"
        Closing="Window_Closing"
        PreviewKeyDown="Window_PreviewKeyDown">

    <Window.InputBindings>
        <KeyBinding Key="S" Modifiers="Ctrl" Command="{Binding SaveProjectCommand}"/>
        <KeyBinding Key="N" Modifiers="Ctrl" Command="{Binding NewProjectCommand}"/>
        <KeyBinding Key="O" Modifiers="Ctrl" Command="{Binding OpenProjectCommand}"/>
    </Window.InputBindings>

    <Window.Resources>
        <conv:BoolToVisibilityConverter    x:Key="BoolToVis"/>
        <conv:MarkerTypeToBrushConverter   x:Key="MarkerBrush"/>
    </Window.Resources>

    <DockPanel>

        <!-- ═══ Menu bar ═══ -->
        <Menu DockPanel.Dock="Top" FontSize="13">

            <MenuItem Header="ファイル(_F)">
                <MenuItem Header="新規プロジェクト(_N)" Command="{Binding NewProjectCommand}"
                          InputGestureText="Ctrl+N"/>
                <MenuItem Header="プロジェクトを開く(_O)..." Command="{Binding OpenProjectCommand}"
                          InputGestureText="Ctrl+O"/>
                <Separator/>
                <MenuItem Header="保存(_S)" Command="{Binding SaveProjectCommand}"
                          InputGestureText="Ctrl+S"/>
                <MenuItem Header="名前を付けて保存(_A)..." Command="{Binding SaveAsProjectCommand}"/>
                <Separator/>
                <MenuItem Header="終了(_X)" Command="{Binding ExitCommand}"
                          InputGestureText="Alt+F4"/>
            </MenuItem>

            <MenuItem Header="編集(_E)">
                <MenuItem Header="検索(_F)..." Click="ShowFindReplace_Click" InputGestureText="Ctrl+F"/>
                <MenuItem Header="置換(_R)..." Click="ShowFindReplace_Click" InputGestureText="Ctrl+H"/>
                <Separator/>
                <MenuItem Header="フォント設定(_O)..." Click="ShowFontSettings_Click"/>
            </MenuItem>

            <MenuItem Header="ノート(_N)">
                <MenuItem Header="ノートブック追加(_B)..." Click="AddNotebook_Click"/>
                <MenuItem Header="ノート追加(_A)..."      Click="AddNote_Click"/>
                <Separator/>
                <MenuItem Header="ノート名変更(_R)..." Click="RenameSelectedNote_Click"/>
                <MenuItem Header="ノート削除(_D)"      Click="DeleteSelectedNote_Click"/>
            </MenuItem>

        </Menu>

        <!-- ═══ Status bar ═══ -->
        <StatusBar DockPanel.Dock="Bottom" Background="#F0F0F0" Padding="4,2" FontSize="12">
            <TextBlock Text="{Binding StatusMessage}"/>
            <Separator/>
            <TextBlock Text="{Binding EditorFontFamily}" Foreground="#777"/>
            <TextBlock Text=" "/>
            <TextBlock Text="{Binding EditorFontSize, StringFormat={}{0}pt}" Foreground="#777"/>
        </StatusBar>

        <!-- ═══ Main 3-pane layout ═══ -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" MinWidth="140" MaxWidth="400"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"   MinWidth="280"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="280" MinWidth="200" MaxWidth="420"/>
            </Grid.ColumnDefinitions>

            <!-- ═══ LEFT PANE: Notebook / Note tree ═══ -->
            <Grid Grid.Column="0" Background="{StaticResource SidebarBg}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Project name header -->
                <Border Grid.Row="0"
                        BorderBrush="{StaticResource PaneBorder}" BorderThickness="0,0,0,1"
                        Padding="10,9">
                    <DockPanel>
                        <Button DockPanel.Dock="Right" Content="+" Width="22" Height="22"
                                Style="{StaticResource IconButton}"
                                Click="LeftPaneAdd_Click" ToolTip="追加"/>
                        <TextBlock Text="{Binding ProjectName}"
                                   FontWeight="Bold" FontSize="13"
                                   TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center"/>
                    </DockPanel>
                </Border>

                <!-- TreeView -->
                <TreeView Grid.Row="1" x:Name="NotebookTree"
                          ItemsSource="{Binding Notebooks}"
                          SelectedItemChanged="NotebookTree_SelectedItemChanged"
                          Padding="0,4">

                    <TreeView.ItemContainerStyle>
                        <Style TargetType="TreeViewItem">
                            <Setter Property="IsExpanded"  Value="{Binding IsExpanded, Mode=TwoWay}"/>
                            <Setter Property="Padding"     Value="2,3"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        </Style>
                    </TreeView.ItemContainerStyle>

                    <TreeView.Resources>

                        <!-- ── Notebook template ── -->
                        <HierarchicalDataTemplate DataType="{x:Type vm:NotebookViewModel}"
                                                  ItemsSource="{Binding Notes}">
                            <TextBlock Text="{Binding Title}"
                                       FontWeight="SemiBold" FontSize="12.5"
                                       Padding="2,1" ToolTip="{Binding Title}">
                                <TextBlock.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="ノートを追加..." Click="AddNoteToNotebook_Click"/>
                                        <Separator/>
                                        <MenuItem Header="名前変更..."    Click="RenameNotebook_Click"/>
                                        <MenuItem Header="削除"           Click="DeleteNotebook_Click"/>
                                    </ContextMenu>
                                </TextBlock.ContextMenu>
                            </TextBlock>
                        </HierarchicalDataTemplate>

                        <!-- ── Note template ── -->
                        <DataTemplate DataType="{x:Type vm:NoteViewModel}">
                            <DockPanel>
                                <DockPanel.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="名前変更..." Click="RenameNote_Click"/>
                                        <Separator/>
                                        <MenuItem Header="削除"        Click="DeleteNote_Click"/>
                                    </ContextMenu>
                                </DockPanel.ContextMenu>
                                <TextBlock DockPanel.Dock="Right"
                                           Text="●"
                                           Foreground="#E67E22"
                                           FontSize="9"
                                           VerticalAlignment="Center"
                                           Margin="0,0,4,0"
                                           ToolTip="このノートにはマーカーがあります"
                                           Visibility="{Binding HasMarkers, Converter={StaticResource BoolToVis}}"/>
                                <TextBlock Text="{Binding Title}"
                                           FontSize="12" Padding="8,1"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip="{Binding Title}"/>
                            </DockPanel>
                        </DataTemplate>

                    </TreeView.Resources>
                </TreeView>

                <!-- Bottom toolbar -->
                <Border Grid.Row="2"
                        BorderBrush="{StaticResource PaneBorder}" BorderThickness="0,1,0,0"
                        Background="{StaticResource SidebarBg}" Padding="6,5">
                    <StackPanel Orientation="Horizontal">
                        <Button Content="+ ノートブック" Style="{StaticResource IconButton}"
                                FontSize="11.5" Click="AddNotebook_Click" Margin="0,0,4,0"/>
                        <Button Content="+ ノート" Style="{StaticResource IconButton}"
                                FontSize="11.5" Click="AddNote_Click"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- GridSplitter L -->
            <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch"
                          Background="{StaticResource PaneBorder}" ShowsPreview="True"/>

            <!-- ═══ CENTER PANE: Editor ═══ -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Sample project banner -->
                <Border Grid.Row="0"
                        Background="#FFF8DC"
                        BorderBrush="#D4B800"
                        BorderThickness="0,0,0,1"
                        Padding="14,8"
                        Visibility="{Binding IsSampleProject, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="サンプルプロジェクトです。「名前を付けて保存」から .notenest ファイルとして保存すると、プロジェクトを開始できます。"
                               FontSize="11.5" Foreground="#7A6000" TextWrapping="Wrap"/>
                </Border>

                <!-- Note / task-comment title bar -->
                <Border Grid.Row="1"
                        BorderBrush="{StaticResource PaneBorder}" BorderThickness="0,0,0,1"
                        Padding="14,9">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsTaskCommentMode}" Value="True">
                                    <Setter Property="Background" Value="#FFF8E1"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <DockPanel>
                        <Button DockPanel.Dock="Right" Content="💾" Width="28" Height="28"
                                Style="{StaticResource IconButton}"
                                Command="{Binding SaveProjectCommand}" ToolTip="保存 (Ctrl+S)"
                                FontSize="15"/>
                        <Border DockPanel.Dock="Right"
                                Background="#FFE082" CornerRadius="3"
                                Padding="6,2" Margin="8,0,0,0"
                                VerticalAlignment="Center"
                                Visibility="{Binding IsTaskCommentMode, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="コメント編集中"
                                       FontSize="10.5" Foreground="#8C6100"/>
                        </Border>
                        <TextBlock Text="{Binding EditorTitle}"
                                   FontSize="14" FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"/>
                    </DockPanel>
                </Border>

                <!-- Editor TextBox -->
                <TextBox Grid.Row="2"
                         x:Name="EditorBox"
                         Text="{Binding EditorContent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         FontFamily="{Binding EditorFontFamily}"
                         FontSize="{Binding EditorFontSize}"
                         AcceptsReturn="True"
                         AcceptsTab="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Disabled"
                         BorderThickness="0"
                         Padding="16,12"
                         VerticalContentAlignment="Top"
                         SpellCheck.IsEnabled="False"/>

                <!-- Marker insertion buttons -->
                <Border Grid.Row="3"
                        BorderBrush="{StaticResource PaneBorder}" BorderThickness="0,1,0,0"
                        Background="{StaticResource SidebarBg}"
                        Padding="12,5">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="挿入：" FontSize="11" Foreground="#888"
                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <Button Content="[TODO]"  Click="InsertTodo_Click"
                                Style="{StaticResource IconButton}" FontSize="11.5"
                                Margin="0,0,4,0" ToolTip="[TODO]  をカーソル位置に挿入"/>
                        <Button Content="[FIXME]" Click="InsertFixme_Click"
                                Style="{StaticResource IconButton}" FontSize="11.5"
                                Margin="0,0,4,0" ToolTip="[FIXME]  をカーソル位置に挿入"/>
                        <Button Content="[NOTE]"  Click="InsertNote_Click"
                                Style="{StaticResource IconButton}" FontSize="11.5"
                                ToolTip="[NOTE]  をカーソル位置に挿入"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- GridSplitter R -->
            <GridSplitter Grid.Column="3" HorizontalAlignment="Stretch"
                          Background="{StaticResource PaneBorder}" ShowsPreview="True"/>

            <!-- ═══ RIGHT PANE ═══ -->
            <Grid Grid.Column="4" Background="#FAFAFA">
                <Grid.RowDefinitions>
                    <RowDefinition Height="3*" MinHeight="150"/>
                    <RowDefinition Height="4"/>
                    <RowDefinition Height="2*" MinHeight="100"/>
                </Grid.RowDefinitions>

                <!-- ── Tasks ── -->
                <Grid Grid.Row="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Tasks header -->
                    <Border Grid.Row="0"
                            BorderBrush="{StaticResource PaneBorder}" BorderThickness="0,0,0,1"
                            Padding="12,9">
                        <DockPanel>
                            <Button DockPanel.Dock="Right" Content="+" Width="22" Height="22"
                                    Style="{StaticResource IconButton}"
                                    Click="AddTaskMenu_Click" ToolTip="タスクを追加"/>
                            <TextBlock Text="タスク" FontWeight="Bold" FontSize="13"
                                       VerticalAlignment="Center"/>
                        </DockPanel>
                    </Border>

                    <!-- Task groups -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding TaskGroups}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel>

                                        <!-- Group header -->
                                        <Border Padding="10,6,10,6"
                                                Background="{StaticResource GroupHeaderBg}"
                                                BorderBrush="{StaticResource PaneBorder}"
                                                BorderThickness="0,0,0,1"
                                                Cursor="Hand">
                                            <Border.InputBindings>
                                                <MouseBinding MouseAction="LeftClick"
                                                              Command="{Binding DataContext.ToggleGroupCommand,
                                                                        RelativeSource={RelativeSource AncestorType=Window}}"
                                                              CommandParameter="{Binding}"/>
                                            </Border.InputBindings>
                                            <DockPanel>
                                                <TextBlock DockPanel.Dock="Right"
                                                           Text="{Binding CountText}"
                                                           Foreground="#999" FontSize="11"
                                                           VerticalAlignment="Center" Margin="4,0,0,0"/>
                                                <Button DockPanel.Dock="Right"
                                                        Content="+" Width="18" Height="18"
                                                        FontSize="12" Padding="0"
                                                        Style="{StaticResource IconButton}"
                                                        Command="{Binding DataContext.AddTaskCommand,
                                                                  RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding Key}"
                                                        ToolTip="このグループにタスクを追加"/>
                                                <TextBlock Text="{Binding Title}"
                                                           FontWeight="SemiBold" FontSize="12"
                                                           VerticalAlignment="Center"/>
                                            </DockPanel>
                                        </Border>

                                        <!-- Tasks in group -->
                                        <ItemsControl ItemsSource="{Binding Tasks}"
                                                      Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVis}}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Padding="10,6"
                                                            BorderBrush="#EEEEEE"
                                                            BorderThickness="0,0,0,1">
                                                        <Border.ContextMenu>
                                                            <ContextMenu>
                                                                <MenuItem Header="名前変更..." Click="RenameTask_Click"/>
                                                                <Separator/>
                                                                <MenuItem Header="削除" Click="DeleteTask_Click"/>
                                                            </ContextMenu>
                                                        </Border.ContextMenu>
                                                        <DockPanel>
                                                            <CheckBox IsChecked="{Binding IsCompleted}"
                                                                      VerticalAlignment="Center"
                                                                      Margin="0,0,8,0"/>
                                                            <TextBlock DockPanel.Dock="Right"
                                                                       Text="●"
                                                                       Foreground="#5B9BD5"
                                                                       FontSize="9"
                                                                       VerticalAlignment="Center"
                                                                       Margin="4,0,0,0"
                                                                       ToolTip="このタスクにはコメントがあります"
                                                                       Visibility="{Binding HasComment, Converter={StaticResource BoolToVis}}"/>
                                                            <TextBlock Text="{Binding Title}"
                                                                       VerticalAlignment="Center"
                                                                       TextWrapping="Wrap"
                                                                       FontSize="12.5"
                                                                       MouseLeftButtonDown="TaskTitle_MouseLeftButtonDown">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                                                <Setter Property="TextDecorations" Value="Strikethrough"/>
                                                                                <Setter Property="Foreground" Value="#AAAAAA"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </DockPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>

                <!-- Horizontal GridSplitter -->
                <GridSplitter Grid.Row="1" HorizontalAlignment="Stretch"
                              Background="{StaticResource PaneBorder}" ShowsPreview="True"/>

                <!-- ── Markers ── -->
                <Grid Grid.Row="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Markers header -->
                    <Border Grid.Row="0"
                            BorderBrush="{StaticResource PaneBorder}" BorderThickness="0,0,0,1"
                            Padding="12,9">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Right"
                                       Text="{Binding MarkerCount, StringFormat={}{0}個}"
                                       Foreground="#888" FontSize="12"
                                       VerticalAlignment="Center"/>
                            <TextBlock DockPanel.Dock="Right"
                                       Text="？"
                                       Foreground="#BBBBBB"
                                       FontSize="12"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"
                                       Cursor="Help">
                                <TextBlock.ToolTip>
                                    <ToolTip>
                                        <StackPanel Margin="4,2">
                                            <TextBlock Text="利用可能なマーカー:" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                            <TextBlock Text="[TODO]   やること"   Margin="0,0,0,3"/>
                                            <TextBlock Text="[FIXME]  修正が必要" Margin="0,0,0,3"/>
                                            <TextBlock Text="[NOTE]   メモ・補足"/>
                                        </StackPanel>
                                    </ToolTip>
                                </TextBlock.ToolTip>
                            </TextBlock>
                            <TextBlock Text="マーカー" FontWeight="Bold" FontSize="13"
                                       VerticalAlignment="Center"/>
                        </DockPanel>
                    </Border>

                    <!-- Marker list -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Markers}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="10,8"
                                            BorderBrush="#EEEEEE" BorderThickness="0,0,0,1"
                                            Cursor="Hand"
                                            MouseLeftButtonDown="Marker_MouseLeftButtonDown">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#F0F4FF"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <DockPanel>
                                                <TextBlock Text="{Binding Type}"
                                                           Foreground="{Binding Type, Converter={StaticResource MarkerBrush}}"
                                                           FontWeight="Bold" FontSize="11"
                                                           Width="46" DockPanel.Dock="Left"/>
                                                <TextBlock Text="{Binding LineLabel}"
                                                           Foreground="#888" FontSize="11"
                                                           Margin="0,0,6,0" VerticalAlignment="Center"
                                                           DockPanel.Dock="Left"/>
                                                <TextBlock Text="{Binding NoteTitle}"
                                                           Foreground="#666" FontSize="11"
                                                           VerticalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </DockPanel>
                                            <TextBlock Text="{Binding Excerpt}"
                                                       Foreground="#555" FontSize="11.5"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="0,3,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Project-wide marker summary -->
                    <Border Grid.Row="2"
                            BorderBrush="{StaticResource PaneBorder}" BorderThickness="0,1,0,0"
                            Background="#F5F5F5"
                            Padding="12,6">
                        <TextBlock Text="{Binding ProjectMarkerSummary}"
                                   FontSize="11" Foreground="#888"
                                   TextWrapping="Wrap"/>
                    </Border>
                </Grid>

            </Grid>
        </Grid>
    </DockPanel>
</Window>
