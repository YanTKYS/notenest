<Window x:Class="NoteNest.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:NoteNest.ViewModels"
        xmlns:conv="clr-namespace:NoteNest.Converters"
        Title="{Binding WindowTitle}"
        Width="1100" Height="720"
        MinWidth="800" MinHeight="520"
        Background="{DynamicResource AppBg}"
        Closing="Window_Closing"
        PreviewKeyDown="Window_PreviewKeyDown">

    <Window.InputBindings>
        <KeyBinding Key="S" Modifiers="Ctrl" Command="{Binding SaveProjectCommand}"/>
        <KeyBinding Key="N" Modifiers="Ctrl" Command="{Binding NewProjectCommand}"/>
        <KeyBinding Key="O" Modifiers="Ctrl" Command="{Binding OpenProjectCommand}"/>
    </Window.InputBindings>

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <DockPanel>

        <!-- ═══ Menu bar ═══ -->
        <Menu DockPanel.Dock="Top" FontSize="13">

            <MenuItem Header="ファイル(_F)">
                <MenuItem Header="新規プロジェクト(_N)" Command="{Binding NewProjectCommand}"
                          InputGestureText="Ctrl+N"/>
                <MenuItem Header="プロジェクトを開く(_O)..." Command="{Binding OpenProjectCommand}"
                          InputGestureText="Ctrl+O"/>
                <Separator/>
                <MenuItem Header="最近使ったファイル(_R)"
                          ItemsSource="{Binding RecentFiles}"
                          IsEnabled="{Binding HasRecentFiles}">
                    <MenuItem.ItemContainerStyle>
                        <Style TargetType="MenuItem">
                            <Setter Property="Header" Value="{Binding FileName}"/>
                            <Setter Property="ToolTip" Value="{Binding FullPath}"/>
                            <Setter Property="Command"
                                    Value="{Binding DataContext.OpenRecentCommand,
                                            RelativeSource={RelativeSource AncestorType=Window}}"/>
                            <Setter Property="CommandParameter" Value="{Binding FullPath}"/>
                        </Style>
                    </MenuItem.ItemContainerStyle>
                </MenuItem>
                <Separator/>
                <MenuItem Header="保存(_S)" Command="{Binding SaveProjectCommand}"
                          InputGestureText="Ctrl+S"/>
                <MenuItem Header="名前を付けて保存(_A)..." Command="{Binding SaveAsProjectCommand}"/>
                <Separator/>
                <MenuItem Header="エクスポート(_E)">
                    <MenuItem Header="プロジェクト全体をテキスト出力(_T)..."
                              Click="ExportProjectText_Click"/>
                    <MenuItem Header="ノートブックごとにテキスト出力(_N)..."
                              Click="ExportNotebooksText_Click"/>
                </MenuItem>
                <Separator/>
                <MenuItem Header="終了(_X)" Command="{Binding ExitCommand}"
                          InputGestureText="Alt+F4"/>
            </MenuItem>

            <MenuItem Header="編集(_E)">
                <MenuItem Header="検索(_F)..." Click="ShowFindReplace_Click" InputGestureText="Ctrl+F"/>
                <MenuItem Header="置換(_R)..." Click="ShowFindReplace_Click" InputGestureText="Ctrl+H"/>
                <Separator/>
                <MenuItem Header="行番号を表示(_L)" IsCheckable="True"
                          IsChecked="{Binding ShowLineNumbers, Mode=TwoWay}"/>
                <MenuItem Header="ダークテーマ(_D)" IsCheckable="True"
                          x:Name="DarkThemeMenuItem"
                          Click="DarkTheme_Click"/>
                <Separator/>
                <MenuItem Header="フォント設定(_O)..." Click="ShowFontSettings_Click"/>
            </MenuItem>

            <MenuItem Header="ノート(_N)">
                <MenuItem Header="ノートブック追加(_B)..." Click="AddNotebook_Click"/>
                <MenuItem Header="ノート追加(_A)..."      Click="AddNote_Click"/>
                <Separator/>
                <MenuItem Header="ノート名変更(_R)..." Click="RenameSelectedNote_Click"/>
                <MenuItem Header="ノート削除(_D)"      Click="DeleteSelectedNote_Click"/>
            </MenuItem>

        </Menu>

        <!-- ═══ Status bar ═══ -->
        <StatusBar DockPanel.Dock="Bottom" Background="{DynamicResource StatusBarBg}"
                   Foreground="{DynamicResource AppFg}" Padding="4,2" FontSize="12">
            <TextBlock Text="{Binding StatusMessage}"/>
            <Separator/>
            <TextBlock Text="{Binding EditorFontFamily}" Foreground="{DynamicResource SubtleFg}"/>
            <TextBlock Text=" "/>
            <TextBlock Text="{Binding EditorFontSize, StringFormat={}{0}pt}" Foreground="{DynamicResource SubtleFg}"/>
            <Separator Visibility="{Binding IsModified, Converter={StaticResource BoolToVis}}"/>
            <TextBlock Text="{Binding UnsavedIndicatorText}"
                       Visibility="{Binding IsModified, Converter={StaticResource BoolToVis}}">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="{DynamicResource UnsavedBrush}"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsUnsavedWarning}" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource UnsavedWarningBrush}"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </StatusBar>

        <!-- ═══ Main 3-pane layout ═══ -->
        <Grid TextElement.Foreground="{DynamicResource AppFg}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" MinWidth="140" MaxWidth="400"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"   MinWidth="280"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="280" MinWidth="200" MaxWidth="420"/>
            </Grid.ColumnDefinitions>

            <!-- ═══ LEFT PANE: Notebook / Note tree ═══ -->
            <Grid Grid.Column="0" Background="{DynamicResource SidebarBg}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Project name header -->
                <Border Grid.Row="0"
                        BorderBrush="{DynamicResource PaneBorder}" BorderThickness="0,0,0,1"
                        Padding="10,9">
                    <DockPanel>
                        <Button DockPanel.Dock="Right" Content="+" Width="22" Height="22"
                                Style="{StaticResource IconButton}"
                                Click="LeftPaneAdd_Click" ToolTip="追加"/>
                        <TextBlock Text="{Binding ProjectName}"
                                   FontWeight="Bold" FontSize="13"
                                   TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center"/>
                    </DockPanel>
                </Border>

                <!-- TreeView -->
                <TreeView Grid.Row="1" x:Name="NotebookTree"
                          ItemsSource="{Binding Notebooks}"
                          SelectedItemChanged="NotebookTree_SelectedItemChanged"
                          Padding="0,4">

                    <TreeView.ItemContainerStyle>
                        <Style TargetType="TreeViewItem"
                               BasedOn="{StaticResource {x:Type TreeViewItem}}">
                            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                        </Style>
                    </TreeView.ItemContainerStyle>

                    <TreeView.Resources>

                        <!-- ── Notebook template ── -->
                        <HierarchicalDataTemplate DataType="{x:Type vm:NotebookViewModel}"
                                                  ItemsSource="{Binding Notes}">
                            <TextBlock Text="{Binding Title}"
                                       FontWeight="SemiBold" FontSize="12.5"
                                       Padding="2,1" ToolTip="{Binding Title}"
                                       AllowDrop="True"
                                       DragOver="NotebookHeader_DragOver"
                                       Drop="NotebookHeader_Drop">
                                <TextBlock.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="ノートを追加..." Click="AddNoteToNotebook_Click"/>
                                        <Separator/>
                                        <MenuItem Header="上に移動" Click="MoveNotebookUp_Click"/>
                                        <MenuItem Header="下に移動" Click="MoveNotebookDown_Click"/>
                                        <Separator/>
                                        <MenuItem Header="名前変更..."    Click="RenameNotebook_Click"/>
                                        <MenuItem Header="削除"           Click="DeleteNotebook_Click"/>
                                    </ContextMenu>
                                </TextBlock.ContextMenu>
                            </TextBlock>
                        </HierarchicalDataTemplate>

                        <!-- ── Note template ── -->
                        <DataTemplate DataType="{x:Type vm:NoteViewModel}">
                            <DockPanel PreviewMouseLeftButtonDown="NoteItem_PreviewMouseLeftButtonDown"
                                       PreviewMouseMove="NoteItem_PreviewMouseMove">
                                <DockPanel.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="上に移動" Click="MoveNoteUp_Click"/>
                                        <MenuItem Header="下に移動" Click="MoveNoteDown_Click"/>
                                        <Separator/>
                                        <MenuItem Header="名前変更..." Click="RenameNote_Click"/>
                                        <Separator/>
                                        <MenuItem Header="削除"        Click="DeleteNote_Click"/>
                                    </ContextMenu>
                                </DockPanel.ContextMenu>
                                <TextBlock DockPanel.Dock="Right"
                                           Text="●"
                                           Foreground="{DynamicResource TodoBrush}"
                                           FontSize="9"
                                           VerticalAlignment="Center"
                                           Margin="0,0,4,0"
                                           ToolTip="このノートにはマーカーがあります"
                                           Visibility="{Binding HasMarkers, Converter={StaticResource BoolToVis}}"/>
                                <TextBlock Text="{Binding Title}"
                                           FontSize="12" Padding="8,1"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip="{Binding Title}"/>
                            </DockPanel>
                        </DataTemplate>

                    </TreeView.Resources>
                </TreeView>

                <!-- Bottom toolbar -->
                <Border Grid.Row="2"
                        BorderBrush="{DynamicResource PaneBorder}" BorderThickness="0,1,0,0"
                        Background="{DynamicResource SidebarBg}" Padding="6,5">
                    <StackPanel Orientation="Horizontal">
                        <Button Content="+ ノートブック" Style="{StaticResource IconButton}"
                                FontSize="11.5" Click="AddNotebook_Click" Margin="0,0,4,0"/>
                        <Button Content="+ ノート" Style="{StaticResource IconButton}"
                                FontSize="11.5" Click="AddNote_Click"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- GridSplitter L -->
            <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch"
                          Background="{DynamicResource PaneBorder}" ShowsPreview="True"/>

            <!-- ═══ CENTER PANE: Editor ═══ -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Sample project banner -->
                <Border Grid.Row="0"
                        Background="{DynamicResource SampleBannerBg}"
                        BorderBrush="{DynamicResource SampleBannerBorder}"
                        BorderThickness="0,0,0,1"
                        Padding="14,10"
                        Visibility="{Binding IsSampleProject, Converter={StaticResource BoolToVis}}">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                    VerticalAlignment="Center" Margin="12,0,0,0">
                            <Button Content="新規プロジェクト"
                                    Command="{Binding NewProjectCommand}"
                                    Padding="10,4" Margin="0,0,8,0" FontSize="11.5"
                                    Background="{DynamicResource BannerPrimaryBg}"
                                    BorderBrush="{DynamicResource BannerPrimaryBorder}"
                                    Foreground="{DynamicResource BannerPrimaryFg}"/>
                            <Button Content="名前を付けて保存..."
                                    Command="{Binding SaveAsProjectCommand}"
                                    Padding="10,4" FontSize="11.5"
                                    Background="{DynamicResource BannerSecondaryBg}"
                                    BorderBrush="{DynamicResource BannerSecondaryBorder}"
                                    Foreground="{DynamicResource BannerSecondaryFg}"/>
                        </StackPanel>
                        <TextBlock Text="サンプルプロジェクトが表示されています。新しいプロジェクトを作成するか、.notenest ファイルとして保存してください。"
                                   FontSize="11.5" Foreground="{DynamicResource SampleBannerFg}" TextWrapping="Wrap"
                                   VerticalAlignment="Center"/>
                    </DockPanel>
                </Border>

                <!-- Note / task-comment title bar -->
                <Border Grid.Row="1"
                        BorderBrush="{DynamicResource PaneBorder}" BorderThickness="0,0,0,1"
                        Padding="14,9">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsTaskCommentMode}" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource TaskCommentTitleBg}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <DockPanel>
                        <Border DockPanel.Dock="Right" CornerRadius="4" Margin="2,0,0,0">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsModified}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource UnsavedSaveBtnBg}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Button Content="💾" Width="28" Height="28"
                                    Style="{StaticResource IconButton}"
                                    Command="{Binding SaveProjectCommand}"
                                    ToolTip="保存 (Ctrl+S)"
                                    FontSize="15"/>
                        </Border>
                        <Border DockPanel.Dock="Right"
                                Background="{DynamicResource CommentBadgeBg}" CornerRadius="3"
                                Padding="6,2" Margin="8,0,0,0"
                                VerticalAlignment="Center"
                                Visibility="{Binding IsTaskCommentMode, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="コメント編集中"
                                       FontSize="10.5" Foreground="{DynamicResource CommentBadgeFg}"/>
                        </Border>
                        <TextBlock Text="{Binding EditorTitle}"
                                   FontSize="14" FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"/>
                    </DockPanel>
                </Border>

                <!-- Related note bar (task comment mode only) -->
                <Border Grid.Row="2"
                        BorderBrush="{DynamicResource PaneBorder}" BorderThickness="0,0,0,1"
                        Background="{DynamicResource TaskCommentTitleBg}"
                        Padding="10,6"
                        Visibility="{Binding IsTaskCommentMode, Converter={StaticResource BoolToVis}}">
                    <DockPanel>
                        <Button DockPanel.Dock="Right" Content="クリア"
                                Click="ClearRelatedNote_Click"
                                Style="{StaticResource IconButton}" FontSize="11.5"
                                Margin="4,0,0,0"
                                Visibility="{Binding HasEditingTaskRelatedNote, Converter={StaticResource BoolToVis}}"/>
                        <Button DockPanel.Dock="Right" Content="開く"
                                Click="OpenRelatedNote_Click"
                                Style="{StaticResource IconButton}" FontSize="11.5"
                                Margin="4,0,0,0"
                                Visibility="{Binding HasEditingTaskRelatedNote, Converter={StaticResource BoolToVis}}"/>
                        <TextBlock Text="関連ノート：" FontSize="11.5" Foreground="{DynamicResource MutedFg}"
                                   VerticalAlignment="Center" Margin="0,0,6,0" DockPanel.Dock="Left"/>
                        <ComboBox ItemsSource="{Binding RelatedNoteChoices}"
                                  SelectedItem="{Binding EditingTaskRelatedNote, Mode=TwoWay}"
                                  DisplayMemberPath="Title"
                                  FontSize="11.5"
                                  VerticalAlignment="Center"/>
                    </DockPanel>
                </Border>

                <!-- Editor area: line number gutter + editor TextBox -->
                <Grid Grid.Row="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Line number gutter -->
                    <TextBox Grid.Column="0"
                             x:Name="LineNumberBox"
                             IsReadOnly="True" IsTabStop="False"
                             FontFamily="{Binding EditorFontFamily}"
                             FontSize="{Binding EditorFontSize}"
                             TextWrapping="NoWrap"
                             VerticalScrollBarVisibility="Hidden"
                             HorizontalScrollBarVisibility="Hidden"
                             BorderThickness="0,0,1,0"
                             BorderBrush="{DynamicResource PaneBorder}"
                             Padding="8,12,6,12"
                             Background="{DynamicResource LineNumberBg}"
                             Foreground="{DynamicResource LineNumberFg}"
                             TextAlignment="Right"
                             Text="1"
                             MinWidth="36"
                             Visibility="{Binding ShowLineNumbers, Converter={StaticResource BoolToVis}}"/>

                    <!-- Editor TextBox -->
                    <TextBox Grid.Column="1"
                             x:Name="EditorBox"
                             Text="{Binding EditorContent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             FontFamily="{Binding EditorFontFamily}"
                             FontSize="{Binding EditorFontSize}"
                             Foreground="{DynamicResource AppFg}"
                             AcceptsReturn="True"
                             AcceptsTab="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Disabled"
                             BorderThickness="0"
                             Padding="16,12"
                             VerticalContentAlignment="Top"
                             SpellCheck.IsEnabled="False"
                             Loaded="EditorBox_Loaded"
                             TextChanged="EditorBox_TextChanged">
                        <TextBox.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="切り取り(_T)"  Command="ApplicationCommands.Cut"/>
                                <MenuItem Header="コピー(_C)"    Command="ApplicationCommands.Copy"/>
                                <MenuItem Header="貼り付け(_P)"  Command="ApplicationCommands.Paste"/>
                                <Separator/>
                                <MenuItem Header="ノートリンクを開く(_L)" Click="OpenNoteLink_Click"
                                          InputGestureText="Ctrl+Enter"/>
                                <MenuItem Header="ノートリンクを挿入(_I)..." Click="InsertNoteLink_Click"/>
                            </ContextMenu>
                        </TextBox.ContextMenu>
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Setter Property="Background" Value="{DynamicResource EditorBg}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsTaskCommentMode}" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource TaskCommentEditorBg}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                </Grid>

                <!-- Marker insertion buttons -->
                <Border Grid.Row="4"
                        BorderBrush="{DynamicResource PaneBorder}" BorderThickness="0,1,0,0"
                        Background="{DynamicResource SidebarBg}"
                        Padding="12,5">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="挿入：" FontSize="11" Foreground="{DynamicResource MutedFg}"
                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <Button Content="[TODO]"  Click="InsertTodo_Click"
                                Style="{StaticResource IconButton}" FontSize="11.5"
                                Margin="0,0,4,0" ToolTip="[TODO]  をカーソル位置に挿入"/>
                        <Button Content="[FIXME]" Click="InsertFixme_Click"
                                Style="{StaticResource IconButton}" FontSize="11.5"
                                Margin="0,0,4,0" ToolTip="[FIXME]  をカーソル位置に挿入"/>
                        <Button Content="[NOTE]"  Click="InsertNote_Click"
                                Style="{StaticResource IconButton}" FontSize="11.5"
                                ToolTip="[NOTE]  をカーソル位置に挿入"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- GridSplitter R -->
            <GridSplitter Grid.Column="3" HorizontalAlignment="Stretch"
                          Background="{DynamicResource PaneBorder}" ShowsPreview="True"/>

            <!-- ═══ RIGHT PANE ═══ -->
            <Grid Grid.Column="4" Background="{DynamicResource RightPaneBg}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="3*" MinHeight="150"/>
                    <RowDefinition Height="4"/>
                    <RowDefinition Height="2*" MinHeight="100"/>
                </Grid.RowDefinitions>

                <!-- ── Tasks ── -->
                <Grid Grid.Row="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Tasks header -->
                    <Border Grid.Row="0"
                            BorderBrush="{DynamicResource PaneBorder}" BorderThickness="0,0,0,1"
                            Padding="12,9">
                        <DockPanel>
                            <Button DockPanel.Dock="Right" Content="+" Width="22" Height="22"
                                    Style="{StaticResource IconButton}"
                                    Click="AddTaskMenu_Click" ToolTip="タスクを追加"/>
                            <TextBlock Text="タスク" FontWeight="Bold" FontSize="13"
                                       VerticalAlignment="Center"/>
                        </DockPanel>
                    </Border>

                    <!-- Task groups -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding TaskGroups}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel>

                                        <!-- Group header -->
                                        <Border Padding="10,6,10,6"
                                                Background="{DynamicResource GroupHeaderBg}"
                                                BorderBrush="{DynamicResource PaneBorder}"
                                                BorderThickness="0,0,0,1"
                                                Cursor="Hand"
                                                AllowDrop="True"
                                                DragOver="TaskGroupHeader_DragOver"
                                                Drop="TaskGroupHeader_Drop">
                                            <Border.InputBindings>
                                                <MouseBinding MouseAction="LeftClick"
                                                              Command="{Binding DataContext.ToggleGroupCommand,
                                                                        RelativeSource={RelativeSource AncestorType=Window}}"
                                                              CommandParameter="{Binding}"/>
                                            </Border.InputBindings>
                                            <DockPanel>
                                                <TextBlock DockPanel.Dock="Right"
                                                           Text="{Binding CountText}"
                                                           Foreground="{DynamicResource FaintFg}" FontSize="11"
                                                           VerticalAlignment="Center" Margin="4,0,0,0"/>
                                                <Button DockPanel.Dock="Right"
                                                        Content="+" Width="18" Height="18"
                                                        FontSize="12" Padding="0"
                                                        Style="{StaticResource IconButton}"
                                                        Command="{Binding DataContext.AddTaskCommand,
                                                                  RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding Key}"
                                                        ToolTip="このグループにタスクを追加"/>
                                                <CheckBox DockPanel.Dock="Right"
                                                          IsChecked="{Binding HideCompleted}"
                                                          VerticalAlignment="Center"
                                                          Margin="0,0,4,0"
                                                          FontSize="10.5"
                                                          Content="完了非表示"
                                                          ToolTip="完了済みタスクを非表示にする"/>
                                                <TextBlock Text="{Binding Title}"
                                                           FontWeight="SemiBold" FontSize="12"
                                                           VerticalAlignment="Center"/>
                                            </DockPanel>
                                        </Border>

                                        <!-- Tasks in group -->
                                        <ItemsControl ItemsSource="{Binding VisibleTasks}"
                                                      Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVis}}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Padding="10,6"
                                                            BorderBrush="{DynamicResource ItemBorderBrush}"
                                                            BorderThickness="0,0,0,1"
                                                            AllowDrop="True"
                                                            PreviewMouseLeftButtonDown="TaskItem_PreviewMouseLeftButtonDown"
                                                            PreviewMouseMove="TaskItem_PreviewMouseMove"
                                                            DragOver="TaskItem_DragOver"
                                                            Drop="TaskItem_Drop">
                                                        <Border.ContextMenu>
                                                            <ContextMenu>
                                                                <MenuItem Header="名前変更..." Click="RenameTask_Click"/>
                                                                <MenuItem Header="グループを変更">
                                                                    <MenuItem Header="今日のタスク" Click="MoveTaskToToday_Click"/>
                                                                    <MenuItem Header="今週のタスク" Click="MoveTaskToWeek_Click"/>
                                                                    <MenuItem Header="バックログ"   Click="MoveTaskToBacklog_Click"/>
                                                                </MenuItem>
                                                                <Separator/>
                                                                <MenuItem Header="関連ノートを開く" Click="OpenRelatedNote_Click"
                                                                          Visibility="{Binding HasRelatedNote, Converter={StaticResource BoolToVis}}"/>
                                                                <MenuItem Header="関連ノートを設定..." Click="SetRelatedNote_Click"/>
                                                                <MenuItem Header="関連ノートをクリア" Click="ClearRelatedNote_Click"
                                                                          Visibility="{Binding HasRelatedNote, Converter={StaticResource BoolToVis}}"/>
                                                                <Separator/>
                                                                <MenuItem Header="削除" Click="DeleteTask_Click"/>
                                                            </ContextMenu>
                                                        </Border.ContextMenu>
                                                        <DockPanel>
                                                            <CheckBox IsChecked="{Binding IsCompleted}"
                                                                      VerticalAlignment="Center"
                                                                      Margin="0,0,8,0"/>
                                                            <TextBlock DockPanel.Dock="Right"
                                                                       Text="🔗"
                                                                       FontSize="9"
                                                                       VerticalAlignment="Center"
                                                                       Margin="4,0,0,0"
                                                                       ToolTip="関連ノートが設定されています"
                                                                       Visibility="{Binding HasRelatedNote, Converter={StaticResource BoolToVis}}"/>
                                                            <TextBlock DockPanel.Dock="Right"
                                                                       Text="●"
                                                                       Foreground="{DynamicResource TaskCommentIndicator}"
                                                                       FontSize="9"
                                                                       VerticalAlignment="Center"
                                                                       Margin="4,0,0,0"
                                                                       ToolTip="このタスクにはコメントがあります"
                                                                       Visibility="{Binding HasComment, Converter={StaticResource BoolToVis}}"/>
                                                            <TextBlock Text="{Binding Title}"
                                                                       VerticalAlignment="Center"
                                                                       TextWrapping="Wrap"
                                                                       FontSize="12.5"
                                                                       MouseLeftButtonDown="TaskTitle_MouseLeftButtonDown">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="ToolTip" Value="ダブルクリックでコメントを追加"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                                                <Setter Property="TextDecorations" Value="Strikethrough"/>
                                                                                <Setter Property="Foreground" Value="{DynamicResource TaskCompletedFg}"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding HasComment}" Value="True">
                                                                                <Setter Property="ToolTip" Value="ダブルクリックでコメントを編集"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </DockPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>

                <!-- Horizontal GridSplitter -->
                <GridSplitter Grid.Row="1" HorizontalAlignment="Stretch"
                              Background="{DynamicResource PaneBorder}" ShowsPreview="True"/>

                <!-- ── Markers ── -->
                <Grid Grid.Row="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Markers header -->
                    <Border Grid.Row="0"
                            BorderBrush="{DynamicResource PaneBorder}" BorderThickness="0,0,0,1"
                            Padding="12,9">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Right"
                                       Text="{Binding FilteredMarkerCountText}"
                                       Foreground="{DynamicResource MutedFg}" FontSize="12"
                                       VerticalAlignment="Center"/>
                            <TextBlock DockPanel.Dock="Right"
                                       Text="？"
                                       Foreground="{DynamicResource HintFg}"
                                       FontSize="12"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"
                                       Cursor="Help">
                                <TextBlock.ToolTip>
                                    <ToolTip>
                                        <StackPanel Margin="4,2">
                                            <TextBlock Text="利用可能なマーカー:" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                            <TextBlock Text="[TODO]   やること"   Margin="0,0,0,3"/>
                                            <TextBlock Text="[FIXME]  修正が必要" Margin="0,0,0,3"/>
                                            <TextBlock Text="[NOTE]   メモ・補足"/>
                                        </StackPanel>
                                    </ToolTip>
                                </TextBlock.ToolTip>
                            </TextBlock>
                            <TextBlock Text="マーカー" FontWeight="Bold" FontSize="13"
                                       VerticalAlignment="Center"/>
                        </DockPanel>
                    </Border>

                    <!-- Marker filter row -->
                    <Border Grid.Row="1"
                            BorderBrush="{DynamicResource PaneBorder}" BorderThickness="0,0,0,1"
                            Background="{DynamicResource RightPaneBg}" Padding="10,5">
                        <StackPanel Orientation="Horizontal">
                            <CheckBox Content="TODO"  IsChecked="{Binding FilterTodo}"
                                      Foreground="{DynamicResource TodoBrush}"  FontSize="11" Margin="0,0,10,0"/>
                            <CheckBox Content="FIXME" IsChecked="{Binding FilterFixme}"
                                      Foreground="{DynamicResource FixmeBrush}" FontSize="11" Margin="0,0,10,0"/>
                            <CheckBox Content="NOTE"  IsChecked="{Binding FilterNote}"
                                      Foreground="{DynamicResource NoteBrush}"  FontSize="11"/>
                        </StackPanel>
                    </Border>

                    <!-- Marker list -->
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding FilteredMarkers}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="10,8"
                                            BorderBrush="{DynamicResource ItemBorderBrush}" BorderThickness="0,0,0,1"
                                            Cursor="Hand"
                                            MouseLeftButtonDown="Marker_MouseLeftButtonDown">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource MarkerHoverBg}"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <DockPanel>
                                                <TextBlock Text="{Binding Type}"
                                                           FontWeight="Bold" FontSize="11"
                                                           Width="46" DockPanel.Dock="Left">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{DynamicResource PrimaryFg}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Type}" Value="TODO">
                                                                    <Setter Property="Foreground" Value="{DynamicResource TodoBrush}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Type}" Value="FIXME">
                                                                    <Setter Property="Foreground" Value="{DynamicResource FixmeBrush}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Type}" Value="NOTE">
                                                                    <Setter Property="Foreground" Value="{DynamicResource NoteBrush}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <TextBlock Text="{Binding LineLabel}"
                                                           Foreground="{DynamicResource MutedFg}" FontSize="11"
                                                           Margin="0,0,6,0" VerticalAlignment="Center"
                                                           DockPanel.Dock="Left"/>
                                                <TextBlock Text="{Binding NoteTitle}"
                                                           Foreground="{DynamicResource SecondaryFg}" FontSize="11"
                                                           VerticalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </DockPanel>
                                            <TextBlock Text="{Binding Excerpt}"
                                                       Foreground="{DynamicResource PrimaryFg}" FontSize="11.5"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="0,3,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Project-wide marker summary -->
                    <Border Grid.Row="3"
                            BorderBrush="{DynamicResource PaneBorder}" BorderThickness="0,1,0,0"
                            Background="{DynamicResource SidebarBg}"
                            Padding="12,6">
                        <TextBlock Text="{Binding ProjectMarkerSummary}"
                                   FontSize="11" Foreground="{DynamicResource MutedFg}"
                                   TextWrapping="Wrap"/>
                    </Border>
                </Grid>

            </Grid>
        </Grid>
    </DockPanel>
</Window>
