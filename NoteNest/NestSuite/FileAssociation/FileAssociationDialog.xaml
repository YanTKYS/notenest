<Window x:Class="NoteNest.NestSuite.FileAssociation.FileAssociationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ファイル関連付けの設定"
        Width="520" Height="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">

            <!-- 現在の状態 -->
            <TextBlock Text="現在の状態" FontWeight="Bold" FontSize="13" Margin="0,0,0,4"/>
            <TextBlock Text="（HKCU\Software\Classes で確認できる範囲）"
                       FontSize="11" Foreground="Gray" Margin="0,0,0,8"/>
            <Border BorderBrush="LightGray" BorderThickness="1" Padding="10,8" Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="26"/>
                        <RowDefinition Height="26"/>
                        <RowDefinition Height="26"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text=".notenest" FontFamily="Consolas" VerticalAlignment="Center"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" x:Name="StatusNotenest" VerticalAlignment="Center"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text=".chatnest"  FontFamily="Consolas" VerticalAlignment="Center"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="StatusChatnest"  VerticalAlignment="Center"/>
                    <TextBlock Grid.Row="2" Grid.Column="0" Text=".ideanest"  FontFamily="Consolas" VerticalAlignment="Center"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" x:Name="StatusIdeanest"  VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- 登録先 -->
            <TextBlock Text="登録先" FontWeight="Bold" Margin="0,0,0,4"/>
            <TextBlock x:Name="ExePathLabel" TextWrapping="Wrap" FontSize="11" FontFamily="Consolas"
                       Margin="0,0,0,16"/>

            <!-- 登録後の動作 -->
            <TextBlock Text="登録後の動作" FontWeight="Bold" Margin="0,0,0,4"/>
            <TextBlock FontSize="11" Margin="0,0,0,2"
                       Text="  .notenest  →  NoteNest Workspace として開く"/>
            <TextBlock FontSize="11" Margin="0,0,0,2"
                       Text="  .chatnest  →  ChatNest Workspace として開く"/>
            <TextBlock FontSize="11" Margin="0,0,0,16"
                       Text="  .ideanest  →  IdeaNest Workspace として開く"/>

            <!-- 注意事項 -->
            <TextBlock Text="注意事項" FontWeight="Bold" Margin="0,0,0,4"/>
            <TextBlock FontSize="11" Margin="0,0,0,2"
                       Text="・ユーザー単位（HKCU）の設定です。管理者権限は不要です。"/>
            <TextBlock FontSize="11" Margin="0,0,0,2"
                       Text="・NoteNest.exe の配置場所を変えた場合は再登録が必要です。"/>
            <TextBlock FontSize="11" Margin="0,0,0,2"
                       Text="・アプリ起動時に自動登録されるものではありません。"/>
            <TextBlock FontSize="11" Margin="0,0,0,16" TextWrapping="Wrap"
                       Text="・関連付けが反映されない場合は、Windows の「設定 → 既定のアプリ」を確認してください。"/>

            <!-- ボタン -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="関連付けを登録" Margin="0,0,8,0" Padding="12,5"
                        Click="RegisterButton_Click"/>
                <Button Content="関連付けを解除" Margin="0,0,8,0" Padding="12,5"
                        Click="UnregisterButton_Click"/>
                <Button Content="閉じる" Padding="12,5" IsCancel="True" Click="CloseButton_Click"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Window>
