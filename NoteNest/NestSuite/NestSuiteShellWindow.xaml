<Window x:Class="NoteNest.NestSuite.NestSuiteShellWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:NoteNest.Views"
        xmlns:chatnest="clr-namespace:NoteNest.NestSuite.ChatNest"
        Title="NestSuite — NoteNest"
        Height="720" Width="1280"
        MinHeight="500" MinWidth="800"
        WindowStartupLocation="CenterScreen">
    <DockPanel>
        <!-- v1.6.4 NestSuite メニュー（ファイル操作・ツール選択・ヘルプ） -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="ファイル(_F)">
                <MenuItem Header="新規プロジェクト(_N)" Command="{Binding NewProjectCommand}"/>
                <MenuItem Header="プロジェクトを開く(_O)..." Command="{Binding OpenProjectCommand}"/>
                <Separator/>
                <MenuItem Header="上書き保存(_S)" Command="{Binding SaveProjectCommand}"/>
                <MenuItem Header="名前を付けて保存(_A)..." Command="{Binding SaveAsProjectCommand}"/>
                <Separator/>
                <MenuItem Header="終了(_X)" Click="MenuExit_Click"/>
            </MenuItem>
            <MenuItem Header="ツール(_T)">
                <!-- v1.6.4: ツール切替対応。未統合ツールも選択可（プレースホルダー表示） -->
                <MenuItem x:Name="ToolMenuNoteNest" Header="NoteNest"
                          Tag="NoteNest"
                          IsCheckable="True" IsChecked="True"
                          Click="MenuTool_Click"/>
                <MenuItem x:Name="ToolMenuIdeaNest" Header="IdeaNest"
                          Tag="IdeaNest"
                          IsCheckable="True"
                          ToolTip="未統合（将来対応予定）"
                          Click="MenuTool_Click"/>
                <MenuItem x:Name="ToolMenuChatNest" Header="ChatNest"
                          Tag="ChatNest"
                          IsCheckable="True"
                          ToolTip="統合検証（v1.7.0）"
                          Click="MenuTool_Click"/>
            </MenuItem>
            <MenuItem Header="ヘルプ(_H)">
                <MenuItem Header="NestSuite について" Click="MenuAbout_Click"/>
            </MenuItem>
        </Menu>

        <!-- NestSuite ヘッダーバー -->
        <Border DockPanel.Dock="Top" Height="32"
                Background="{DynamicResource GroupHeaderBg}"
                BorderBrush="{DynamicResource PaneBorder}"
                BorderThickness="0,0,0,1">
            <TextBlock Text="NestSuite" FontWeight="Bold" FontSize="13"
                       VerticalAlignment="Center" Margin="12,0"
                       Foreground="{DynamicResource PrimaryFg}"/>
        </Border>

        <!-- NestSuite ステータスバー（プロジェクト名・未保存・選択ツール動的表示） -->
        <Border DockPanel.Dock="Bottom" Height="22"
                Background="{DynamicResource StatusBarBg}"
                BorderBrush="{DynamicResource PaneBorder}"
                BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0">
                <TextBlock Text="{Binding ProjectDisplayName}"
                           FontSize="11" Foreground="{DynamicResource MutedFg}"/>
                <TextBlock Text="{Binding UnsavedIndicatorText}"
                           FontSize="11" Foreground="{DynamicResource UnsavedBrush}"
                           Visibility="{Binding IsModified, Converter={StaticResource BoolToVis}}"/>
                <TextBlock x:Name="NestSuiteModeSuffix"
                           Text="  /  NoteNest"
                           FontSize="11" Foreground="{DynamicResource MutedFg}"/>
            </StackPanel>
        </Border>

        <!-- メインエリア: ツール選択領域 + Workspace 領域 -->
        <Grid>
            <Grid.ColumnDefinitions>
                <!-- ツール選択: 固定幅 -->
                <ColumnDefinition Width="120"/>
                <!-- Workspace 領域: 残り幅 -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ツール選択領域（v1.6.4: 選択可能・ツール切替対応） -->
            <Border Grid.Column="0"
                    Background="{DynamicResource SidebarBg}"
                    BorderBrush="{DynamicResource PaneBorder}"
                    BorderThickness="0,0,1,0">
                <StackPanel x:Name="ToolSelectorPanel" Margin="0,10,0,0">
                    <TextBlock Text="ツール" FontSize="10" FontWeight="SemiBold"
                               Foreground="{DynamicResource MutedFg}"
                               Margin="10,0,10,6"/>
                    <!-- NoteNest: 統合済み・初期選択 -->
                    <Border x:Name="NoteNestToolBorder"
                            Tag="NoteNest"
                            Background="{DynamicResource SelectedNoteBg}"
                            CornerRadius="4" Margin="6,1" Padding="8,5"
                            Cursor="Hand"
                            MouseLeftButtonDown="ToolBorder_MouseDown">
                        <TextBlock x:Name="NoteNestToolLabel"
                                   Text="NoteNest" FontSize="12"
                                   Foreground="{DynamicResource PrimaryFg}"/>
                    </Border>
                    <!-- IdeaNest: 未統合・選択可（プレースホルダー表示） -->
                    <Border x:Name="IdeaNestToolBorder"
                            Tag="IdeaNest"
                            CornerRadius="4" Margin="6,1" Padding="8,5"
                            Cursor="Hand"
                            ToolTip="未統合（将来対応予定）"
                            MouseLeftButtonDown="ToolBorder_MouseDown">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="IdeaNest" FontSize="12"
                                       Foreground="{DynamicResource SubtleFg}"/>
                            <TextBlock Text=" 未統合" FontSize="9"
                                       Foreground="{DynamicResource MutedFg}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <!-- ChatNest: v1.7.0 統合検証・選択可（Workspace 表示） -->
                    <Border x:Name="ChatNestToolBorder"
                            Tag="ChatNest"
                            CornerRadius="4" Margin="6,1" Padding="8,5"
                            Cursor="Hand"
                            ToolTip="統合検証（v1.7.0）"
                            MouseLeftButtonDown="ToolBorder_MouseDown">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="ChatNest" FontSize="12"
                                       Foreground="{DynamicResource PrimaryFg}"/>
                            <TextBlock Text=" 検証" FontSize="9"
                                       Foreground="{DynamicResource MutedFg}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Workspace 領域: 選択ツールに応じて各 Workspace またはプレースホルダーを表示 -->
            <Grid Grid.Column="1">
                <views:NoteNestWorkspaceView x:Name="WorkspaceView"/>
                <!-- v1.7.0: ChatNest 統合検証用 Workspace（ChatNest 選択時に表示） -->
                <chatnest:ChatNestWorkspaceView x:Name="ChatWorkspaceView" Visibility="Collapsed"/>
                <!-- 未統合ツール選択時のプレースホルダー -->
                <Border x:Name="UnintegratedPlaceholder" Visibility="Collapsed"
                        Background="{DynamicResource SidebarBg}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                Margin="24">
                        <TextBlock x:Name="PlaceholderTitle"
                                   FontSize="18" FontWeight="Bold"
                                   TextAlignment="Center"
                                   Foreground="{DynamicResource MutedFg}"
                                   Margin="0,0,0,16"/>
                        <TextBlock x:Name="PlaceholderMessage"
                                   FontSize="13" TextAlignment="Center"
                                   Foreground="{DynamicResource SubtleFg}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
