<Window x:Class="NoteNest.NestSuite.NestSuiteShellWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:NoteNest.Views"
        Title="NestSuite — NoteNest"
        Height="720" Width="1280"
        MinHeight="500" MinWidth="800"
        WindowStartupLocation="CenterScreen">
    <DockPanel>
        <!--
            v1.6.0 NestSuite 最小 AppShell ヘッダー。
            v1.6.0 では NoteNest のみを搭載。メニュー・ステータスバー・ウィンドウ設定は未実装。
            将来は他ツール（IdeaNest 等）のタブ切替領域として拡張する想定。
        -->
        <Border DockPanel.Dock="Top" Height="30"
                Background="{DynamicResource GroupHeaderBg}"
                BorderBrush="{DynamicResource PaneBorder}"
                BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0">
                <TextBlock Text="NestSuite" FontWeight="SemiBold" FontSize="13"/>
                <TextBlock Text=" | " Margin="6,0" Foreground="{DynamicResource PaneBorder}"/>
                <TextBlock Text="NoteNest" FontSize="13"/>
            </StackPanel>
        </Border>

        <!-- Workspace: v1.6.0 では NoteNestWorkspaceView のみ配置 -->
        <views:NoteNestWorkspaceView x:Name="WorkspaceView"/>
    </DockPanel>
</Window>
