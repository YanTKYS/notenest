<Window x:Class="NoteNest.NestSuite.NestSuiteShellWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:NoteNest.Views"
        Title="NestSuite — NoteNest"
        Height="720" Width="1280"
        MinHeight="500" MinWidth="800"
        WindowStartupLocation="CenterScreen">
    <DockPanel>
        <!-- v1.6.3 NestSuite メニュー（ファイル操作・ツール選択・ヘルプ） -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="ファイル(_F)">
                <MenuItem Header="新規プロジェクト(_N)" Command="{Binding NewProjectCommand}"/>
                <MenuItem Header="プロジェクトを開く(_O)..." Command="{Binding OpenProjectCommand}"/>
                <Separator/>
                <MenuItem Header="上書き保存(_S)" Command="{Binding SaveProjectCommand}"/>
                <MenuItem Header="名前を付けて保存(_A)..." Command="{Binding SaveAsProjectCommand}"/>
                <Separator/>
                <MenuItem Header="終了(_X)" Click="MenuExit_Click"/>
            </MenuItem>
            <MenuItem Header="ツール(_T)">
                <!-- NoteNest: 統合済み・常に選択中。v1.6.4 以降でツール切替を実装予定 -->
                <MenuItem Header="NoteNest" IsCheckable="True" IsChecked="True"
                          Click="MenuToolNoteNest_Click"/>
                <MenuItem Header="IdeaNest" IsEnabled="False"
                          ToolTip="未統合（将来対応予定）"/>
                <MenuItem Header="ChatNest" IsEnabled="False"
                          ToolTip="未統合（将来対応予定）"/>
            </MenuItem>
            <MenuItem Header="ヘルプ(_H)">
                <MenuItem Header="NestSuite について" Click="MenuAbout_Click"/>
            </MenuItem>
        </Menu>

        <!-- NestSuite ヘッダーバー -->
        <Border DockPanel.Dock="Top" Height="32"
                Background="{DynamicResource GroupHeaderBg}"
                BorderBrush="{DynamicResource PaneBorder}"
                BorderThickness="0,0,0,1">
            <TextBlock Text="NestSuite" FontWeight="Bold" FontSize="13"
                       VerticalAlignment="Center" Margin="12,0"
                       Foreground="{DynamicResource PrimaryFg}"/>
        </Border>

        <!-- NestSuite ステータスバー（v1.6.3: プロジェクト名・未保存インジケーター動的表示） -->
        <Border DockPanel.Dock="Bottom" Height="22"
                Background="{DynamicResource StatusBarBg}"
                BorderBrush="{DynamicResource PaneBorder}"
                BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0">
                <TextBlock Text="{Binding ProjectDisplayName}"
                           FontSize="11" Foreground="{DynamicResource MutedFg}"/>
                <TextBlock Text="{Binding UnsavedIndicatorText}"
                           FontSize="11" Foreground="{DynamicResource UnsavedBrush}"
                           Visibility="{Binding IsModified, Converter={StaticResource BoolToVis}}"/>
                <TextBlock Text="  /  NestSuite mode"
                           FontSize="11" Foreground="{DynamicResource MutedFg}"/>
            </StackPanel>
        </Border>

        <!-- メインエリア: ツール選択領域 + Workspace 領域 -->
        <Grid>
            <Grid.ColumnDefinitions>
                <!-- ツール選択: 固定幅 -->
                <ColumnDefinition Width="120"/>
                <!-- Workspace 領域: 残り幅 -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!--
                ツール状態表示領域（v1.6.2）。
                NoteNest = 統合済み（ハイライト表示）、IdeaNest / ChatNest = 未統合（半透明）。
                ツール切替インタラクションは v1.6.4 以降で実装予定。
            -->
            <Border Grid.Column="0"
                    Background="{DynamicResource SidebarBg}"
                    BorderBrush="{DynamicResource PaneBorder}"
                    BorderThickness="0,0,1,0">
                <StackPanel x:Name="ToolSelectorPanel" Margin="0,10,0,0">
                    <TextBlock Text="ツール" FontSize="10" FontWeight="SemiBold"
                               Foreground="{DynamicResource MutedFg}"
                               Margin="10,0,10,6"/>
                    <!-- NoteNest: 統合済み・表示中 -->
                    <Border Background="{DynamicResource SelectedNoteBg}"
                            CornerRadius="4" Margin="6,1" Padding="8,5">
                        <TextBlock x:Name="NoteNestToolLabel"
                                   Text="NoteNest" FontSize="12"
                                   Foreground="{DynamicResource PrimaryFg}"/>
                    </Border>
                    <!-- IdeaNest: 未統合（将来対応予定） -->
                    <Border Margin="6,1" Padding="8,5" Opacity="0.45"
                            ToolTip="未統合（将来対応予定）">
                        <TextBlock Text="IdeaNest" FontSize="12"
                                   Foreground="{DynamicResource SubtleFg}"/>
                    </Border>
                    <!-- ChatNest: 未統合（将来対応予定） -->
                    <Border Margin="6,1" Padding="8,5" Opacity="0.45"
                            ToolTip="未統合（将来対応予定）">
                        <TextBlock Text="ChatNest" FontSize="12"
                                   Foreground="{DynamicResource SubtleFg}"/>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Workspace 領域: v1.6.2 では NoteNestWorkspaceView を配置 -->
            <views:NoteNestWorkspaceView x:Name="WorkspaceView" Grid.Column="1"/>
        </Grid>
    </DockPanel>
</Window>
