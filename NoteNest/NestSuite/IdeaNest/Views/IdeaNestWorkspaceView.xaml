<UserControl x:Class="NoteNest.NestSuite.IdeaNest.Views.IdeaNestWorkspaceView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:NoteNest.NestSuite.IdeaNest.ViewModels"
        Background="{StaticResource IdeaAppBackgroundBrush}"
        TextOptions.TextFormattingMode="Display" UseLayoutRounding="True">
    <UserControl.InputBindings>
        <KeyBinding Modifiers="Ctrl+Shift" Key="N" Command="{Binding AddIdeaCommand}" />
        <KeyBinding Modifiers="Ctrl+Shift" Key="C" Command="{Binding CopyAllMarkdownCommand}" />
        <KeyBinding Modifiers="Ctrl+Shift" Key="R" Command="{Binding RandomPreviewCommand}" />
    </UserControl.InputBindings>
    <DockPanel>
        <!-- Menu (kept minimal: no border below) -->
        <Menu x:Name="WorkspaceMenu" DockPanel.Dock="Top" Background="Transparent" Padding="4,2"
              Visibility="{Binding ShowMenu, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource IdeaBoolToVis}}">
            <MenuItem Header="ファイル(_F)">
                <MenuItem Header="エクスポート(_E)">
                    <MenuItem Header="Markdown風テキスト(_M)..." Command="{Binding ExportMarkdownCommand}" />
                    <MenuItem Header="NoteNest向けテキスト(_N)..." Command="{Binding ExportNoteNestCommand}" />
                </MenuItem>
            </MenuItem>
            <MenuItem Header="編集(_E)">
                <MenuItem Header="新規カード追加(_N)" InputGestureText="Ctrl+Shift+N"
                          Command="{Binding AddIdeaCommand}" />
                <Separator />
                <MenuItem Header="検索(_F)" InputGestureText="Ctrl+F"
                          Click="OnFocusSearchClick" />
                <Separator />
                <MenuItem Header="タグ管理(_T)..." Command="{Binding ManageTagsCommand}" />
                <Separator />
                <MenuItem Header="表示中カードをMarkdown形式でコピー(_C)" InputGestureText="Ctrl+Shift+C"
                          Command="{Binding CopyAllMarkdownCommand}" />
                <MenuItem Header="表示中カードをNoteNest向けにコピー(_N)"
                          Command="{Binding CopyNoteNestCommand}" />
                <Separator />
                <MenuItem Header="壁打ち — ランダムにプレビュー(_R)" InputGestureText="Ctrl+Shift+R"
                          Command="{Binding RandomPreviewCommand}" />
            </MenuItem>
            <MenuItem Header="表示(_V)">
                <MenuItem Header="アーカイブを表示" IsCheckable="True" IsChecked="{Binding ShowArchived, Mode=TwoWay}" />
                <MenuItem Header="タグパネル" IsCheckable="True" IsChecked="{Binding IsTagPanelOpen, Mode=TwoWay}" />
                <Separator />
                <MenuItem Header="カードサイズ(_Z)">
                    <MenuItem Header="小 (S)" IsCheckable="True"
                              IsChecked="{Binding IsCardSizeSmall, Mode=OneWay}"
                              Command="{Binding SetCardSizeCommand}" CommandParameter="small" />
                    <MenuItem Header="中 (M)" IsCheckable="True"
                              IsChecked="{Binding IsCardSizeMedium, Mode=OneWay}"
                              Command="{Binding SetCardSizeCommand}" CommandParameter="medium" />
                    <MenuItem Header="大 (L)" IsCheckable="True"
                              IsChecked="{Binding IsCardSizeLarge, Mode=OneWay}"
                              Command="{Binding SetCardSizeCommand}" CommandParameter="large" />
                </MenuItem>
                <MenuItem Header="カード高さ(_H)">
                    <MenuItem Header="固定" IsCheckable="True"
                              IsChecked="{Binding IsCardHeightFixed, Mode=OneWay}"
                              Command="{Binding SetCardHeightModeCommand}" CommandParameter="fixed" />
                    <MenuItem Header="本文に合わせる" IsCheckable="True"
                              IsChecked="{Binding IsCardHeightAuto, Mode=OneWay}"
                              Command="{Binding SetCardHeightModeCommand}" CommandParameter="auto" />
                </MenuItem>
            </MenuItem>
        </Menu>

        <!-- Search & filter bar (compact) -->
        <Border DockPanel.Dock="Top" Background="Transparent" Padding="16,8,16,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Tag panel toggle -->
                <Button Grid.Column="0"
                        Content="{Binding TagPanelButtonLabel}"
                        ToolTip="{Binding TagPanelButtonTip}"
                        Command="{Binding ToggleTagPanelCommand}"
                        Style="{StaticResource IdeaIconButtonStyle}"
                        Padding="8,4" Margin="0,0,8,0"
                        FontSize="12" />

                <!-- Search box -->
                <Grid Grid.Column="1">
                    <TextBox x:Name="SearchBox"
                             Style="{StaticResource IdeaSearchTextBoxStyle}"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="タイトル・本文・タグを検索 (Ctrl+F)"
                             PreviewKeyDown="OnSearchBoxPreviewKeyDown"
                             Padding="10,6,30,6" />
                    <TextBlock Text="タイトル・本文・タグを検索"
                               IsHitTestVisible="False"
                               VerticalAlignment="Center"
                               Margin="12,0,0,0"
                               Foreground="{StaticResource IdeaTextSecondaryBrush}"
                               FontSize="13">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <Button Content="✕"
                            Style="{StaticResource IdeaIconButtonStyle}"
                            Command="{Binding ClearSearchCommand}"
                            HorizontalAlignment="Right" VerticalAlignment="Center"
                            Margin="0,0,4,0"
                            ToolTip="検索をクリア (Esc)"
                            Visibility="{Binding SearchText, Converter={StaticResource IdeaStringToVis}}" />
                </Grid>

                <!-- Count badge -->
                <TextBlock Grid.Column="2" Text="{Binding CountText}"
                           Foreground="{StaticResource IdeaTextSecondaryBrush}" FontSize="12"
                           VerticalAlignment="Center" Margin="12,0,0,0" />

                <!-- Active tag chip -->
                <Border Grid.Column="3" VerticalAlignment="Center" Margin="10,0,0,0"
                        Visibility="{Binding SelectedTag, Converter={StaticResource IdeaStringToVis}}"
                        Background="{StaticResource IdeaChipBackgroundBrush}"
                        CornerRadius="9" Padding="10,4">
                    <TextBlock Text="{Binding SelectedTag, StringFormat='#{0}'}"
                               Foreground="{StaticResource IdeaChipForegroundBrush}" FontSize="12" />
                </Border>

                <!-- Archive toggle -->
                <CheckBox Grid.Column="4" Content="アーカイブを表示"
                          IsChecked="{Binding ShowArchived, Mode=TwoWay}"
                          Foreground="{StaticResource IdeaTextSecondaryBrush}"
                          VerticalAlignment="Center" Margin="14,0,0,0" />
            </Grid>
        </Border>

        <!-- Color filter strip (compact) + card size toggle -->
        <Border DockPanel.Dock="Top" Background="Transparent" Padding="16,0,16,6">
            <DockPanel>
                <!-- Sort + card size toggle (right side) -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="並び:" Foreground="{StaticResource IdeaTextSecondaryBrush}"
                               FontSize="12" VerticalAlignment="Center" Margin="12,0,6,0" />
                    <ComboBox ItemsSource="{Binding SortOptions}"
                              SelectedValue="{Binding SortMode, Mode=TwoWay}"
                              SelectedValuePath="Value"
                              DisplayMemberPath="DisplayName"
                              FontSize="12" MinWidth="106"
                              VerticalContentAlignment="Center"
                              ToolTip="カードの並び順を選択" />
                    <Button Content="🔀" ToolTip="再シャッフル"
                            Style="{StaticResource IdeaIconButtonStyle}"
                            Command="{Binding ReshuffleCommand}"
                            Padding="6,4" Margin="4,0,0,0"
                            Visibility="{Binding IsShuffleMode, Converter={StaticResource IdeaBoolToVis}}" />
                    <Button Content="🎲" ToolTip="壁打ち — ランダムに 1 枚プレビュー (Ctrl+Shift+R)"
                            Style="{StaticResource IdeaIconButtonStyle}"
                            Command="{Binding RandomPreviewCommand}"
                            Padding="6,4" Margin="4,0,0,0" />
                    <TextBlock Text="サイズ:" Foreground="{StaticResource IdeaTextSecondaryBrush}"
                               FontSize="12" VerticalAlignment="Center" Margin="12,0,6,0" />
                    <Button Content="S" ToolTip="小 (コンパクト)"
                            Command="{Binding SetCardSizeCommand}" CommandParameter="small"
                            Padding="6,4" Margin="0,0,2,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource IdeaIconButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsCardSizeSmall}" Value="True">
                                        <Setter Property="Background" Value="#FFE4D2" />
                                        <Setter Property="Foreground" Value="{StaticResource IdeaAccentBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="M" ToolTip="中 (標準)"
                            Command="{Binding SetCardSizeCommand}" CommandParameter="medium"
                            Padding="6,4" Margin="0,0,2,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource IdeaIconButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsCardSizeMedium}" Value="True">
                                        <Setter Property="Background" Value="#FFE4D2" />
                                        <Setter Property="Foreground" Value="{StaticResource IdeaAccentBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="L" ToolTip="大 (広い)"
                            Command="{Binding SetCardSizeCommand}" CommandParameter="large"
                            Padding="6,4" Margin="0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource IdeaIconButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsCardSizeLarge}" Value="True">
                                        <Setter Property="Background" Value="#FFE4D2" />
                                        <Setter Property="Foreground" Value="{StaticResource IdeaAccentBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
                <!-- Color filter (left side) -->
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="色:" Foreground="{StaticResource IdeaTextSecondaryBrush}"
                               FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <Button Content="(すべて)"
                            Command="{Binding ClearColorCommand}"
                            Style="{StaticResource IdeaIconButtonStyle}"
                            Padding="8,4" Margin="0,0,8,0"
                            ToolTip="色フィルタを解除" />
                    <ListBox ItemsSource="{Binding ColorItems}"
                             SelectedValue="{Binding SelectedColor, Mode=TwoWay}"
                             SelectedValuePath="Name"
                             Background="Transparent" BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Disabled">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Margin" Value="0,0,4,0" />
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="Cursor" Value="Hand" />
                                <Setter Property="ToolTip" Value="{Binding DisplayName}" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="Ring" Width="22" Height="22" CornerRadius="11"
                                                    Background="Transparent"
                                                    BorderBrush="Transparent" BorderThickness="2"
                                                    Padding="2">
                                                <Ellipse Fill="{Binding Name, Converter={StaticResource IdeaColorNameToBrush}}"
                                                         Stroke="#D1D5DB" StrokeThickness="1" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Ring" Property="BorderBrush" Value="#FFE4D2" />
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Ring" Property="BorderBrush" Value="{StaticResource IdeaAccentBrush}" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom" Background="Transparent" Padding="16,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text=""
                           Foreground="{StaticResource IdeaTextSecondaryBrush}"
                           FontSize="12" VerticalAlignment="Center" />
                <TextBlock Grid.Column="1" Text="{Binding StatusMessage}"
                           Foreground="{StaticResource IdeaTextSecondaryBrush}"
                           FontSize="12" VerticalAlignment="Center"
                           HorizontalAlignment="Right" />
            </Grid>
        </Border>

        <!-- Body: collapsible tag list + cards -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Tag side panel -->
            <Border Grid.Column="0" Width="200"
                    Background="{StaticResource IdeaSurfaceBrush}"
                    BorderBrush="{StaticResource IdeaBorderBrush}" BorderThickness="0,0,1,0"
                    Padding="16,8,8,8"
                    Visibility="{Binding IsTagPanelOpen, Converter={StaticResource IdeaBoolToVis}}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="タグ"
                               Style="{StaticResource IdeaSectionHeaderStyle}"
                               Margin="6,4,0,8" />
                    <Button DockPanel.Dock="Top" Content="(すべて)"
                            Command="{Binding ClearTagCommand}"
                            Style="{StaticResource IdeaIconButtonStyle}"
                            HorizontalContentAlignment="Left"
                            HorizontalAlignment="Stretch"
                            Padding="8,6" Margin="0,0,0,4" />
                    <ListBox ItemsSource="{Binding VisibleTagPanelItems}"
                             SelectedValue="{Binding SelectedTag, Mode=TwoWay}"
                             SelectedValuePath="Name"
                             BorderThickness="0" Background="Transparent"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="Padding" Value="8,6" />
                                <Setter Property="Margin" Value="0,1" />
                                <Setter Property="Foreground" Value="{StaticResource IdeaTextPrimaryBrush}" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="Bd"
                                                    Background="{TemplateBinding Background}"
                                                    CornerRadius="6"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource IdeaHoverOverlayBrush}" />
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#FFE4D2" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding DisplayName}" FontSize="12"
                                               Foreground="{StaticResource IdeaTextPrimaryBrush}" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Count}" FontSize="11"
                                               Foreground="{StaticResource IdeaTextSecondaryBrush}"
                                               Margin="6,0,0,0" VerticalAlignment="Center" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <Grid Grid.Column="1" x:Name="CardArea"
                  Background="Transparent"
                  Focusable="True"
                  FocusVisualStyle="{x:Null}"
                  AllowDrop="True"
                  DragOver="OnCardAreaDragOver"
                  Drop="OnCardAreaDrop"
                  MouseDown="OnCardAreaMouseDown">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12,8,12,12"
                              Visibility="{Binding ShowEmptyState, Converter={StaticResource IdeaBoolToVisInverse}}">
                    <ItemsControl ItemsSource="{Binding VisibleCards}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource IdeaCardContainerStyle}"
                                        Width="{Binding DataContext.CardWidth, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        Height="{Binding DataContext.CardHeight, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        MinHeight="{Binding DataContext.CardMinHeight, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        MaxHeight="{Binding DataContext.CardMaxHeight, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        VerticalAlignment="Top"
                                        ClipToBounds="True"
                                        Background="{Binding BackgroundBrush, Converter={StaticResource IdeaHexToBrush}}"
                                        MouseLeftButtonUp="OnCardMouseLeftButtonUp">
                                    <Border.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="プレビュー(_V)"
                                                      Command="{Binding DataContext.PreviewIdeaCommand, Source={x:Reference CardArea}}"
                                                      CommandParameter="{Binding}" />
                                            <Separator />
                                            <MenuItem Header="Markdown形式でコピー(_C)"
                                                      Command="{Binding DataContext.CopyCardMarkdownCommand, Source={x:Reference CardArea}}"
                                                      CommandParameter="{Binding}" />
                                            <Separator />
                                            <MenuItem Header="編集(_E)"
                                                      Command="{Binding DataContext.EditIdeaCommand, Source={x:Reference CardArea}}"
                                                      CommandParameter="{Binding}" />
                                            <MenuItem Header="ピン留め切替(_P)"
                                                      Command="{Binding DataContext.TogglePinCommand, Source={x:Reference CardArea}}"
                                                      CommandParameter="{Binding}" />
                                            <MenuItem Header="アーカイブ切替(_A)"
                                                      Command="{Binding DataContext.ToggleArchiveCommand, Source={x:Reference CardArea}}"
                                                      CommandParameter="{Binding}" />
                                            <Separator />
                                            <MenuItem Header="削除(_D)"
                                                      Command="{Binding DataContext.DeleteIdeaCommand, Source={x:Reference CardArea}}"
                                                      CommandParameter="{Binding}" />
                                        </ContextMenu>
                                    </Border.ContextMenu>
                                    <DockPanel Margin="14">
                                        <!-- Header: pin + title -->
                                        <Grid DockPanel.Dock="Top" Margin="0,0,0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="★" Foreground="#E0A800" FontSize="14"
                                                       Margin="0,0,6,0" VerticalAlignment="Center"
                                                       Visibility="{Binding IsPinned, Converter={StaticResource IdeaBoolToVis}}" />
                                            <TextBlock Grid.Column="1" Text="{Binding DisplayTitle}"
                                                       Foreground="{StaticResource IdeaTextPrimaryBrush}"
                                                       FontWeight="SemiBold" FontSize="14"
                                                       TextTrimming="CharacterEllipsis" />
                                        </Grid>

                                        <!-- Footer: action buttons (visible & interactive on hover only) -->
                                        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                                                    HorizontalAlignment="Right" Margin="0,4,0,0">
                                            <StackPanel.Style>
                                                <Style TargetType="StackPanel">
                                                    <Setter Property="Opacity" Value="0" />
                                                    <Setter Property="IsHitTestVisible" Value="False" />
                                                    <Setter Property="KeyboardNavigation.TabNavigation" Value="None" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Border}}" Value="True">
                                                            <Setter Property="Opacity" Value="1" />
                                                            <Setter Property="IsHitTestVisible" Value="True" />
                                                            <Setter Property="KeyboardNavigation.TabNavigation" Value="Local" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </StackPanel.Style>
                                            <Button Content="📌" ToolTip="ピン留め切替"
                                                    Style="{StaticResource IdeaIconButtonStyle}"
                                                    Command="{Binding DataContext.TogglePinCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}" />
                                            <Button Content="✎" ToolTip="編集"
                                                    Style="{StaticResource IdeaIconButtonStyle}"
                                                    Command="{Binding DataContext.EditIdeaCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}" />
                                            <Button Content="📥" ToolTip="アーカイブ切替"
                                                    Style="{StaticResource IdeaIconButtonStyle}"
                                                    Command="{Binding DataContext.ToggleArchiveCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}" />
                                            <Button Content="🗑" ToolTip="削除"
                                                    Style="{StaticResource IdeaIconButtonStyle}"
                                                    Command="{Binding DataContext.DeleteIdeaCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}" />
                                        </StackPanel>

                                        <!-- Meta -->
                                        <TextBlock DockPanel.Dock="Bottom" Text="{Binding UpdatedAtText}"
                                                   FontSize="10" Foreground="{StaticResource IdeaTextSecondaryBrush}"
                                                   Margin="0,2,0,2" />

                                        <!-- Tag chips -->
                                        <ItemsControl DockPanel.Dock="Bottom"
                                                      ItemsSource="{Binding TagsList}"
                                                      Margin="0,4,0,2">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel Orientation="Horizontal" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Style="{StaticResource IdeaTagChipStyle}">
                                                        <TextBlock Text="{Binding StringFormat='#{0}'}"
                                                                   Style="{StaticResource IdeaTagChipTextStyle}" />
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <!-- Body preview (fixed mode) -->
                                        <TextBlock Text="{Binding BodyPreview}"
                                                   TextWrapping="Wrap" Margin="0,2,0,4"
                                                   FontSize="12"
                                                   Foreground="{StaticResource IdeaTextPrimaryBrush}"
                                                   Opacity="0.85">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding DataContext.IsCardHeightAuto, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <!-- Body full text (auto height mode) -->
                                        <TextBlock Text="{Binding Body}"
                                                   TextWrapping="Wrap" Margin="0,2,0,4"
                                                   FontSize="12"
                                                   Foreground="{StaticResource IdeaTextPrimaryBrush}"
                                                   Opacity="0.85">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding DataContext.IsCardHeightAuto, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Empty state placeholder -->
                <StackPanel Visibility="{Binding ShowEmptyState, Converter={StaticResource IdeaBoolToVis}}"
                            HorizontalAlignment="Center" VerticalAlignment="Center"
                            MaxWidth="420">
                    <TextBlock Text="{Binding EmptyStateTitle}"
                               Foreground="{StaticResource IdeaTextPrimaryBrush}"
                               FontSize="16" FontWeight="SemiBold"
                               HorizontalAlignment="Center" Margin="0,0,0,8" />
                    <TextBlock Text="{Binding EmptyStateMessage}"
                               Foreground="{StaticResource IdeaTextSecondaryBrush}"
                               FontSize="13" TextWrapping="Wrap"
                               HorizontalAlignment="Center" TextAlignment="Center"
                               LineHeight="20" />
                </StackPanel>

                <!-- Floating action button: 新規アイデア -->
                <Button Style="{StaticResource IdeaFloatingAddButtonStyle}"
                        Content="＋"
                        ToolTip="新しいアイデアを追加 (Ctrl+Shift+N)"
                        HorizontalAlignment="Right" VerticalAlignment="Bottom"
                        Margin="0,0,28,28"
                        Command="{Binding AddIdeaCommand}" />
            </Grid>
        </Grid>
    </DockPanel>
</UserControl>
