<UserControl x:Class="NestSuite.Views.NoteNestWorkspaceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:NestSuite.ViewModels"
             xmlns:editor="clr-namespace:NestSuite.NoteNest.Editor"
             TextElement.Foreground="{DynamicResource AppFg}">

    <UserControl.Resources>
        <DataTemplate x:Key="TaskItemTemplate">
            <Border Padding="10,6"
                    BorderBrush="{DynamicResource ItemBorderBrush}"
                    BorderThickness="0,0,0,1"
                    AllowDrop="True"
                    PreviewMouseLeftButtonDown="TaskItem_PreviewMouseLeftButtonDown"
                    PreviewMouseMove="TaskItem_PreviewMouseMove"
                    DragOver="TaskItem_DragOver"
                    Drop="TaskItem_Drop">
                <Border.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="コメントを編集(_E)..." Click="EditTaskComment_Click"/>
                        <MenuItem Header="名前変更(_R)..." Click="RenameTask_Click"/>
                        <MenuItem Header="グループを変更(_G)">
                            <MenuItem Header="今日のタスク(_T)" Click="MoveTaskToToday_Click"/>
                            <MenuItem Header="今週のタスク(_W)" Click="MoveTaskToWeek_Click"/>
                            <MenuItem Header="バックログ(_B)"   Click="MoveTaskToBacklog_Click"/>
                        </MenuItem>
                        <Separator/>
                        <MenuItem Header="関連ノートを開く(_O)" Click="OpenRelatedNote_Click"
                                  Visibility="{Binding HasRelatedNote, Converter={StaticResource BoolToVis}}"/>
                        <MenuItem Header="関連ノートを設定(_S)..." Click="SetRelatedNote_Click"/>
                        <MenuItem Header="関連ノートをクリア(_L)" Click="ClearRelatedNote_Click"
                                  Visibility="{Binding HasRelatedNote, Converter={StaticResource BoolToVis}}"/>
                        <Separator/>
                        <MenuItem Header="削除(_D)" Click="DeleteTask_Click"/>
                    </ContextMenu>
                </Border.ContextMenu>
                <DockPanel>
                    <CheckBox IsChecked="{Binding IsCompleted}"
                              VerticalAlignment="Center"
                              Margin="0,0,8,0"/>
                    <TextBlock DockPanel.Dock="Right"
                               Text="🔗"
                               FontSize="9"
                               VerticalAlignment="Center"
                               Margin="4,0,0,0"
                               ToolTip="関連ノートが設定されています"
                               Visibility="{Binding HasRelatedNote, Converter={StaticResource BoolToVis}}"/>
                    <TextBlock DockPanel.Dock="Right"
                               Text="●"
                               Foreground="{DynamicResource TaskCommentIndicator}"
                               FontSize="9"
                               VerticalAlignment="Center"
                               Margin="4,0,0,0"
                               ToolTip="このタスクにはコメントがあります"
                               Visibility="{Binding HasComment, Converter={StaticResource BoolToVis}}"/>
                    <Button DockPanel.Dock="Right"
                            Content="✏"
                            FontSize="10"
                            VerticalAlignment="Center"
                            Margin="4,0,0,0"
                            Padding="3,1"
                            ToolTip="コメントを編集"
                            Click="EditTaskComment_Click"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"/>
                    <TextBlock Text="{Binding Title}"
                               VerticalAlignment="Center"
                               TextWrapping="Wrap"
                               FontSize="12.5"
                               MouseLeftButtonDown="TaskTitle_MouseLeftButtonDown">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="ToolTip" Value="ダブルクリックでコメントを追加"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                        <Setter Property="TextDecorations" Value="Strikethrough"/>
                                        <Setter Property="Foreground" Value="{DynamicResource TaskCompletedFg}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding HasComment}" Value="True">
                                        <Setter Property="ToolTip" Value="ダブルクリックでコメントを編集"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </DockPanel>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <!-- ═══ Main 3-pane layout ═══ -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="LeftPaneColumn"      Width="220" MinWidth="140" MaxWidth="400"/>
            <ColumnDefinition Width="4"/>
            <ColumnDefinition Width="*"    MinWidth="280"/>
            <ColumnDefinition x:Name="RightSplitterColumn" Width="4"/>
            <ColumnDefinition x:Name="RightPaneColumn"     Width="280" MinWidth="200" MaxWidth="420"/>
        </Grid.ColumnDefinitions>

        <!-- ═══ LEFT PANE: Notebook / Note tree ═══ -->
        <Grid Grid.Column="0" Background="{DynamicResource SidebarBg}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Project name header -->
            <Border Grid.Row="0"
                    BorderBrush="{DynamicResource PaneBorder}" BorderThickness="0,0,0,1"
                    Padding="10,9">
                <DockPanel>
                    <Button DockPanel.Dock="Right" Content="+" Width="22" Height="22"
                            Style="{StaticResource IconButton}"
                            Click="LeftPaneAdd_Click" ToolTip="追加"/>
                    <TextBlock Text="{Binding ProjectDisplayName}"
                               FontWeight="Bold" FontSize="13"
                               TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Center"/>
                </DockPanel>
            </Border>

            <!-- L1: ノートタイトル絞り込みバー -->
            <Border Grid.Row="1"
                    BorderBrush="{DynamicResource PaneBorder}" BorderThickness="0,0,0,1"
                    Padding="6,4">
                <DockPanel>
                    <Button x:Name="NoteFilterClearButton"
                            AutomationProperties.AutomationId="NoteNest.FilterClearButton"
                            AutomationProperties.Name="NoteNest.FilterClearButton"
                            DockPanel.Dock="Right"
                            Content="×" Width="20" Height="20"
                            Margin="2,0,0,0" Padding="0"
                            Background="Transparent" BorderThickness="0"
                            Cursor="Hand" Visibility="Collapsed"
                            Click="NoteFilterClear_Click"/>
                    <Grid>
                        <TextBox x:Name="NoteFilterBox"
                                 AutomationProperties.AutomationId="NoteNest.FilterBox"
                                 AutomationProperties.Name="NoteNest.FilterBox"
                                 FontSize="11.5" Padding="4,2"
                                 TextChanged="NoteFilter_TextChanged"/>
                        <TextBlock Text="絞り込む..."
                                   IsHitTestVisible="False"
                                   FontSize="11.5"
                                   Foreground="{DynamicResource MutedFg}"
                                   Margin="6,0,0,0"
                                   VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=NoteFilterBox}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </DockPanel>
            </Border>

            <!-- TreeView -->
            <Grid Grid.Row="2">
            <TreeView x:Name="NotebookTree"
                      AutomationProperties.AutomationId="NoteNest.NotebookTree"
                      AutomationProperties.Name="NoteNest.NotebookTree"
                      ItemsSource="{Binding Notebooks}"
                      SelectedItemChanged="NotebookTree_SelectedItemChanged"
                      Padding="0,4">

                <TreeView.ItemContainerStyle>
                    <Style TargetType="TreeViewItem"
                           BasedOn="{StaticResource {x:Type TreeViewItem}}">
                        <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                    </Style>
                </TreeView.ItemContainerStyle>

                <TreeView.Resources>

                    <!-- ── Notebook template ── -->
                    <HierarchicalDataTemplate DataType="{x:Type vm:NotebookViewModel}"
                                              ItemsSource="{Binding Notes}">
                        <TextBlock Text="{Binding Title}"
                                   FontWeight="SemiBold" FontSize="12.5"
                                   Padding="2,1" ToolTip="{Binding Title}"
                                   AllowDrop="True"
                                   DragOver="NotebookHeader_DragOver"
                                   Drop="NotebookHeader_Drop">
                            <TextBlock.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="ノートを追加(_A)..." Click="AddNoteToNotebook_Click"/>
                                    <Separator/>
                                    <MenuItem Header="上に移動(_U)" Click="MoveNotebookUp_Click"/>
                                    <MenuItem Header="下に移動(_L)" Click="MoveNotebookDown_Click"/>
                                    <Separator/>
                                    <MenuItem Header="名前変更(_R)..."    Click="RenameNotebook_Click"/>
                                    <MenuItem Header="削除(_D)"           Click="DeleteNotebook_Click"/>
                                </ContextMenu>
                            </TextBlock.ContextMenu>
                        </TextBlock>
                    </HierarchicalDataTemplate>

                    <!-- ── Note template ── -->
                    <DataTemplate DataType="{x:Type vm:NoteViewModel}">
                        <DockPanel PreviewMouseLeftButtonDown="NoteItem_PreviewMouseLeftButtonDown"
                                   PreviewMouseMove="NoteItem_PreviewMouseMove">
                            <DockPanel.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="上に移動(_U)" Click="MoveNoteUp_Click"/>
                                    <MenuItem Header="下に移動(_L)" Click="MoveNoteDown_Click"/>
                                    <Separator/>
                                    <MenuItem Header="このノートへのリンクを挿入(_I)" Click="InsertNoteLinkFromNote_Click"/>
                                    <Separator/>
                                    <MenuItem Header="名前変更(_R)..." Click="RenameNote_Click"/>
                                    <MenuItem Header="複製(_C)"        Click="DuplicateNote_Click"/>
                                    <Separator/>
                                    <MenuItem Header="削除(_D)"        Click="DeleteNote_Click"/>
                                </ContextMenu>
                            </DockPanel.ContextMenu>
                            <TextBlock DockPanel.Dock="Right"
                                       Text="●"
                                       Foreground="{DynamicResource TodoBrush}"
                                       FontSize="9"
                                       VerticalAlignment="Center"
                                       Margin="0,0,4,0"
                                       ToolTip="このノートにはマーカーがあります"
                                       Visibility="{Binding HasMarkers, Converter={StaticResource BoolToVis}}"/>
                            <TextBlock Text="{Binding Title}"
                                       FontSize="12" Padding="8,1"
                                       TextTrimming="CharacterEllipsis"
                                       ToolTip="{Binding Title}"/>
                        </DockPanel>
                    </DataTemplate>

                </TreeView.Resources>
            </TreeView>
            <TextBlock Text="＋ で最初のノートを作成"
                       Foreground="{DynamicResource MutedFg}"
                       FontSize="12"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       IsHitTestVisible="False"
                       Visibility="{Binding IsNoteListEmpty, Converter={StaticResource BoolToVis}}"/>
            </Grid>

            <!-- Bottom toolbar -->
            <Border Grid.Row="3"
                    BorderBrush="{DynamicResource PaneBorder}" BorderThickness="0,1,0,0"
                    Background="{DynamicResource SidebarBg}" Padding="6,5">
                <StackPanel Orientation="Horizontal">
                    <Button Content="+ ノートブック" Style="{StaticResource IconButton}"
                            AutomationProperties.AutomationId="NoteNest.AddNotebookButton"
                            AutomationProperties.Name="NoteNest.AddNotebookButton"
                            FontSize="11.5" Click="AddNotebook_Click" Margin="0,0,4,0"/>
                    <Button Content="+ ノート" Style="{StaticResource IconButton}"
                            AutomationProperties.AutomationId="NoteNest.AddNoteButton"
                            AutomationProperties.Name="NoteNest.AddNoteButton"
                            FontSize="11.5" Click="AddNote_Click"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- GridSplitter L -->
        <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch"
                      Background="{DynamicResource PaneBorder}" ShowsPreview="True"/>

        <!-- ═══ CENTER PANE: Editor ═══ -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Sample project banner -->
            <Border Grid.Row="0"
                    Background="{DynamicResource SampleBannerBg}"
                    BorderBrush="{DynamicResource SampleBannerBorder}"
                    BorderThickness="0,0,0,1"
                    Padding="14,10"
                    Visibility="{Binding IsSampleProject, Converter={StaticResource BoolToVis}}">
                <DockPanel>
                    <!-- v1.16.4: Dock="Bottom" に変更。右側配置では TextBlock に残る幅が極端に狭くなり折り返し崩れが発生していた -->
                    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                                Margin="0,6,0,0">
                        <Button Content="新規プロジェクト"
                                Command="{Binding NewProjectCommand}"
                                Padding="10,4" Margin="0,0,8,0" FontSize="11.5"
                                Background="{DynamicResource BannerPrimaryBg}"
                                BorderBrush="{DynamicResource BannerPrimaryBorder}"
                                Foreground="{DynamicResource BannerPrimaryFg}"/>
                        <Button Content="名前を付けて保存..."
                                Command="{Binding SaveAsProjectCommand}"
                                Padding="10,4" FontSize="11.5"
                                Background="{DynamicResource BannerSecondaryBg}"
                                BorderBrush="{DynamicResource BannerSecondaryBorder}"
                                Foreground="{DynamicResource BannerSecondaryFg}"/>
                    </StackPanel>
                    <TextBlock Text="サンプルプロジェクトが表示されています。新しいプロジェクトを作成するか、.notenest ファイルとして保存してください。"
                               FontSize="11.5" Foreground="{DynamicResource SampleBannerFg}" TextWrapping="Wrap"
                               VerticalAlignment="Center"/>
                </DockPanel>
            </Border>

            <!-- Note / task-comment title bar -->
            <Border Grid.Row="1"
                    BorderBrush="{DynamicResource PaneBorder}" BorderThickness="0,0,0,1"
                    Padding="14,9">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="{DynamicResource EditorBg}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsTaskCommentMode}" Value="True">
                                <Setter Property="Background" Value="{DynamicResource TaskCommentTitleBg}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <DockPanel>
                    <Border DockPanel.Dock="Right" CornerRadius="4" Margin="2,0,0,0">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsModified}" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource UnsavedSaveBtnBg}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Button Content="💾" Width="28" Height="28"
                                Style="{StaticResource IconButton}"
                                Command="{Binding SaveProjectCommand}"
                                ToolTip="保存 (Ctrl+S)"
                                FontSize="15"/>
                    </Border>
                    <Border DockPanel.Dock="Right"
                            Background="{DynamicResource CommentBadgeBg}" CornerRadius="3"
                            Padding="6,2" Margin="8,0,0,0"
                            VerticalAlignment="Center"
                            Visibility="{Binding IsTaskCommentMode, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="コメント編集中"
                                   FontSize="10.5" Foreground="{DynamicResource CommentBadgeFg}"/>
                    </Border>
                    <ComboBox DockPanel.Dock="Right"
                              FontSize="11" Width="52" Margin="0,0,4,0"
                              VerticalAlignment="Center"
                              ItemsSource="{x:Static vm:MainViewModel.EditorFontSizeChoices}"
                              SelectedItem="{Binding EditorFontSize, Mode=TwoWay}"
                              ToolTip="フォントサイズ"/>
                    <TextBlock Text="{Binding EditorTitle}"
                               Foreground="{DynamicResource AppFg}"
                               ToolTip="{Binding CurrentNoteTimestampSummary}"
                               FontSize="14" FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>
                </DockPanel>
            </Border>

            <!-- Related note bar (task comment mode only) -->
            <Border Grid.Row="2"
                    BorderBrush="{DynamicResource PaneBorder}" BorderThickness="0,0,0,1"
                    Background="{DynamicResource TaskCommentTitleBg}"
                    Padding="10,6"
                    Visibility="{Binding IsTaskCommentMode, Converter={StaticResource BoolToVis}}">
                <DockPanel>
                    <Button DockPanel.Dock="Right" Content="クリア"
                            Click="ClearRelatedNote_Click"
                            Style="{StaticResource IconButton}" FontSize="11.5"
                            Margin="4,0,0,0"
                            Visibility="{Binding HasEditingTaskRelatedNote, Converter={StaticResource BoolToVis}}"/>
                    <Button DockPanel.Dock="Right" Content="開く"
                            Click="OpenRelatedNote_Click"
                            Style="{StaticResource IconButton}" FontSize="11.5"
                            Margin="4,0,0,0"
                            Visibility="{Binding HasEditingTaskRelatedNote, Converter={StaticResource BoolToVis}}"/>
                    <TextBlock Text="関連ノート：" FontSize="11.5" Foreground="{DynamicResource MutedFg}"
                               VerticalAlignment="Center" Margin="0,0,6,0" DockPanel.Dock="Left"/>
                    <ComboBox ItemsSource="{Binding RelatedNoteChoices}"
                              SelectedItem="{Binding EditingTaskRelatedNote, Mode=TwoWay}"
                              DisplayMemberPath="Title"
                              FontSize="11.5"
                              VerticalAlignment="Center"/>
                </DockPanel>
            </Border>

            <!-- Editor area -->
            <editor:NoteEditorHost Grid.Row="3"
                x:Name="EditorHost"
                AutomationProperties.AutomationId="NoteNest.EditorHost"
                AutomationProperties.Name="NoteNest.EditorHost"
                OpenNoteLinkClicked="OpenNoteLink_Click"
                InsertNoteLinkClicked="InsertNoteLink_Click"/>

            <!-- Marker insertion buttons -->
            <Border Grid.Row="4"
                    BorderBrush="{DynamicResource PaneBorder}" BorderThickness="0,1,0,0"
                    Background="{DynamicResource SidebarBg}"
                    Padding="12,5">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="挿入：" FontSize="11" Foreground="{DynamicResource MutedFg}"
                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <Button Content="[TODO]"  Click="InsertTodo_Click"
                            AutomationProperties.AutomationId="NoteNest.InsertTodoButton"
                            AutomationProperties.Name="NoteNest.InsertTodoButton"
                            Style="{StaticResource IconButton}" FontSize="11.5"
                            Margin="0,0,4,0" ToolTip="[TODO]  をカーソル位置に挿入"/>
                    <Button Content="[FIXME]" Click="InsertFixme_Click"
                            AutomationProperties.AutomationId="NoteNest.InsertFixmeButton"
                            AutomationProperties.Name="NoteNest.InsertFixmeButton"
                            Style="{StaticResource IconButton}" FontSize="11.5"
                            Margin="0,0,4,0" ToolTip="[FIXME]  をカーソル位置に挿入"/>
                    <Button Content="[NOTE]"  Click="InsertNote_Click"
                            AutomationProperties.AutomationId="NoteNest.InsertNoteButton"
                            AutomationProperties.Name="NoteNest.InsertNoteButton"
                            Style="{StaticResource IconButton}" FontSize="11.5"
                            ToolTip="[NOTE]  をカーソル位置に挿入"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- GridSplitter R（v1.16.3: 折り畳み時は非表示にし展開ボタンを Column 3 に表示する） -->
        <GridSplitter x:Name="RightGridSplitter"
                      AutomationProperties.AutomationId="NoteNest.RightGridSplitter"
                      AutomationProperties.Name="NoteNest.RightGridSplitter"
                      Grid.Column="3" HorizontalAlignment="Stretch"
                      Background="{DynamicResource PaneBorder}" ShowsPreview="True"/>

        <!-- 右ペイン展開ボタン。折り畳み時に Column 3（20px）に表示。Panel.ZIndex なし、左ボーダーで区切り -->
        <Button Grid.Column="3"
                x:Name="RightPaneExpandButton"
                AutomationProperties.AutomationId="NoteNest.RightPaneExpandButton"
                AutomationProperties.Name="NoteNest.RightPaneExpandButton"
                Content="»" Width="20"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                Style="{StaticResource IconButton}"
                Click="ToggleRightPane_Click"
                ToolTip="右ペインを表示"
                Visibility="Collapsed"
                BorderBrush="{DynamicResource PaneBorder}"
                BorderThickness="1,0,0,0"/>

        <!-- ═══ RIGHT PANE ═══ -->
        <Grid Grid.Column="4" Background="{DynamicResource RightPaneBg}">
            <Grid.RowDefinitions>
                <RowDefinition Height="3*" MinHeight="150"/>
                <RowDefinition Height="4"/>
                <RowDefinition Height="2*" MinHeight="100"/>
            </Grid.RowDefinitions>

            <!-- ── Tasks ── -->
            <Grid Grid.Row="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Tasks header -->
                <Border Grid.Row="0"
                        BorderBrush="{DynamicResource PaneBorder}" BorderThickness="0,0,0,1"
                        Padding="12,9">
                    <DockPanel>
                        <Button DockPanel.Dock="Right" Content="+" Width="22" Height="22"
                                Style="{StaticResource IconButton}"
                                Click="AddTaskMenu_Click" ToolTip="タスクを追加"/>
                        <Button DockPanel.Dock="Right" Content="«" Width="22" Height="22"
                                Style="{StaticResource IconButton}"
                                Click="ToggleRightPane_Click" ToolTip="右ペインを折り畳む"/>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="タスク" FontWeight="Bold" FontSize="13"/>
                            <TextBlock Text="{Binding TotalIncompleteTaskCountText}"
                                       Foreground="{DynamicResource FaintFg}" FontSize="11"
                                       VerticalAlignment="Center" Margin="4,0,0,0"/>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- Task groups -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding TaskGroups}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>

                                    <!-- Group header -->
                                    <Border Padding="10,6,10,6"
                                            Background="{DynamicResource GroupHeaderBg}"
                                            BorderBrush="{DynamicResource PaneBorder}"
                                            BorderThickness="0,0,0,1"
                                            Cursor="Hand"
                                            AllowDrop="True"
                                            DragOver="TaskGroupHeader_DragOver"
                                            Drop="TaskGroupHeader_Drop">
                                        <Border.InputBindings>
                                            <MouseBinding MouseAction="LeftClick"
                                                          Command="{Binding DataContext.ToggleGroupCommand,
                                                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                          CommandParameter="{Binding}"/>
                                        </Border.InputBindings>
                                        <DockPanel>
                                            <TextBlock DockPanel.Dock="Right"
                                                       Text="{Binding CountText}"
                                                       Foreground="{DynamicResource FaintFg}" FontSize="11"
                                                       VerticalAlignment="Center" Margin="4,0,0,0"/>
                                            <Button DockPanel.Dock="Right"
                                                    Content="+" Width="18" Height="18"
                                                    FontSize="12" Padding="0"
                                                    Style="{StaticResource IconButton}"
                                                    Command="{Binding DataContext.AddTaskCommand,
                                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding Key}"
                                                    ToolTip="このグループにタスクを追加"/>
                                            <TextBlock Text="{Binding Title}"
                                                       FontWeight="SemiBold" FontSize="12"
                                                       VerticalAlignment="Center"/>
                                        </DockPanel>
                                    </Border>

                                    <!-- Incomplete tasks (always visible when group is expanded) -->
                                    <ItemsControl ItemsSource="{Binding IncompleteTasks}"
                                                  ItemTemplate="{StaticResource TaskItemTemplate}"
                                                  Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVis}}"/>

                                    <!-- Completed tasks section -->
                                    <StackPanel Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVis}}">
                                        <!-- Completed section header: only shown when completed tasks exist -->
                                        <Border Padding="10,5,10,5"
                                                Background="{DynamicResource GroupHeaderBg}"
                                                BorderBrush="{DynamicResource PaneBorder}"
                                                BorderThickness="0,1,0,1"
                                                Cursor="Hand"
                                                Visibility="{Binding HasCompletedTasks, Converter={StaticResource BoolToVis}}">
                                            <Border.InputBindings>
                                                <MouseBinding MouseAction="LeftClick"
                                                              Command="{Binding ToggleCompletedSectionCommand}"/>
                                            </Border.InputBindings>
                                            <DockPanel>
                                                <TextBlock DockPanel.Dock="Right"
                                                           FontSize="9"
                                                           VerticalAlignment="Center"
                                                           Foreground="{DynamicResource FaintFg}">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="▼"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsCompletedSectionExpanded}" Value="False">
                                                                    <Setter Property="Text" Value="▶"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <TextBlock Text="{Binding CompletedCountText}"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource FaintFg}"
                                                           VerticalAlignment="Center"/>
                                            </DockPanel>
                                        </Border>
                                        <!-- Completed task items (dimmed) -->
                                        <ItemsControl ItemsSource="{Binding CompletedTasks}"
                                                      ItemTemplate="{StaticResource TaskItemTemplate}"
                                                      Opacity="0.80"
                                                      Visibility="{Binding IsCompletedSectionExpanded, Converter={StaticResource BoolToVis}}"/>
                                    </StackPanel>

                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <!-- Horizontal GridSplitter -->
            <GridSplitter Grid.Row="1" HorizontalAlignment="Stretch"
                          Background="{DynamicResource PaneBorder}" ShowsPreview="True"/>

            <!-- ── Markers / Links TabControl ── -->
            <TabControl Grid.Row="2"
                        AutomationProperties.AutomationId="NoteNest.RightPaneTabControl"
                        AutomationProperties.Name="NoteNest.RightPaneTabControl"
                        Background="{DynamicResource RightPaneBg}"
                        BorderBrush="{DynamicResource PaneBorder}"
                        BorderThickness="0,1,0,0"
                        FontSize="11.5">

                <!-- ── Tab: マーカー ── -->
                <TabItem Header="マーカー">
                    <Grid Background="{DynamicResource RightPaneBg}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Markers header -->
                        <Border Grid.Row="0"
                                BorderBrush="{DynamicResource PaneBorder}" BorderThickness="0,0,0,1"
                                Padding="12,9">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Right"
                                           Text="{Binding FilteredMarkerCountText}"
                                           Foreground="{DynamicResource MutedFg}" FontSize="12"
                                           VerticalAlignment="Center"/>
                                <TextBlock DockPanel.Dock="Right"
                                           Text="？"
                                           Foreground="{DynamicResource HintFg}"
                                           FontSize="12"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0"
                                           Cursor="Help">
                                    <TextBlock.ToolTip>
                                        <ToolTip>
                                            <StackPanel Margin="4,2">
                                                <TextBlock Text="利用可能なマーカー:" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                                <TextBlock Text="[TODO]   やること"   Margin="0,0,0,3"/>
                                                <TextBlock Text="[FIXME]  修正が必要" Margin="0,0,0,3"/>
                                                <TextBlock Text="[NOTE]   メモ・補足"/>
                                            </StackPanel>
                                        </ToolTip>
                                    </TextBlock.ToolTip>
                                </TextBlock>
                                <TextBlock Text="マーカー" FontWeight="Bold" FontSize="13"
                                           VerticalAlignment="Center"/>
                            </DockPanel>
                        </Border>

                        <!-- Marker filter row -->
                        <Border Grid.Row="1"
                                BorderBrush="{DynamicResource PaneBorder}" BorderThickness="0,0,0,1"
                                Background="{DynamicResource RightPaneBg}" Padding="10,5">
                            <DockPanel>
                                <ComboBox DockPanel.Dock="Right"
                                          AutomationProperties.AutomationId="NoteNest.MarkerSortComboBox"
                                          AutomationProperties.Name="NoteNest.MarkerSortComboBox"
                                          SelectedIndex="{Binding MarkerSortOrderIndex}"
                                          FontSize="11"
                                          Width="68"
                                          VerticalAlignment="Center">
                                    <ComboBoxItem Content="抽出順"/>
                                    <ComboBoxItem Content="種別順"/>
                                    <ComboBoxItem Content="ノート順"/>
                                    <ComboBoxItem Content="行番号順"/>
                                </ComboBox>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <CheckBox Content="{Binding TodoCountText}"  IsChecked="{Binding FilterTodo}"
                                              AutomationProperties.AutomationId="NoteNest.TodoFilterCheckBox"
                                              AutomationProperties.Name="NoteNest.TodoFilterCheckBox"
                                              Foreground="{DynamicResource TodoBrush}"  FontSize="11" Margin="0,0,10,0"/>
                                    <CheckBox Content="{Binding FixmeCountText}" IsChecked="{Binding FilterFixme}"
                                              AutomationProperties.AutomationId="NoteNest.FixmeFilterCheckBox"
                                              AutomationProperties.Name="NoteNest.FixmeFilterCheckBox"
                                              Foreground="{DynamicResource FixmeBrush}" FontSize="11" Margin="0,0,10,0"/>
                                    <CheckBox Content="{Binding NoteCountText}"  IsChecked="{Binding FilterNote}"
                                              AutomationProperties.AutomationId="NoteNest.NoteMarkerFilterCheckBox"
                                              AutomationProperties.Name="NoteNest.NoteMarkerFilterCheckBox"
                                              Foreground="{DynamicResource NoteBrush}"  FontSize="11"/>
                                </StackPanel>
                            </DockPanel>
                        </Border>

                        <!-- Marker list -->
                        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding FilteredMarkers}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="10,8"
                                                BorderBrush="{DynamicResource ItemBorderBrush}" BorderThickness="0,0,0,1"
                                                Cursor="Hand"
                                                MouseLeftButtonDown="Marker_MouseLeftButtonDown">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource MarkerHoverBg}"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel>
                                                <DockPanel>
                                                    <TextBlock Text="{Binding Type}"
                                                               FontWeight="Bold" FontSize="11"
                                                               Width="46" DockPanel.Dock="Left">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="{DynamicResource PrimaryFg}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Type}" Value="TODO">
                                                                        <Setter Property="Foreground" Value="{DynamicResource TodoBrush}"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Type}" Value="FIXME">
                                                                        <Setter Property="Foreground" Value="{DynamicResource FixmeBrush}"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Type}" Value="NOTE">
                                                                        <Setter Property="Foreground" Value="{DynamicResource NoteBrush}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <TextBlock Text="{Binding LineLabel}"
                                                               Foreground="{DynamicResource MutedFg}" FontSize="11"
                                                               Margin="0,0,6,0" VerticalAlignment="Center"
                                                               DockPanel.Dock="Left"/>
                                                    <TextBlock Text="{Binding NoteTitle}"
                                                               Foreground="{DynamicResource SecondaryFg}" FontSize="11"
                                                               VerticalAlignment="Center"
                                                               TextTrimming="CharacterEllipsis"/>
                                                </DockPanel>
                                                <TextBlock Text="{Binding Excerpt}"
                                                           Foreground="{DynamicResource PrimaryFg}" FontSize="11.5"
                                                           TextTrimming="CharacterEllipsis"
                                                           Margin="0,3,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <!-- Project-wide marker summary -->
                        <Border Grid.Row="3"
                                BorderBrush="{DynamicResource PaneBorder}" BorderThickness="0,1,0,0"
                                Background="{DynamicResource SidebarBg}"
                                Padding="12,6">
                            <TextBlock Text="{Binding ProjectMarkerSummary}"
                                       FontSize="11" Foreground="{DynamicResource MutedFg}"
                                       TextWrapping="Wrap"/>
                        </Border>
                    </Grid>
                </TabItem>

                <!-- ── Tab: リンク ── -->
                <TabItem Header="リンク">
                    <Grid Background="{DynamicResource RightPaneBg}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>

                                <!-- No note selected -->
                                <TextBlock Margin="12,16,12,8"
                                           FontSize="12" Foreground="{DynamicResource MutedFg}"
                                           Text="ノートを選択してください"
                                           TextWrapping="Wrap"
                                           Visibility="{Binding LinkPanel.HasNoNote, Converter={StaticResource BoolToVis}}"/>

                                <!-- ── Section: からのリンク ── -->
                                <Border Padding="12,8"
                                        BorderBrush="{DynamicResource PaneBorder}" BorderThickness="0,0,0,1"
                                        Background="{DynamicResource GroupHeaderBg}"
                                        Visibility="{Binding LinkPanel.HasNote, Converter={StaticResource BoolToVis}}">
                                    <DockPanel>
                                        <TextBlock Text="{Binding LinkPanel.OutboundCountText}"
                                                   DockPanel.Dock="Right"
                                                   Foreground="{DynamicResource MutedFg}" FontSize="11"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="からのリンク"
                                                   FontWeight="SemiBold" FontSize="12"
                                                   VerticalAlignment="Center"/>
                                    </DockPanel>
                                </Border>

                                <!-- No outbound links -->
                                <TextBlock Text="（なし）"
                                           FontSize="11" Foreground="{DynamicResource MutedFg}"
                                           Margin="12,6,12,6"
                                           Visibility="{Binding LinkPanel.HasNoOutboundLinks, Converter={StaticResource BoolToVis}}"/>

                                <!-- Outbound link items -->
                                <ItemsControl ItemsSource="{Binding LinkPanel.OutboundLinks}"
                                              Visibility="{Binding LinkPanel.HasNote, Converter={StaticResource BoolToVis}}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="12,7"
                                                    BorderBrush="{DynamicResource ItemBorderBrush}" BorderThickness="0,0,0,1"
                                                    Cursor="Hand"
                                                    MouseLeftButtonDown="OutboundLink_MouseLeftButtonDown">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="{DynamicResource MarkerHoverBg}"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <DockPanel>
                                                    <TextBlock DockPanel.Dock="Right"
                                                               Text="⚠"
                                                               Foreground="{DynamicResource FixmeBrush}"
                                                               FontSize="11"
                                                               VerticalAlignment="Center"
                                                               ToolTip="リンク切れ"
                                                               Visibility="{Binding IsBroken, Converter={StaticResource BoolToVis}}"/>
                                                    <TextBlock Text="{Binding LinkName}"
                                                               FontSize="12" FontWeight="SemiBold"
                                                               VerticalAlignment="Center"
                                                               TextTrimming="CharacterEllipsis"/>
                                                </DockPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- ── Section: へのリンク ── -->
                                <Border Padding="12,8"
                                        Margin="0,6,0,0"
                                        BorderBrush="{DynamicResource PaneBorder}" BorderThickness="0,1,0,1"
                                        Background="{DynamicResource GroupHeaderBg}"
                                        Visibility="{Binding LinkPanel.HasNote, Converter={StaticResource BoolToVis}}">
                                    <DockPanel>
                                        <TextBlock Text="{Binding LinkPanel.BacklinkCountText}"
                                                   DockPanel.Dock="Right"
                                                   Foreground="{DynamicResource MutedFg}" FontSize="11"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="へのリンク"
                                                   FontWeight="SemiBold" FontSize="12"
                                                   VerticalAlignment="Center"/>
                                    </DockPanel>
                                </Border>

                                <!-- No backlinks -->
                                <TextBlock Text="（なし）"
                                           FontSize="11" Foreground="{DynamicResource MutedFg}"
                                           Margin="12,6,12,6"
                                           Visibility="{Binding LinkPanel.HasNoBacklinks, Converter={StaticResource BoolToVis}}"/>

                                <!-- Backlink items -->
                                <ItemsControl ItemsSource="{Binding LinkPanel.Backlinks}"
                                              Visibility="{Binding LinkPanel.HasNote, Converter={StaticResource BoolToVis}}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="12,7"
                                                    BorderBrush="{DynamicResource ItemBorderBrush}" BorderThickness="0,0,0,1"
                                                    Cursor="Hand"
                                                    MouseLeftButtonDown="Backlink_MouseLeftButtonDown">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="{DynamicResource MarkerHoverBg}"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding DisplayText}"
                                                           FontSize="12"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </TabItem>

            </TabControl>

        </Grid>
    </Grid>
</UserControl>
