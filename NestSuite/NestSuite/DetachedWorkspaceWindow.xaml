<Window x:Class="NestSuite.DetachedWorkspaceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:NestSuite.Views"
        Title="NoteNest"
        Height="600" Width="900"
        MinHeight="300" MinWidth="500"
        WindowStartupLocation="CenterOwner">
    <Window.CommandBindings>
        <CommandBinding Command="ApplicationCommands.Save" Executed="CommandSave_Executed"/>
    </Window.CommandBindings>
    <views:NoteNestWorkspaceView x:Name="WorkspaceView"/>
</Window>
