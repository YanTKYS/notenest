<UserControl x:Class="NestSuite.ChatNest.ChatNestWorkspaceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:cn="clr-namespace:NestSuite.ChatNest">

    <UserControl.Resources>
        <!-- Converters（参照ソース ChatNest v0.4.1。Workspace で実際に使う 4 種のみ取り込み） -->
        <cn:RadioConverter x:Key="RadioConverter"/>
        <cn:SpeakerBackgroundConverter x:Key="SpeakerBg"/>
        <cn:SpeakerAccentConverter x:Key="SpeakerAccent"/>
        <cn:SpeakerAlignmentConverter x:Key="SpeakerAlign"/>

        <!-- Styles（参照ソース App.xaml より Workspace 用のみ取り込み。App.xaml 自体は移植しない） -->
        <Style x:Key="FlatButton" TargetType="Button">
            <Setter Property="FontFamily" Value="Yu Gothic UI, Meiryo UI, sans-serif"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.7"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource FlatButton}">
            <Setter Property="Background" Value="#1976D2"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="20,9"/>
        </Style>

        <!-- v1.16.5: コピーボタン用スタイル -->
        <Style x:Key="CopyButton" TargetType="Button">
            <Setter Property="FontFamily" Value="Yu Gothic UI, Meiryo UI, sans-serif"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="#EEEEEE"/>
            <Setter Property="Foreground" Value="#424242"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E0E0E0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#BDBDBD"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SpeakerToggle" TargetType="RadioButton">
            <Setter Property="FontFamily" Value="Yu Gothic UI, Meiryo UI, sans-serif"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border"
                                Background="#F0F0F0"
                                CornerRadius="16"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1976D2"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- v2.3.0: DataType を MessageViewModel に変更。削除ボタン廃止・右クリックメニュー追加・インライン編集追加 -->
        <DataTemplate x:Key="MessageTemplate" DataType="{x:Type cn:MessageViewModel}">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="{Binding Speaker, Converter={StaticResource SpeakerAlign}}"
                        VerticalAlignment="Top"
                        Margin="16,2"
                        MaxWidth="580">

                <!-- CH-4/CH-6: 右クリックで編集・削除を選択する -->
                <StackPanel.ContextMenu>
                    <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                        <MenuItem Header="編集" Command="{Binding BeginEditCommand}"/>
                        <MenuItem Header="削除" Command="{Binding RequestDeleteCommand}"/>
                    </ContextMenu>
                </StackPanel.ContextMenu>

                <!-- メタ情報（発言者・時刻） -->
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Top"
                            Margin="0,5,7,0">
                    <TextBlock Text="{Binding Speaker}"
                               FontSize="11"
                               FontWeight="Bold"
                               Foreground="{Binding Speaker, Converter={StaticResource SpeakerAccent}}"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding CreatedAt, StringFormat=HH:mm}"
                               FontSize="10"
                               Foreground="#C0C0C0"
                               Margin="5,0,3,0"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- 吹き出し -->
                <Border Background="{Binding Speaker, Converter={StaticResource SpeakerBg}}"
                        BorderBrush="{Binding Speaker, Converter={StaticResource SpeakerAccent}}"
                        BorderThickness="3,0,0,0"
                        CornerRadius="8"
                        Padding="10,6"
                        MaxWidth="460">
                    <Grid>
                        <!-- 通常表示: 本文テキスト -->
                        <TextBlock Text="{Binding Text}"
                                   TextWrapping="Wrap"
                                   FontSize="13"
                                   LineHeight="20"
                                   Foreground="#212121">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <!-- CH-6: 編集モード（IsEditing=true のとき表示） -->
                        <StackPanel Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}">
                            <TextBox Text="{Binding EditingText, UpdateSourceTrigger=PropertyChanged}"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     MinHeight="52"
                                     MaxHeight="120"
                                     VerticalScrollBarVisibility="Auto"
                                     FontSize="13"
                                     Padding="4,4"
                                     BorderThickness="1"
                                     BorderBrush="#1976D2"
                                     Background="White"
                                     Foreground="#212121"
                                     PreviewKeyDown="EditBox_PreviewKeyDown"
                                     IsVisibleChanged="EditBox_IsVisibleChanged"/>
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        Margin="0,6,0,0">
                                <Button Content="キャンセル"
                                        Style="{StaticResource CopyButton}"
                                        Margin="0,0,6,0"
                                        Command="{Binding CancelEditCommand}"/>
                                <Button Content="確定"
                                        Style="{StaticResource FlatButton}"
                                        Background="#1976D2"
                                        Foreground="White"
                                        Padding="12,6"
                                        Command="{Binding CommitEditCommand}"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

            </StackPanel>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Background="#F5F5F7">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ========== CHAT LOG ========== -->
        <ScrollViewer Grid.Row="0"
                      x:Name="ChatScrollViewer"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="0,8,0,8"
                      Background="Transparent"
                      ScrollChanged="ChatScrollViewer_ScrollChanged">
            <ItemsControl ItemsSource="{Binding Messages}"
                          ItemTemplate="{StaticResource MessageTemplate}"
                          VirtualizingPanel.IsVirtualizing="False">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </ScrollViewer>

        <!-- Empty state -->
        <StackPanel Grid.Row="0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    IsHitTestVisible="False">
            <StackPanel.Style>
                <Style TargetType="StackPanel">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Messages.Count}" Value="0">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </StackPanel.Style>
            <TextBlock Text="💬"
                       FontSize="36"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,12"/>
            <TextBlock Text="発言者を選んで、考えを書き出そう"
                       FontSize="14"
                       Foreground="#BDBDBD"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Ctrl / Shift + Enter で投稿"
                       FontSize="11"
                       Foreground="#D0D0D0"
                       HorizontalAlignment="Center"
                       Margin="0,6,0,0"/>
        </StackPanel>

        <!-- CH-3: 最新へボタン（過去発言を読んでいるときのみ表示） -->
        <Button x:Name="ScrollToBottomButton"
                Grid.Row="0"
                Content="↓ 最新へ"
                Visibility="Collapsed"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Margin="0,0,16,12"
                Style="{StaticResource FlatButton}"
                Background="#1976D2"
                Foreground="White"
                FontSize="12"
                Padding="12,6"
                Click="ScrollToBottomButton_Click"/>

        <!-- ========== INPUT AREA ========== -->
        <Border Grid.Row="1"
                Background="White"
                Padding="16,12,16,14">
            <Border.Effect>
                <DropShadowEffect Color="#000000" Opacity="0.05" BlurRadius="8" ShadowDepth="-2" Direction="90"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Speaker selector + shortcut hint + copy buttons (v1.16.5) -->
                <Grid Grid.Row="0" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="発言者："
                                   FontSize="11"
                                   Foreground="#757575"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                        <RadioButton Style="{StaticResource SpeakerToggle}"
                                     Content="自分"
                                     IsChecked="{Binding SelectedSpeaker, Converter={StaticResource RadioConverter}, ConverterParameter=自分, Mode=TwoWay}"
                                     GroupName="Speaker"/>
                        <RadioButton Style="{StaticResource SpeakerToggle}"
                                     Content="反論"
                                     IsChecked="{Binding SelectedSpeaker, Converter={StaticResource RadioConverter}, ConverterParameter=反論, Mode=TwoWay}"
                                     GroupName="Speaker"/>
                        <RadioButton Style="{StaticResource SpeakerToggle}"
                                     Content="補足"
                                     IsChecked="{Binding SelectedSpeaker, Converter={StaticResource RadioConverter}, ConverterParameter=補足, Mode=TwoWay}"
                                     GroupName="Speaker"/>
                        <RadioButton Style="{StaticResource SpeakerToggle}"
                                     Content="結論"
                                     IsChecked="{Binding SelectedSpeaker, Converter={StaticResource RadioConverter}, ConverterParameter=結論, Mode=TwoWay}"
                                     GroupName="Speaker"/>
                    </StackPanel>

                    <TextBlock Grid.Column="1"
                               Text="Ctrl / Shift + ← / → で切り替え"
                               FontSize="10"
                               Foreground="#C8C8C8"
                               VerticalAlignment="Center"
                               Margin="12,0,6,0"/>

                    <!-- v1.16.5: コピーボタン群 + 状態テキスト -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="8,0,0,0">
                        <TextBlock Text="{Binding CopyStatusText}"
                                   FontSize="10"
                                   Foreground="#9E9E9E"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CopyStatusText}" Value="">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <Button Style="{StaticResource CopyButton}"
                                Content="Copy NestSuite"
                                Command="{Binding CopyNestSuiteCommand}"
                                ToolTip="NoteNest / IdeaNest に貼り付けやすい形式でコピー"/>
                        <Button Style="{StaticResource CopyButton}"
                                Content="Copy Markdown"
                                Command="{Binding CopyMarkdownCommand}"
                                ToolTip="Markdown 形式でコピー"
                                Margin="4,0,0,0"/>
                    </StackPanel>
                </Grid>

                <!-- Input row: TextBox + Post button -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            BorderBrush="#E0E0E0"
                            BorderThickness="1"
                            CornerRadius="8"
                            Margin="0,0,10,0">
                        <TextBox x:Name="InputBox"
                                 Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 MinHeight="52"
                                 MaxHeight="120"
                                 VerticalScrollBarVisibility="Auto"
                                 FontSize="13"
                                 Padding="10,8"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 VerticalContentAlignment="Top"
                                 PreviewKeyDown="InputBox_PreviewKeyDown">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="FontFamily" Value="Yu Gothic UI, Meiryo UI, sans-serif"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="TextBox">
                                                <ScrollViewer x:Name="PART_ContentHost" Margin="0" Padding="{TemplateBinding Padding}"/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                    </Border>

                    <Button Grid.Column="1"
                            Style="{StaticResource PrimaryButton}"
                            Content="投稿"
                            Width="70"
                            VerticalAlignment="Bottom"
                            Command="{Binding PostCommand}"/>
                </Grid>
            </Grid>
        </Border>

        <!-- CH-4: 発言削除確認ダイアログ（オーバーレイ）-->
        <Grid Grid.Row="0" Grid.RowSpan="2"
              Visibility="{Binding IsDeleteConfirmVisible, Converter={StaticResource BoolToVis}}">
            <!-- 半透明バックドロップ -->
            <Border Background="#80000000"/>
            <!-- ダイアログカード -->
            <Border Background="White"
                    CornerRadius="12"
                    Padding="24"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    MaxWidth="300">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.18" BlurRadius="20" ShadowDepth="4"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="この発言を削除しますか？"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#212121"
                               Margin="0,0,0,16"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="キャンセル"
                                Style="{StaticResource CopyButton}"
                                Padding="14,7"
                                Margin="0,0,8,0"
                                Command="{Binding CancelDeleteCommand}"/>
                        <Button Content="削除"
                                Style="{StaticResource FlatButton}"
                                Background="#E53935"
                                Foreground="White"
                                Padding="14,7"
                                Command="{Binding ConfirmDeleteCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

    </Grid>
</UserControl>
