<UserControl x:Class="NestSuite.ChatNest.ChatNestWorkspaceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:cn="clr-namespace:NestSuite.ChatNest">

    <UserControl.Resources>
        <!-- Converters（参照ソース ChatNest v0.4.1。Workspace で実際に使う 4 種のみ取り込み） -->
        <cn:RadioConverter x:Key="RadioConverter"/>
        <cn:SpeakerBackgroundConverter x:Key="SpeakerBg"/>
        <cn:SpeakerAccentConverter x:Key="SpeakerAccent"/>
        <cn:SpeakerAlignmentConverter x:Key="SpeakerAlign"/>

        <!-- Styles（参照ソース App.xaml より Workspace 用のみ取り込み。App.xaml 自体は移植しない） -->
        <Style x:Key="FlatButton" TargetType="Button">
            <Setter Property="FontFamily" Value="Yu Gothic UI, Meiryo UI, sans-serif"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.7"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Cursor" Value="Arrow"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource FlatButton}">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="20,9"/>
        </Style>

        <!-- v1.16.5: 会話全体コピーボタン用スタイル -->
        <Style x:Key="CopyButton" TargetType="Button">
            <Setter Property="FontFamily" Value="Yu Gothic UI, Meiryo UI, sans-serif"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="{DynamicResource ChatCopyButtonBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource ChatCopyButtonHoverBackgroundBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource ChatCopyButtonPressedBackgroundBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Cursor" Value="Arrow"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- v2.7.11 CH-10: 発言単体コピーボタン。低透明度で常時表示し、ホバーで鮮明になる -->
        <Style x:Key="MessageCopyButton" TargetType="Button">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="2,0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Opacity" Value="0.35"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="1"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- v2.7.11 CH-5: 検索バーボタン（前へ / 次へ / 閉じる） -->
        <Style x:Key="SearchButton" TargetType="Button">
            <Setter Property="FontFamily" Value="Yu Gothic UI, Meiryo UI, sans-serif"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource HoverBackgroundBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource SelectionBackgroundBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Cursor" Value="Arrow"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- v2.9.6: Foreground を明示し Dark テーマ非選択状態の視認性を確保する。
             IsChecked=True 時は Foreground=White で上書きされる。 -->
        <Style x:Key="SpeakerToggle" TargetType="RadioButton">
            <Setter Property="FontFamily" Value="Yu Gothic UI, Meiryo UI, sans-serif"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border"
                                Background="{DynamicResource ChatChipBackgroundBrush}"
                                CornerRadius="16"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- v2.3.0: DataType を MessageViewModel に変更。v2.7.11: CH-7 speaker chip / CH-10 copy / CH-5 search highlight -->
        <DataTemplate x:Key="MessageTemplate" DataType="{x:Type cn:MessageViewModel}">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="{Binding Speaker, Converter={StaticResource SpeakerAlign}}"
                        VerticalAlignment="Top"
                        Margin="16,3"
                        MaxWidth="580">

                <!-- CH-5: 現在の検索結果に背景ハイライトを付ける -->
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Background" Value="Transparent"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSearchCurrent}" Value="True">
                                <Setter Property="Background" Value="{DynamicResource SearchHighlightBrush}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>

                <!-- CH-4/CH-6: 右クリックで編集・削除を選択する -->
                <StackPanel.ContextMenu>
                    <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                        <MenuItem Header="編集(_E)" Command="{Binding BeginEditCommand}"/>
                        <MenuItem Header="削除(_D)" Command="{Binding RequestDeleteCommand}"/>
                    </ContextMenu>
                </StackPanel.ContextMenu>

                <!-- CH-7: 発言者チップ + 時刻 + CH-10 コピーボタン -->
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Top"
                            Margin="0,6,7,0">
                    <!-- CH-7: 発言者ラベルをチップ形状で表示（背景色 + ボーダー + 太字） -->
                    <Border Background="{Binding Speaker, Converter={StaticResource SpeakerBg}}"
                            BorderBrush="{Binding Speaker, Converter={StaticResource SpeakerAccent}}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="6,2"
                            VerticalAlignment="Center">
                        <TextBlock Text="{Binding Speaker}"
                                   FontSize="11"
                                   FontWeight="Bold"
                                   Foreground="{Binding Speaker, Converter={StaticResource SpeakerAccent}}"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <!-- CH-8: タイムスタンプ非表示時は Collapsed。ShowTimestamps は UserControl の DataContext (ChatNestWorkspaceViewModel) が持つ -->
                    <TextBlock Text="{Binding CreatedAt, StringFormat=HH:mm}"
                               FontSize="10"
                               Foreground="{DynamicResource MutedTextBrush}"
                               Margin="5,0,3,0"
                               VerticalAlignment="Center"
                               Visibility="{Binding DataContext.ShowTimestamps, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, Converter={StaticResource BoolToVis}}"/>
                    <!-- CH-10: 発言本文のみコピーするボタン（常時表示、ホバーで鮮明） -->
                    <Button Content="📋"
                            Style="{StaticResource MessageCopyButton}"
                            Command="{Binding CopyMessageCommand}"
                            ToolTip="本文をコピー"
                            Margin="2,0,0,0"
                            VerticalAlignment="Center"/>
                </StackPanel>

                <!-- 吹き出し。CH-5: IsSearchCurrent で全辺ボーダー表示 -->
                <Border Background="{Binding Speaker, Converter={StaticResource SpeakerBg}}"
                        BorderBrush="{Binding Speaker, Converter={StaticResource SpeakerAccent}}"
                        CornerRadius="8"
                        Padding="10,6"
                        MaxWidth="460">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="BorderThickness" Value="3,0,0,0"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSearchCurrent}" Value="True">
                                    <Setter Property="BorderThickness" Value="3,2,2,2"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <!-- 通常表示: 本文テキスト -->
                        <TextBlock Text="{Binding Text}"
                                   TextWrapping="Wrap"
                                   FontSize="13"
                                   LineHeight="20"
                                   Foreground="{DynamicResource ChatBubbleTextBrush}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <!-- CH-6: 編集モード（IsEditing=true のとき表示） -->
                        <StackPanel Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}">
                            <TextBox Text="{Binding EditingText, UpdateSourceTrigger=PropertyChanged}"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     MinHeight="52"
                                     MaxHeight="120"
                                     VerticalScrollBarVisibility="Auto"
                                     FontSize="13"
                                     Padding="4,4"
                                     BorderThickness="1"
                                     BorderBrush="{DynamicResource FocusBorderBrush}"
                                     Background="{DynamicResource InputBackgroundBrush}"
                                     Foreground="{DynamicResource PrimaryTextBrush}"
                                     PreviewKeyDown="EditBox_PreviewKeyDown"
                                     IsVisibleChanged="EditBox_IsVisibleChanged"/>
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        Margin="0,6,0,0">
                                <Button Content="キャンセル(_C)"
                                        Style="{StaticResource CopyButton}"
                                        Margin="0,0,6,0"
                                        Command="{Binding CancelEditCommand}"/>
                                <Button Content="確定(_K)"
                                        Style="{StaticResource FlatButton}"
                                        Background="{DynamicResource AccentBrush}"
                                        Foreground="White"
                                        Padding="12,6"
                                        Command="{Binding CommitEditCommand}"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

            </StackPanel>
        </DataTemplate>
    </UserControl.Resources>

    <!-- v2.7.11: Row 0 = CH-5 検索バー（非表示時は高さゼロ）、Row 1 = チャットログ、Row 2 = 入力エリア -->
    <Grid Background="{DynamicResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ========== CH-5: 検索バー ========== -->
        <Border Grid.Row="0"
                Background="{DynamicResource ChatSearchBarBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="10,5"
                Visibility="{Binding IsSearchBarVisible, Converter={StaticResource BoolToVis}}">
            <DockPanel>
                <Button DockPanel.Dock="Right"
                        Content="✕"
                        Style="{StaticResource SearchButton}"
                        Command="{Binding CloseSearchCommand}"
                        ToolTip="検索を閉じる (Esc)"
                        Margin="4,0,0,0"/>
                <Button DockPanel.Dock="Right"
                        Content="▲"
                        Style="{StaticResource SearchButton}"
                        Command="{Binding SearchPreviousCommand}"
                        ToolTip="前の結果 (Shift+Enter)"
                        Margin="2,0,0,0"/>
                <Button DockPanel.Dock="Right"
                        Content="▼"
                        Style="{StaticResource SearchButton}"
                        Command="{Binding SearchNextCommand}"
                        ToolTip="次の結果 (Enter)"
                        Margin="2,0,0,0"/>
                <TextBlock DockPanel.Dock="Right"
                           Text="{Binding SearchResultSummary}"
                           FontSize="11"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           VerticalAlignment="Center"
                           MinWidth="44"
                           TextAlignment="Right"
                           Margin="8,0,0,0"/>
                <TextBlock DockPanel.Dock="Left"
                           Text="検索："
                           FontSize="11"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           VerticalAlignment="Center"
                           Margin="0,0,6,0"/>
                <TextBox x:Name="SearchBox"
                         AutomationProperties.AutomationId="ChatNest.SearchBox"
                         AutomationProperties.Name="ChatNest.SearchBox"
                         Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="12"
                         Padding="6,3"
                         BorderThickness="1"
                         BorderBrush="{DynamicResource BorderBrush}"
                         Background="{DynamicResource InputBackgroundBrush}"
                         VerticalContentAlignment="Center"
                         PreviewKeyDown="SearchBox_PreviewKeyDown"/>
            </DockPanel>
        </Border>

        <!-- ========== CHAT LOG ========== -->
        <ScrollViewer Grid.Row="1"
                      x:Name="ChatScrollViewer"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="0,8,0,8"
                      Background="Transparent"
                      ScrollChanged="ChatScrollViewer_ScrollChanged">
            <ItemsControl x:Name="ChatItemsControl"
                          ItemsSource="{Binding Messages}"
                          ItemTemplate="{StaticResource MessageTemplate}"
                          VirtualizingPanel.IsVirtualizing="False">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </ScrollViewer>

        <!-- Empty state -->
        <StackPanel Grid.Row="1"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    IsHitTestVisible="False">
            <StackPanel.Style>
                <Style TargetType="StackPanel">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Messages.Count}" Value="0">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </StackPanel.Style>
            <TextBlock Text="💬"
                       FontSize="36"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,12"/>
            <TextBlock Text="発言者を選んで、考えを書き出そう"
                       FontSize="14"
                       Foreground="{DynamicResource MutedTextBrush}"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Ctrl + Enter で投稿"
                       FontSize="11"
                       Foreground="{DynamicResource MutedTextBrush}"
                       HorizontalAlignment="Center"
                       Margin="0,6,0,0"/>
        </StackPanel>

        <!-- CH-3: 最新へボタン（過去発言を読んでいるときのみ表示） -->
        <Button x:Name="ScrollToBottomButton"
                AutomationProperties.AutomationId="ChatNest.ScrollToBottomButton"
                AutomationProperties.Name="ChatNest.ScrollToBottomButton"
                Grid.Row="1"
                Content="↓ 最新へ"
                Visibility="Collapsed"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Margin="0,0,16,12"
                Style="{StaticResource FlatButton}"
                Background="{DynamicResource AccentBrush}"
                Foreground="White"
                FontSize="12"
                Padding="12,6"
                Click="ScrollToBottomButton_Click"/>

        <!-- ========== INPUT AREA ========== -->
        <Border Grid.Row="2"
                Background="{DynamicResource ChatInputPanelBackgroundBrush}"
                Padding="16,12,16,14">
            <Border.Effect>
                <DropShadowEffect Color="#000000" Opacity="0.05" BlurRadius="8" ShadowDepth="-2" Direction="90"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Speaker selector + shortcut hint + copy buttons (v1.16.5) -->
                <Grid Grid.Row="0" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="発言者："
                                   FontSize="11"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                        <RadioButton Style="{StaticResource SpeakerToggle}"
                                     AutomationProperties.AutomationId="ChatNest.SpeakerSelf"
                                     AutomationProperties.Name="ChatNest.SpeakerSelf"
                                     Content="自分"
                                     IsChecked="{Binding SelectedSpeaker, Converter={StaticResource RadioConverter}, ConverterParameter=自分, Mode=TwoWay}"
                                     GroupName="Speaker"/>
                        <RadioButton Style="{StaticResource SpeakerToggle}"
                                     AutomationProperties.AutomationId="ChatNest.SpeakerRefute"
                                     AutomationProperties.Name="ChatNest.SpeakerRefute"
                                     Content="反論"
                                     IsChecked="{Binding SelectedSpeaker, Converter={StaticResource RadioConverter}, ConverterParameter=反論, Mode=TwoWay}"
                                     GroupName="Speaker"/>
                        <RadioButton Style="{StaticResource SpeakerToggle}"
                                     AutomationProperties.AutomationId="ChatNest.SpeakerSupplement"
                                     AutomationProperties.Name="ChatNest.SpeakerSupplement"
                                     Content="補足"
                                     IsChecked="{Binding SelectedSpeaker, Converter={StaticResource RadioConverter}, ConverterParameter=補足, Mode=TwoWay}"
                                     GroupName="Speaker"/>
                        <RadioButton Style="{StaticResource SpeakerToggle}"
                                     AutomationProperties.AutomationId="ChatNest.SpeakerConclusion"
                                     AutomationProperties.Name="ChatNest.SpeakerConclusion"
                                     Content="結論"
                                     IsChecked="{Binding SelectedSpeaker, Converter={StaticResource RadioConverter}, ConverterParameter=結論, Mode=TwoWay}"
                                     GroupName="Speaker"/>
                    </StackPanel>

                    <!-- CH-8: ショートカットヒント + タイムスタンプ表示切替チェックボックス -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="12,0,6,0">
                        <TextBlock Text="Ctrl + ← / → で切り替え"
                                   FontSize="10"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   VerticalAlignment="Center"/>
                        <CheckBox x:Name="ShowTimestampsCheckBox"
                                  AutomationProperties.AutomationId="ChatNest.ShowTimestampsCheckBox"
                                  AutomationProperties.Name="ChatNest.ShowTimestampsCheckBox"
                                  Content="発言時刻を表示"
                                  IsChecked="{Binding ShowTimestamps, Mode=TwoWay}"
                                  FontSize="10"
                                  Foreground="{DynamicResource SecondaryTextBrush}"
                                  VerticalAlignment="Center"
                                  Margin="16,0,0,0"/>
                    </StackPanel>

                    <!-- v1.16.5: コピーボタン群 + 状態テキスト -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="8,0,0,0">
                        <TextBlock Text="{Binding CopyStatusText}"
                                   FontSize="10"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CopyStatusText}" Value="">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <Button Style="{StaticResource CopyButton}"
                                Content="Copy NestSuite"
                                Command="{Binding CopyNestSuiteCommand}"
                                ToolTip="NoteNest / IdeaNest に貼り付けやすい形式でコピー"/>
                        <Button Style="{StaticResource CopyButton}"
                                Content="Copy Markdown"
                                Command="{Binding CopyMarkdownCommand}"
                                ToolTip="Markdown 形式でコピー"
                                Margin="4,0,0,0"/>
                        <!-- CH-14: 会話整形コピー -->
                        <Button Style="{StaticResource CopyButton}"
                                AutomationProperties.AutomationId="ChatNest.CopyConversationButton"
                                AutomationProperties.Name="ChatNest.CopyConversationButton"
                                Content="会話をコピー"
                                Command="{Binding CopyConversationCommand}"
                                ToolTip="発言者: 本文 形式で会話全体をコピー"
                                Margin="4,0,0,0"/>
                        <!-- CH-9: 会話ファイルエクスポート -->
                        <Button Style="{StaticResource CopyButton}"
                                AutomationProperties.AutomationId="ChatNest.ExportConversationButton"
                                AutomationProperties.Name="ChatNest.ExportConversationButton"
                                Content="会話を保存..."
                                Command="{Binding ExportConversationCommand}"
                                ToolTip="テキスト / Markdown 形式で会話全体をファイルに保存"
                                Margin="4,0,0,0"/>
                    </StackPanel>
                </Grid>

                <!-- Input row: TextBox + Post button -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Margin="0,0,10,0">
                        <TextBox x:Name="InputBox"
                                 AutomationProperties.AutomationId="ChatNest.InputBox"
                                 AutomationProperties.Name="ChatNest.InputBox"
                                 Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 MinHeight="52"
                                 MaxHeight="120"
                                 VerticalScrollBarVisibility="Auto"
                                 FontSize="13"
                                 Padding="10,8"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Foreground="{DynamicResource PrimaryTextBrush}"
                                 CaretBrush="{DynamicResource PrimaryTextBrush}"
                                 VerticalContentAlignment="Top"
                                 PreviewKeyDown="InputBox_PreviewKeyDown">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="FontFamily" Value="Yu Gothic UI, Meiryo UI, sans-serif"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="TextBox">
                                                <ScrollViewer x:Name="PART_ContentHost" Margin="0" Padding="{TemplateBinding Padding}"/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                    </Border>

                    <Button Grid.Column="1"
                            AutomationProperties.AutomationId="ChatNest.PostButton"
                            AutomationProperties.Name="ChatNest.PostButton"
                            Style="{StaticResource PrimaryButton}"
                            Content="投稿"
                            Width="70"
                            VerticalAlignment="Bottom"
                            Command="{Binding PostCommand}"/>
                </Grid>
            </Grid>
        </Border>

        <!-- CH-4: 発言削除確認ダイアログ（オーバーレイ）-->
        <Grid Grid.Row="0" Grid.RowSpan="3"
              Visibility="{Binding IsDeleteConfirmVisible, Converter={StaticResource BoolToVis}}">
            <!-- 半透明バックドロップ -->
            <Border Background="#80000000"/>
            <!-- ダイアログカード -->
            <Border Background="{DynamicResource OverlayCardBackgroundBrush}"
                    CornerRadius="12"
                    Padding="24"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    MaxWidth="300">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.18" BlurRadius="20" ShadowDepth="4"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="この発言を削除しますか？"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               Margin="0,0,0,16"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="キャンセル(_C)"
                                Style="{StaticResource CopyButton}"
                                Padding="14,7"
                                Margin="0,0,8,0"
                                Command="{Binding CancelDeleteCommand}"/>
                        <Button Content="削除(_D)"
                                Style="{StaticResource FlatButton}"
                                Background="{DynamicResource ErrorBrush}"
                                Foreground="White"
                                Padding="14,7"
                                Command="{Binding ConfirmDeleteCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

    </Grid>
</UserControl>
