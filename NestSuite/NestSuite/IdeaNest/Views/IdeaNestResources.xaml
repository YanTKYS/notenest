<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:conv="clr-namespace:NestSuite.IdeaNest.Converters">

    <!-- IdeaNest converters (prefixed with "Idea" to avoid conflicts) -->
    <conv:IdeaBoolToVisibilityConverter x:Key="IdeaBoolToVis" />
    <conv:IdeaBoolToVisibilityConverter x:Key="IdeaBoolToVisInverse" Invert="True" />
    <conv:IdeaStringIsEmptyToVisibilityConverter x:Key="IdeaStringToVis" />
    <conv:IdeaHexStringToBrushConverter x:Key="IdeaHexToBrush" />
    <conv:IdeaColorNameToBrushConverter x:Key="IdeaColorNameToBrush" />
    <conv:IdeaBodyTrimConverter x:Key="IdeaBodyTrim" />

    <!-- IdeaNest uses SH-10 brushes supplied by the active app theme. -->

    <!-- ID-9: Card hover / focus visual feedback -->
    <DropShadowEffect x:Key="IdeaCardHoverShadow"
                      Color="#1F2937" Opacity="0.16" BlurRadius="20" ShadowDepth="4" Direction="270" />

    <!-- Modern TextBox style (IdeaNest) -->
    <Style x:Key="IdeaModernTextBoxStyle" TargetType="TextBox">
        <Setter Property="Background" Value="{DynamicResource IdeaSurfaceBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource IdeaTextPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource IdeaBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="10,8" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            SnapsToDevicePixels="True">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Margin="{TemplateBinding Padding}"
                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                      Background="Transparent" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource IdeaAccentBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.6" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Search TextBox -->
    <Style x:Key="IdeaSearchTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource IdeaModernTextBoxStyle}">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="MinHeight" Value="30" />
    </Style>

    <!-- Card container style -->
    <Style x:Key="IdeaCardContainerStyle" TargetType="Border">
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Background" Value="{DynamicResource IdeaSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource IdeaBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Margin" Value="8" />
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="#1F2937" Opacity="0.08"
                                  BlurRadius="14" ShadowDepth="2" Direction="270" />
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <!-- ID-9: hover — border becomes visible, shadow deepens -->
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="BorderBrush" Value="{DynamicResource IdeaCardHoverBorderBrush}" />
                <Setter Property="Effect"      Value="{StaticResource IdeaCardHoverShadow}" />
            </Trigger>
            <!-- ID-9: keyboard focus — accent border clearly marks the active card -->
            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                <Setter Property="BorderBrush" Value="{DynamicResource IdeaAccentBrush}" />
                <Setter Property="Effect"      Value="{StaticResource IdeaCardHoverShadow}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Icon button -->
    <Style x:Key="IdeaIconButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="6" />
        <Setter Property="Margin" Value="2,0" />
        <Setter Property="MinWidth" Value="30" />
        <Setter Property="MinHeight" Value="30" />
        <Setter Property="Foreground" Value="{DynamicResource IdeaTextSecondaryBrush}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          RecognizesAccessKey="True" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource IdeaHoverOverlayBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource IdeaBorderBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Cursor" Value="Arrow" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Secondary button: outlined, soft -->
    <Style x:Key="IdeaSecondaryButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource IdeaTextPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource IdeaBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="14,8" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="MinWidth" Value="92" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          RecognizesAccessKey="True" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource IdeaHoverOverlayBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource IdeaBorderBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Cursor" Value="Arrow" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Primary button (accent fill) -->
    <Style x:Key="IdeaPrimaryButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{DynamicResource IdeaAccentBrush}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="16,8" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="MinWidth" Value="92" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="8"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          RecognizesAccessKey="True" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource IdeaAccentHoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource IdeaAccentPressedBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Cursor" Value="Arrow" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Floating add button -->
    <Style x:Key="IdeaFloatingAddButtonStyle" TargetType="Button">
        <Setter Property="Width" Value="60" />
        <Setter Property="Height" Value="60" />
        <Setter Property="Background" Value="{DynamicResource IdeaAccentBrush}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="FontSize" Value="30" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" CornerRadius="30"
                            Background="{TemplateBinding Background}">
                        <Border.Effect>
                            <DropShadowEffect Color="#1F2937" Opacity="0.30"
                                              BlurRadius="16" ShadowDepth="3" Direction="270" />
                        </Border.Effect>
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          RecognizesAccessKey="True" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource IdeaAccentHoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource IdeaAccentPressedBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Cursor" Value="Arrow" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Tag chip -->
    <Style x:Key="IdeaTagChipStyle" TargetType="Border">
        <Setter Property="CornerRadius" Value="9" />
        <Setter Property="Background" Value="{DynamicResource IdeaChipBackgroundBrush}" />
        <Setter Property="Padding" Value="8,2" />
        <Setter Property="Margin" Value="0,0,4,4" />
    </Style>

    <Style x:Key="IdeaTagChipTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource IdeaChipForegroundBrush}" />
        <Setter Property="FontSize" Value="11" />
    </Style>

    <!-- Section header -->
    <Style x:Key="IdeaSectionHeaderStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource IdeaTextSecondaryBrush}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <!-- Field label -->
    <Style x:Key="IdeaFieldLabelStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource IdeaTextSecondaryBrush}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Margin" Value="0,0,0,6" />
    </Style>

    <!-- Aliases for ConfirmWindow code-behind which calls FindResource("PrimaryButtonStyle") -->
    <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource IdeaPrimaryButtonStyle}"/>
    <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource IdeaSecondaryButtonStyle}"/>

</ResourceDictionary>
