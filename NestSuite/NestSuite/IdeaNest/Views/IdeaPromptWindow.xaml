<Window x:Class="NestSuite.IdeaNest.Views.IdeaPromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="IdeaNest"
        Width="440" SizeToContent="Height"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource IdeaAppBackgroundBrush}"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True">
    <Border Margin="20" Background="{DynamicResource IdeaSurfaceBrush}" CornerRadius="12" Padding="24">
        <Border.Effect>
            <DropShadowEffect Color="#1F2937" Opacity="0.10" BlurRadius="14" ShadowDepth="2" Direction="270" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" x:Name="HeaderText"
                       Foreground="{DynamicResource IdeaTextPrimaryBrush}"
                       FontSize="15" FontWeight="SemiBold"
                       Margin="0,0,0,6" />

            <TextBlock Grid.Row="1" x:Name="MessageText"
                       Foreground="{DynamicResource IdeaTextSecondaryBrush}"
                       FontSize="12" TextWrapping="Wrap"
                       Margin="0,0,0,14"
                       Visibility="Collapsed" />

            <TextBox Grid.Row="2" x:Name="InputBox"
                     Style="{StaticResource IdeaModernTextBoxStyle}"
                     Margin="0,0,0,20" />

            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="キャンセル" Style="{StaticResource IdeaSecondaryButtonStyle}"
                        Margin="0,0,10,0" IsCancel="True" Click="OnCancel" />
                <Button Content="OK" Style="{StaticResource IdeaPrimaryButtonStyle}"
                        IsDefault="True" Click="OnOk" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
