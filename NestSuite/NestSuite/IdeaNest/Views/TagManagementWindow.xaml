<Window x:Class="NestSuite.IdeaNest.Views.TagManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="タグ管理"
        Width="520" Height="520"
        MinWidth="380" MinHeight="340"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource IdeaAppBackgroundBrush}"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True">
    <Border Margin="20" Background="{StaticResource IdeaSurfaceBrush}" CornerRadius="12" Padding="20">
        <Border.Effect>
            <DropShadowEffect Color="#1F2937" Opacity="0.08" BlurRadius="14" ShadowDepth="2" Direction="270" />
        </Border.Effect>
        <DockPanel>

            <!-- Header -->
            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,16">
                <TextBlock Text="タグ管理"
                           Foreground="{StaticResource IdeaTextPrimaryBrush}"
                           FontSize="16" FontWeight="SemiBold" Margin="0,0,0,4" />
                <TextBlock Text="タグのリネーム（既存タグ名を指定すると統合）・削除ができます"
                           Foreground="{StaticResource IdeaTextSecondaryBrush}"
                           FontSize="12" TextWrapping="Wrap" />
            </StackPanel>

            <!-- Footer -->
            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                        HorizontalAlignment="Right" Margin="0,16,0,0">
                <TextBlock Text="※ タグを削除してもカード自体は削除されません"
                           Foreground="{StaticResource IdeaTextSecondaryBrush}"
                           FontSize="11" VerticalAlignment="Center" Margin="0,0,16,0" />
                <Button Content="閉じる" Style="{StaticResource IdeaSecondaryButtonStyle}"
                        IsCancel="True" Click="OnClose" />
            </StackPanel>

            <!-- Tag list -->
            <Border DockPanel.Dock="Top"
                    BorderBrush="{StaticResource IdeaBorderBrush}" BorderThickness="1"
                    CornerRadius="8" ClipToBounds="True">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="TagList" ItemsSource="{Binding TagItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border x:Name="RowBd"
                                        BorderBrush="{StaticResource IdeaBorderBrush}"
                                        BorderThickness="0,0,0,1"
                                        Padding="12,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" Orientation="Horizontal"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="{Binding DisplayName}"
                                                       FontSize="14"
                                                       Foreground="{StaticResource IdeaTextPrimaryBrush}"
                                                       VerticalAlignment="Center" />
                                            <Border Background="{StaticResource IdeaChipBackgroundBrush}"
                                                    CornerRadius="9" Padding="8,2" Margin="8,0,0,0">
                                                <TextBlock Text="{Binding CountText}"
                                                           FontSize="11"
                                                           Foreground="{StaticResource IdeaChipForegroundBrush}" />
                                            </Border>
                                        </StackPanel>

                                        <Button Grid.Column="2" Content="リネーム"
                                                Style="{StaticResource IdeaIconButtonStyle}"
                                                Padding="10,4" FontSize="12"
                                                Tag="{Binding Name}"
                                                Click="OnRenameClick" />
                                        <Button Grid.Column="3" Content="削除"
                                                Style="{StaticResource IdeaIconButtonStyle}"
                                                Padding="10,4" FontSize="12"
                                                Foreground="#DC2626"
                                                Tag="{Binding Name}"
                                                Click="OnDeleteClick" />
                                    </Grid>
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="{StaticResource IdeaHoverOverlayBrush}" />
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

        </DockPanel>
    </Border>
</Window>
