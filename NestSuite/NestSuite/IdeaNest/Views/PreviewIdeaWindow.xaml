<Window x:Class="NestSuite.IdeaNest.Views.PreviewIdeaWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="アイデアの詳細"
        Width="720" Height="640"
        MinWidth="520" MinHeight="380"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource IdeaAppBackgroundBrush}"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True">
    <Border Margin="0"
            Background="{Binding BackgroundBrush, Converter={StaticResource IdeaHexToBrush}}"
            CornerRadius="0"
            Padding="16">
        <DockPanel>
            <!-- Header: pin star + editable title + archive badge -->
            <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="★"
                           Foreground="#E0A800" FontSize="22"
                           Margin="0,0,8,0" VerticalAlignment="Center"
                           Visibility="{Binding IsPinned, Converter={StaticResource IdeaBoolToVis}}" />
                <TextBox Grid.Column="1"
                         x:Name="TitleBox"
                         Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"
                         Foreground="{StaticResource IdeaTextPrimaryBrush}"
                         FontWeight="SemiBold" FontSize="22"
                         TextWrapping="Wrap" VerticalAlignment="Center"
                         AcceptsReturn="False"
                         Background="Transparent"
                         BorderThickness="0"
                         Padding="2,0" />
                <Border Grid.Column="2" VerticalAlignment="Center" Margin="10,0,0,0"
                        Background="{StaticResource IdeaChipBackgroundBrush}"
                        CornerRadius="9" Padding="10,4"
                        Visibility="{Binding IsArchived, Converter={StaticResource IdeaBoolToVis}}">
                    <TextBlock Text="📥 アーカイブ済み"
                               Foreground="{StaticResource IdeaChipForegroundBrush}" FontSize="12" />
                </Border>
            </Grid>

            <!-- Tags (editable, comma-separated) -->
            <Grid DockPanel.Dock="Top" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="タグ: "
                           Foreground="{StaticResource IdeaTextSecondaryBrush}"
                           FontSize="12" VerticalAlignment="Center" Margin="2,0,2,0" />
                <TextBox Grid.Column="1" x:Name="TagsBox"
                         Text="{Binding TagsText, UpdateSourceTrigger=PropertyChanged}"
                         Foreground="{StaticResource IdeaTextSecondaryBrush}"
                         FontSize="12"
                         ToolTip="タグをカンマ区切りで入力 (例: アイデア, メモ, 仕事)"
                         TextWrapping="NoWrap"
                         AcceptsReturn="False"
                         Background="Transparent"
                         BorderThickness="0"
                         Padding="0" />
            </Grid>

            <!-- Footer: dates + color picker + action buttons -->
            <Grid DockPanel.Dock="Bottom" Margin="0,10,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Dates row (hidden in new-card mode) -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8"
                            Visibility="{Binding IsExistingCard, Converter={StaticResource IdeaBoolToVis}}">
                    <TextBlock Text="作成: " Foreground="{StaticResource IdeaTextSecondaryBrush}" FontSize="11" />
                    <TextBlock Text="{Binding CreatedAtText}" Foreground="{StaticResource IdeaTextSecondaryBrush}" FontSize="11" />
                    <TextBlock Text="  /  更新: " Foreground="{StaticResource IdeaTextSecondaryBrush}" FontSize="11" />
                    <TextBlock Text="{Binding UpdatedAtText}" Foreground="{StaticResource IdeaTextSecondaryBrush}" FontSize="11" />
                </StackPanel>

                <!-- Color picker -->
                <ListBox Grid.Row="1" Margin="0,0,0,10"
                         ItemsSource="{Binding AvailableColors}"
                         SelectedItem="{Binding Color}"
                         Background="Transparent" BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Margin" Value="0,0,8,0" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="Cursor" Value="Hand" />
                            <Setter Property="ToolTip" Value="{Binding}" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="Ring" Width="28" Height="28" CornerRadius="14"
                                                Background="Transparent"
                                                BorderBrush="Transparent" BorderThickness="2"
                                                Padding="2">
                                            <Ellipse Fill="{Binding Converter={StaticResource IdeaColorNameToBrush}}"
                                                     Stroke="#D1D5DB" StrokeThickness="1" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Ring" Property="BorderBrush" Value="#FFE4D2" />
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Ring" Property="BorderBrush" Value="{StaticResource IdeaAccentBrush}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>

                <!-- Action buttons -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <Button x:Name="PinButton" Style="{StaticResource IdeaSecondaryButtonStyle}"
                                Click="OnTogglePinClick" Margin="0,0,8,0" />
                        <Button x:Name="ArchiveButton" Style="{StaticResource IdeaSecondaryButtonStyle}"
                                Click="OnToggleArchiveClick" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,8,0">
                        <Button x:Name="PrevButton" Content="← 前" Style="{StaticResource IdeaSecondaryButtonStyle}"
                                ToolTip="前のカード (←)"
                                Click="OnPrevClick" Margin="0,0,4,0" />
                        <Button x:Name="NextButton" Content="次 →" Style="{StaticResource IdeaSecondaryButtonStyle}"
                                ToolTip="次のカード (→)"
                                Click="OnNextClick" />
                    </StackPanel>
                    <Button Grid.Column="2" Content="閉じる(_C)" Style="{StaticResource IdeaPrimaryButtonStyle}"
                            IsCancel="True" Click="OnCloseClick" />
                </Grid>
            </Grid>

            <!-- Body (editable, scrollable) -->
            <Border Background="{Binding BackgroundBrush, Converter={StaticResource IdeaHexToBrush}}"
                    CornerRadius="6" Padding="14">
                <TextBox x:Name="BodyBox"
                         Text="{Binding Body, UpdateSourceTrigger=PropertyChanged}"
                         TextWrapping="Wrap"
                         Foreground="{StaticResource IdeaTextPrimaryBrush}"
                         FontSize="16"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Disabled"
                         Background="Transparent"
                         BorderThickness="0"
                         Padding="0"
                         VerticalAlignment="Stretch" />
            </Border>
        </DockPanel>
    </Border>
</Window>
