<Window x:Class="NestSuite.IdeaNest.Views.IdeaConfirmWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="IdeaNest"
        Width="460" SizeToContent="Height"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource IdeaAppBackgroundBrush}"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True">
    <Border Margin="20" Background="{StaticResource IdeaSurfaceBrush}" CornerRadius="12" Padding="24">
        <Border.Effect>
            <DropShadowEffect Color="#1F2937" Opacity="0.10" BlurRadius="14" ShadowDepth="2" Direction="270" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" x:Name="HeaderText"
                       Foreground="{StaticResource IdeaTextPrimaryBrush}"
                       FontSize="15" FontWeight="SemiBold"
                       Margin="0,0,0,8" />

            <TextBlock Grid.Row="1" x:Name="MessageText"
                       Foreground="{StaticResource IdeaTextPrimaryBrush}"
                       FontSize="13" TextWrapping="Wrap" LineHeight="20"
                       Margin="0,0,0,20" />

            <StackPanel Grid.Row="2" x:Name="ButtonStack"
                        Orientation="Horizontal" HorizontalAlignment="Right" />
        </Grid>
    </Border>
</Window>
