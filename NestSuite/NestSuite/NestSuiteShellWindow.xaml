<Window x:Class="NestSuite.NestSuiteShellWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:NestSuite.Views"
        xmlns:chatnest="clr-namespace:NestSuite.ChatNest"
        xmlns:ideanest="clr-namespace:NestSuite.IdeaNest.Views"
        xmlns:tempnest="clr-namespace:NestSuite.TempNest"
        Title="NestSuite"
        Height="720" Width="1280"
        MinHeight="500" MinWidth="870"
        WindowStartupLocation="CenterScreen">
    <Window.CommandBindings>
        <!-- v1.16.1: Ctrl+S で SaveActiveTab() を実行する。ApplicationCommands.Save は Ctrl+S ジェスチャを内包する -->
        <CommandBinding Command="ApplicationCommands.Save" Executed="CommandSave_Executed"/>
    </Window.CommandBindings>
    <DockPanel>
        <!-- ファイルメニュー: 新規/開くはツール横断、保存系は選択中タブの WorkspaceKind に応じて処理する -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="ファイル(_F)">
                <MenuItem Header="新規(_N)">
                    <MenuItem Header="新規 NoteNest(_N)" Click="MenuNewNoteNest_Click"/>
                    <MenuItem Header="新規 ChatNest(_C)"  Click="MenuNewChatNest_Click"/>
                    <MenuItem Header="新規 IdeaNest(_I)"  Click="MenuNewIdeaNest_Click"/>
                </MenuItem>
                <MenuItem Header="開く(_O)..." Click="MenuOpen_Click"/>
                <MenuItem x:Name="RecentFilesMenu" Header="最近使ったファイル(_R)">
                    <MenuItem Header="（履歴なし）" IsEnabled="False"/>
                </MenuItem>
                <Separator/>
                <MenuItem Header="上書き保存(_S)" Command="ApplicationCommands.Save"/>
                <MenuItem Header="名前を付けて保存(_A)..." Click="MenuSaveAs_Click"/>
                <Separator/>
                <MenuItem Header="終了(_X)" Click="MenuExit_Click"/>
            </MenuItem>
            <MenuItem Header="ツール(_T)">
                <!-- v1.7.3: ツール選択はタブランチャーとして機能する。既存タブがあれば移動、なければ新規作成 -->
                <MenuItem x:Name="ToolMenuNoteNest" Header="NoteNest"
                          Tag="NoteNest"
                          IsCheckable="True" IsChecked="True"
                          Click="MenuTool_Click"/>
                <MenuItem x:Name="ToolMenuIdeaNest" Header="IdeaNest"
                          Tag="IdeaNest"
                          IsCheckable="True"
                          Click="MenuTool_Click"/>
                <MenuItem x:Name="ToolMenuChatNest" Header="ChatNest"
                          Tag="ChatNest"
                          IsCheckable="True"
                          Click="MenuTool_Click"/>
            </MenuItem>
            <MenuItem Header="表示(_V)">
                <MenuItem Header="テーマ(_T)">
                    <MenuItem x:Name="ThemeLightMenuItem"
                              Header="Light"
                              IsCheckable="True"
                              Click="MenuThemeLight_Click"/>
                    <MenuItem x:Name="ThemeDarkMenuItem"
                              Header="Dark"
                              IsCheckable="True"
                              Click="MenuThemeDark_Click"/>
                </MenuItem>
            </MenuItem>
            <MenuItem Header="ヘルプ(_H)">
                <MenuItem Header="ファイル関連付けの設定(_A)..." Click="MenuFileAssociation_Click"/>
                <Separator/>
                <MenuItem Header="NestSuite について" Click="MenuAbout_Click"/>
            </MenuItem>
        </Menu>

        <!-- NestSuite ヘッダーバー（v1.16.2: ツールランチャーを右側へ移動） -->
        <Border DockPanel.Dock="Top" Height="32"
                Background="{DynamicResource GroupHeaderBg}"
                BorderBrush="{DynamicResource PaneBorder}"
                BorderThickness="0,0,0,1">
            <DockPanel>
                <!-- v1.16.2 fix: DockPanel.Dock="Right" を先に配置し、TextBlock が残り左領域を埋める。
                     ツールランチャーがヘッダー右端に固定される -->
                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal" VerticalAlignment="Center" Margin="4,0">
                    <Border x:Name="NoteNestToolBorder"
                            Tag="NoteNest"
                            CornerRadius="4" Margin="2,2" Padding="8,4"
                            Cursor="Hand"
                            MouseLeftButtonDown="ToolBorder_MouseDown">
                        <TextBlock x:Name="NoteNestToolLabel"
                                   Text="NoteNest" FontSize="12"
                                   Foreground="{DynamicResource PrimaryFg}"/>
                    </Border>
                    <Border x:Name="IdeaNestToolBorder"
                            Tag="IdeaNest"
                            CornerRadius="4" Margin="2,2" Padding="8,4"
                            Cursor="Hand"
                            MouseLeftButtonDown="ToolBorder_MouseDown">
                        <TextBlock Text="IdeaNest" FontSize="12"
                                   Foreground="{DynamicResource PrimaryFg}"/>
                    </Border>
                    <Border x:Name="ChatNestToolBorder"
                            Tag="ChatNest"
                            CornerRadius="4" Margin="2,2" Padding="8,4"
                            Cursor="Hand"
                            MouseLeftButtonDown="ToolBorder_MouseDown">
                        <TextBlock Text="ChatNest" FontSize="12"
                                   Foreground="{DynamicResource PrimaryFg}"/>
                    </Border>
                </StackPanel>
                <TextBlock DockPanel.Dock="Left"
                           Text="NestSuite" FontWeight="Bold" FontSize="13"
                           VerticalAlignment="Center" Margin="12,0"
                           Foreground="{DynamicResource PrimaryFg}"/>
            </DockPanel>
        </Border>

        <!-- NestSuite ステータスバー（プロジェクト名・未保存・選択ツール動的表示） -->
        <Border DockPanel.Dock="Bottom" Height="22"
                Background="{DynamicResource StatusBarBg}"
                BorderBrush="{DynamicResource PaneBorder}"
                BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0">
                <TextBlock Text="{Binding ProjectDisplayName}"
                           AutomationProperties.AutomationId="Shell.StatusBar"
                           AutomationProperties.Name="Shell.StatusBar"
                           FontSize="11" Foreground="{DynamicResource MutedFg}"/>
                <TextBlock Text="{Binding UnsavedIndicatorText}"
                           FontSize="11" Foreground="{DynamicResource UnsavedBrush}"
                           Visibility="{Binding IsModified, Converter={StaticResource BoolToVis}}"/>
                <TextBlock x:Name="NestSuiteModeSuffix"
                           Text="  /  NoteNest"
                           FontSize="11" Foreground="{DynamicResource MutedFg}"/>
                <TextBlock x:Name="WorkspaceStatusText"
                           FontSize="11" Foreground="{DynamicResource MutedFg}"/>
            </StackPanel>
        </Border>

        <!-- メインエリア: Workspace 領域（v1.16.2: 左ツール選択カラムを廃止し全幅化） -->
        <Grid>
            <Grid.RowDefinitions>
                <!-- v1.16.4: Height="Auto" + MinHeight="50" でタブ（32px）とスクロールバー（~17px）が重ならないよう確保 -->
                <RowDefinition Height="Auto"/>
                <!-- Workspace コンテンツ -->
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- v1.7.3: ファイル単位タブストリップ。ItemsSource は NestSuiteDocumentTab のコレクション -->
            <!-- v2.2.0: DockPanel で「＋」ボタン（SH-5）を右端に追加 -->
            <Border Grid.Row="0"
                    MinHeight="50"
                    BorderBrush="{DynamicResource PaneBorder}"
                    BorderThickness="0,0,0,1">
                <DockPanel>
                    <!-- v2.2.0 SH-5: 新規タブ追加ボタン。クリックで NoteNest/IdeaNest/ChatNest 選択メニューを表示 -->
                    <Button DockPanel.Dock="Right"
                            AutomationProperties.AutomationId="Shell.TabAddButton"
                            AutomationProperties.Name="Shell.TabAddButton"
                            Content="＋"
                            FontSize="14"
                            Width="36"
                            VerticalAlignment="Stretch"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            ToolTip="新規タブを追加"
                            Click="TabAddButton_Click">
                        <Button.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="新規 NoteNest(_N)" Click="MenuNewNoteNest_Click"/>
                                <MenuItem Header="新規 IdeaNest(_I)"  Click="MenuNewIdeaNest_Click"/>
                                <MenuItem Header="新規 ChatNest(_C)"  Click="MenuNewChatNest_Click"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                    <!-- v2.7.9 SH-6: タブ一覧ボタン。クリックで開いているタブをドロップダウン一覧表示 -->
                    <Button DockPanel.Dock="Right"
                            AutomationProperties.AutomationId="Shell.TabListButton"
                            AutomationProperties.Name="Shell.TabListButton"
                            Content="▾"
                            FontSize="12"
                            Width="28"
                            VerticalAlignment="Stretch"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            ToolTip="タブ一覧"
                            Click="TabListButton_Click"/>
                    <ListBox x:Name="TabStrip"
                             AutomationProperties.AutomationId="Shell.TabStrip"
                             AutomationProperties.Name="Shell.TabStrip"
                             BorderThickness="0"
                             Background="{DynamicResource GroupHeaderBg}"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto"
                             ScrollViewer.VerticalScrollBarVisibility="Disabled"
                             AllowDrop="True"
                             SelectionChanged="TabStrip_SelectionChanged"
                             PreviewMouseLeftButtonDown="TabStrip_PreviewMouseLeftButtonDown"
                             PreviewMouseMove="TabStrip_PreviewMouseMove"
                             PreviewMouseDown="TabStrip_PreviewMouseButtonDown"
                             DragOver="TabStrip_DragOver"
                             DragLeave="TabStrip_DragLeave"
                             Drop="TabStrip_Drop">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <!-- v2.2.0 SH-7: Padding="0" / Stretch でアクセント帯を ListBoxItem 全幅に描画 -->
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                                <Setter Property="Height" Value="32"/>
                                <Setter Property="AutomationProperties.AutomationId" Value="{Binding TabAutomationId}"/>
                                <Setter Property="AutomationProperties.Name" Value="{Binding TabAutomationId}"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <!-- v1.9.9: ツールチップにツール種別・ファイルパス・保存状態を表示 -->
                                <!-- v2.2.0 SH-7: 上部 3px に Workspace 種別カラーアクセントを追加 -->
                                <!-- v2.4.0 SH-2: 右クリックコンテキストメニュー -->
                                <Grid ToolTip="{Binding TooltipText}">
                                    <Grid.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="このタブを閉じる(_C)"
                                                      IsEnabled="{Binding CanClose}"
                                                      Click="TabContextClose_Click"/>
                                            <!-- v2.9.0 SH-21: NoteNest タブのみ別ウィンドウ表示を提供する -->
                                            <MenuItem Header="別ウィンドウで表示(_D)"
                                                      Visibility="{Binding IsNoteNest, Converter={StaticResource BoolToVis}}"
                                                      Click="TabContextDetach_Click"/>
                                            <Separator/>
                                            <MenuItem Header="他のタブを閉じる(_O)"   Click="TabContextCloseOthers_Click"/>
                                            <MenuItem Header="右側のタブを閉じる(_R)" Click="TabContextCloseRight_Click"/>
                                        </ContextMenu>
                                    </Grid.ContextMenu>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="3"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <Border Grid.Row="0"
                                            Background="{Binding WorkspaceKind, Converter={StaticResource KindToAccent}}"/>
                                    <!-- タブラベル・未保存マーク・閉じるボタン -->
                                    <StackPanel Grid.Row="1" Orientation="Horizontal"
                                                VerticalAlignment="Center" Margin="12,0">
                                        <TextBlock Text="{Binding TabHeaderText}" FontSize="12"
                                                   VerticalAlignment="Center"/>
                                        <!-- v2.2.0: 未保存マークを ● に変更（視認性向上） -->
                                        <TextBlock Text="●" FontSize="10"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource UnsavedBrush}"
                                                   Margin="4,0,0,0"
                                                   Visibility="{Binding IsModified, Converter={StaticResource BoolToVis}}"/>
                                        <!-- v1.7.6: タブ閉じるボタン。Tag に自身のタブモデルをバインドして渡す -->
                                        <Button Content="×" FontSize="10"
                                                Margin="6,0,0,0" Padding="3,1"
                                                VerticalAlignment="Center"
                                                Background="Transparent" BorderThickness="0"
                                                Cursor="Hand"
                                                ToolTip="このタブを閉じる"
                                                Tag="{Binding}"
                                                Visibility="{Binding CanClose, Converter={StaticResource BoolToVis}}"
                                                Click="TabClose_Click"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- Workspace コンテンツ（選択タブに対応する Workspace を表示） -->
            <Grid Grid.Row="1">
                <!-- v1.10.2: Visibility="Collapsed" デフォルトにした。ActivateTab が表示を制御する。
                     起動時にタブ未選択の瞬間 NoteNest Workspace が見えるちらつきを防ぐ。 -->
                <views:NoteNestWorkspaceView x:Name="WorkspaceView"
                                             AutomationProperties.AutomationId="Shell.NoteNestWorkspace"
                                             AutomationProperties.Name="Shell.NoteNestWorkspace"
                                             Visibility="Collapsed"/>
                <!-- v1.7.0: ChatNest 統合検証用 Workspace（ChatNest タブ選択時に表示） -->
                <chatnest:ChatNestWorkspaceView x:Name="ChatWorkspaceView"
                                                AutomationProperties.AutomationId="Shell.ChatNestWorkspace"
                                                AutomationProperties.Name="Shell.ChatNestWorkspace"
                                                Visibility="Collapsed"/>
                <!-- v1.8.0: IdeaNest 統合検証用 Workspace（IdeaNest タブ選択時に表示） -->
                <ideanest:IdeaNestWorkspaceView x:Name="IdeaNestWorkspaceView"
                                                AutomationProperties.AutomationId="Shell.IdeaNestWorkspace"
                                                AutomationProperties.Name="Shell.IdeaNestWorkspace"
                                                ShowMenu="False" Visibility="Collapsed"/>
                <!-- v2.6.0: TempNest 固定タブ Workspace（ファイル型でない内部 JSON 管理の一時メモ） -->
                <tempnest:TempNestWorkspaceView x:Name="TempNestWorkspaceView"
                                                AutomationProperties.AutomationId="Shell.TempNestWorkspace"
                                                AutomationProperties.Name="Shell.TempNestWorkspace"
                                                Visibility="Collapsed"/>
                <!-- v2.9.0 SH-21: 別ウィンドウ表示中の NoteNest タブ向けプレースホルダー -->
                <Grid x:Name="DetachedNoteNestPlaceholder" Visibility="Collapsed"
                      Background="{DynamicResource SidebarBg}">
                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                               Text="このWorkspaceは別ウィンドウで表示中です"
                               FontSize="14"
                               Foreground="{DynamicResource MutedFg}"/>
                </Grid>
                <!-- 未統合ツールタブ選択時のプレースホルダー -->
                <Border x:Name="UnintegratedPlaceholder" Visibility="Collapsed"
                        Background="{DynamicResource SidebarBg}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                Margin="24">
                        <TextBlock x:Name="PlaceholderTitle"
                                   FontSize="18" FontWeight="Bold"
                                   TextAlignment="Center"
                                   Foreground="{DynamicResource MutedFg}"
                                   Margin="0,0,0,16"/>
                        <TextBlock x:Name="PlaceholderMessage"
                                   FontSize="13" TextAlignment="Center"
                                   Foreground="{DynamicResource SubtleFg}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
