<UserControl x:Class="NestSuite.TempNest.TempNestWorkspaceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="{DynamicResource AppBg}" Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="8"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Slot 1: Top-Left -->
        <Border Grid.Row="0" Grid.Column="0"
                BorderBrush="{DynamicResource PaneBorder}" BorderThickness="1"
                CornerRadius="4" Background="{DynamicResource SidebarBg}">
            <DockPanel Margin="10">
                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                            HorizontalAlignment="Right" Margin="0,6,0,0">
                    <TextBlock Text="コピーしました"
                               Foreground="{DynamicResource MutedFg}"
                               FontSize="10.5"
                               Margin="0,0,6,0"
                               VerticalAlignment="Center"
                               Visibility="{Binding Slot1.ShowCopyFeedback, Converter={StaticResource BoolToVis}}"/>
                    <Button Content="コピー" Padding="8,3" Margin="0,0,4,0" FontSize="11"
                            AutomationProperties.AutomationId="TempNest.Slot1.CopyButton"
                            AutomationProperties.Name="TempNest.Slot1.CopyButton"
                            Command="{Binding Slot1.CopyBodyCommand}"
                            Background="Transparent" BorderBrush="{DynamicResource PaneBorder}" BorderThickness="1"/>
                    <Button Content="クリア" Padding="8,3" FontSize="11"
                            AutomationProperties.AutomationId="TempNest.Slot1.ClearButton"
                            AutomationProperties.Name="TempNest.Slot1.ClearButton"
                            Command="{Binding Slot1.ClearCommand}"
                            Background="Transparent" BorderBrush="{DynamicResource PaneBorder}" BorderThickness="1"/>
                </StackPanel>
                <Grid DockPanel.Dock="Top" Margin="0,0,0,6">
                    <TextBox Text="{Binding Slot1.Title, UpdateSourceTrigger=PropertyChanged}"
                             AutomationProperties.AutomationId="TempNest.Slot1.TitleBox"
                             AutomationProperties.Name="TempNest.Slot1.TitleBox"
                             BorderThickness="0,0,0,1" BorderBrush="{DynamicResource PaneBorder}"
                             Background="Transparent" Foreground="{DynamicResource AppFg}"
                             FontSize="12" FontWeight="SemiBold" Padding="0,0,0,4"
                             MaxLength="100"/>
                    <TextBlock Text="タイトル"
                               Foreground="{DynamicResource MutedFg}"
                               FontSize="12" FontWeight="SemiBold"
                               Padding="1,0,0,0" VerticalAlignment="Top"
                               IsHitTestVisible="False">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Slot1.Title}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
                <Grid>
                    <TextBox Text="{Binding Slot1.Body, UpdateSourceTrigger=PropertyChanged}"
                             AutomationProperties.AutomationId="TempNest.Slot1.BodyBox"
                             AutomationProperties.Name="TempNest.Slot1.BodyBox"
                             AcceptsReturn="True" TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             BorderThickness="0" Background="Transparent"
                             Foreground="{DynamicResource AppFg}"
                             VerticalContentAlignment="Top" FontSize="12" Padding="0"
                             SpellCheck.IsEnabled="False"/>
                    <TextBlock Text="一時メモ"
                               Foreground="{DynamicResource MutedFg}"
                               FontSize="12"
                               Padding="1,0,0,0" VerticalAlignment="Top"
                               IsHitTestVisible="False">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Slot1.Body}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </DockPanel>
        </Border>

