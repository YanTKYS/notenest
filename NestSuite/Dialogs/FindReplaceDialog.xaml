<Window x:Class="NestSuite.Dialogs.FindReplaceDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="検索と置換"
        Width="420" Height="210"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Closing="Window_Closing">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="80"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="検索:" VerticalAlignment="Center"/>
        <TextBox   Grid.Row="0" Grid.Column="1" x:Name="FindBox" FontSize="13" Padding="4,3"
                   KeyDown="FindBox_KeyDown"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="置換:" VerticalAlignment="Center"/>
        <TextBox   Grid.Row="2" Grid.Column="1" x:Name="ReplaceBox" FontSize="13" Padding="4,3"/>

        <CheckBox  Grid.Row="4" Grid.Column="1" x:Name="CaseCheck" Content="大文字/小文字を区別する" FontSize="12"/>

        <StackPanel Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2"
                    Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="次を検索" Width="90" Margin="0,0,6,0" Click="FindNext_Click" IsDefault="True" Padding="6,4"/>
            <Button Content="置換" Width="70" Margin="0,0,6,0" Click="Replace_Click" Padding="6,4"/>
            <Button Content="すべて置換" Width="90" Margin="0,0,6,0" Click="ReplaceAll_Click" Padding="6,4"/>
            <Button Content="閉じる" Width="70" Click="Close_Click" Padding="6,4"/>
        </StackPanel>
    </Grid>
</Window>
