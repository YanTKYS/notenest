<Window x:Class="NestSuite.Dialogs.FindReplaceDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="検索と置換"
        Width="460" Height="250"
        MinWidth="380" MinHeight="230"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Closing="Window_Closing">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- 0: 検索 -->
            <RowDefinition Height="4"/>
            <RowDefinition Height="Auto"/>   <!-- 2: 件数表示 -->
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>   <!-- 4: 置換 -->
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>   <!-- 6: チェックボックス行 -->
            <RowDefinition Height="4"/>
            <RowDefinition Height="Auto"/>   <!-- 8: ラップ/ステータス通知 -->
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>   <!-- 10: ボタン -->
            <RowDefinition Height="6"/>
            <RowDefinition Height="*"/>      <!-- 12: 全ノート検索結果 -->
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="80"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 検索 -->
        <TextBlock Grid.Row="0" Grid.Column="0" Text="検索:" VerticalAlignment="Center"/>
        <TextBox   Grid.Row="0" Grid.Column="1" x:Name="FindBox" FontSize="13" Padding="4,3"
                   KeyDown="FindBox_KeyDown"/>

        <!-- 件数表示 -->
        <TextBlock Grid.Row="2" Grid.Column="1" x:Name="MatchCountText"
                   FontSize="11" VerticalAlignment="Center" Margin="2,0"/>

        <!-- 置換 -->
        <TextBlock Grid.Row="4" Grid.Column="0" Text="置換:" VerticalAlignment="Center"/>
        <TextBox   Grid.Row="4" Grid.Column="1" x:Name="ReplaceBox" FontSize="13" Padding="4,3"/>

        <!-- チェックボックス -->
        <StackPanel Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal">
            <CheckBox x:Name="CaseCheck" Content="大文字/小文字を区別する(_S)" FontSize="12"
                      Margin="0,0,20,0"
                      Checked="CaseCheck_Changed" Unchecked="CaseCheck_Changed"/>
            <CheckBox x:Name="AllNotesCheck" Content="全ノートを検索(_G)" FontSize="12"
                      Checked="AllNotes_Changed" Unchecked="AllNotes_Changed"/>
        </StackPanel>

        <!-- ラップ通知・ステータスメッセージ -->
        <TextBlock Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="2"
                   x:Name="StatusText"
                   FontSize="11" Foreground="{DynamicResource FaintFg}"
                   TextWrapping="Wrap"/>

        <!-- ボタン -->
        <StackPanel Grid.Row="10" Grid.Column="0" Grid.ColumnSpan="2"
                    Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="次を検索(_N)" Width="90" Margin="0,0,5,0" IsDefault="True"
                    Click="FindNext_Click" Padding="6,4"/>
            <Button Content="前を検索(_P)" Width="90" Margin="0,0,5,0"
                    Click="FindPrev_Click" Padding="6,4"/>
            <Button x:Name="ReplaceButton" Content="置換(_R)" Width="70" Margin="0,0,5,0"
                    Click="Replace_Click" Padding="6,4"/>
            <Button x:Name="ReplaceAllButton" Content="すべて置換(_A)" Width="92" Margin="0,0,5,0"
                    Click="ReplaceAll_Click" Padding="6,4"/>
            <Button Content="閉じる(_C)" Width="70" Click="Close_Click" Padding="6,4"/>
        </StackPanel>

        <!-- 全ノート検索結果 (AllNotesCheck 有効時のみ表示) -->
        <Border Grid.Row="12" Grid.Column="0" Grid.ColumnSpan="2"
                Visibility="Collapsed"
                x:Name="AllNotesResultBorder"
                BorderBrush="{DynamicResource PaneBorder}" BorderThickness="0,1,0,0"
                Margin="0,4,0,0">
            <ListBox x:Name="AllNotesResultList"
                     SelectionMode="Single"
                     FontSize="12"
                     BorderThickness="0"
                     MouseDoubleClick="AllNotesResult_DoubleClick"
                     KeyDown="AllNotesResult_KeyDown">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Display}"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding Display}"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>
    </Grid>
</Window>
