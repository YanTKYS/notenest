<Window x:Class="NestSuite.Dialogs.FontSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="フォント設定"
        Width="380" Height="220"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="90"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="フォント:" VerticalAlignment="Center"/>
        <ComboBox  Grid.Row="0" Grid.Column="1" x:Name="FontFamilyBox"
                   AutomationProperties.AutomationId="Dialog.FontFamilyBox"
                   AutomationProperties.Name="Dialog.FontFamilyBox"
                   FontSize="13" SelectedValuePath="Content"
                   SelectionChanged="FontFamilyBox_SelectionChanged">
            <ComboBoxItem Content="Yu Gothic UI"/>
            <ComboBoxItem Content="Meiryo UI"/>
            <ComboBoxItem Content="MS Gothic"/>
            <ComboBoxItem Content="MS Mincho"/>
            <ComboBoxItem Content="BIZ UDGothic"/>
            <ComboBoxItem Content="Consolas"/>
            <ComboBoxItem Content="Courier New"/>
            <ComboBoxItem Content="Segoe UI"/>
            <ComboBoxItem Content="Arial"/>
        </ComboBox>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="サイズ:" VerticalAlignment="Center"/>
        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
            <TextBox x:Name="FontSizeBox" Width="60" FontSize="13" Padding="4,3"
                     AutomationProperties.AutomationId="Dialog.FontSizeBox"
                     AutomationProperties.Name="Dialog.FontSizeBox"
                     TextChanged="FontSizeBox_TextChanged"/>
            <TextBlock Text="pt" VerticalAlignment="Center" Margin="6,0,0,0" Foreground="Gray"/>
        </StackPanel>

        <Border Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2"
                BorderBrush="#E0E0E0" BorderThickness="1" Padding="8,6">
            <TextBlock x:Name="PreviewText"
                       Text="プレビュー: あいうえお ABCdef 012345"
                       TextWrapping="Wrap"/>
        </Border>

        <StackPanel Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2"
                    Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" Width="80" Margin="0,0,8,0" IsDefault="True"
                    AutomationProperties.AutomationId="Dialog.OkButton"
                    AutomationProperties.Name="Dialog.OkButton"
                    Click="OK_Click"
                    Background="#2B5CE6" Foreground="White" BorderThickness="0" Padding="6,4"/>
            <Button Content="キャンセル" Width="88" IsCancel="True"
                    AutomationProperties.AutomationId="Dialog.CancelButton"
                    AutomationProperties.Name="Dialog.CancelButton"
                    Click="Cancel_Click" Padding="6,4"/>
        </StackPanel>
    </Grid>
</Window>
