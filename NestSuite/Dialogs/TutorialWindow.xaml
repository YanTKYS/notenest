<Window x:Class="NestSuite.Dialogs.TutorialWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="チュートリアル"
        Width="900" Height="650"
        MinWidth="400" MinHeight="300"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto">
            <Image x:Name="TutorialImage"
                   Source="pack://application:,,,/Assets/tutorial.png"
                   Stretch="Uniform"
                   StretchDirection="DownOnly"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Top"
                   Margin="8"/>
        </ScrollViewer>

        <Border Grid.Row="1" BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource {x:Static SystemColors.ControlLightBrushKey}}"
                Padding="8,6">
            <Button Content="閉じる" Width="88" HorizontalAlignment="Right"
                    IsCancel="True" Click="Close_Click" Padding="6,4"/>
        </Border>
    </Grid>
</Window>
