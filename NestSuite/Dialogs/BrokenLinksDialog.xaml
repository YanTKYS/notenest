<Window x:Class="NestSuite.Dialogs.BrokenLinksDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="リンク切れチェック"
        Width="600" Height="440"
        MinWidth="420" MinHeight="300"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="HeaderText" Grid.Row="0" FontSize="13"
                   AutomationProperties.AutomationId="Dialog.HeaderText"
                   AutomationProperties.Name="Dialog.HeaderText"/>

        <Grid Grid.Row="2">
            <TextBlock x:Name="EmptyMessage"
                       Text="リンク切れはありません ✓"
                       FontSize="14"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Foreground="#2E7D32"
                       Visibility="Collapsed"/>
            <ListView x:Name="ResultList"
                      AutomationProperties.AutomationId="Dialog.ResultList"
                      AutomationProperties.Name="Dialog.ResultList"
                      FontSize="12"
                      SelectionMode="Single"
                      Visibility="Collapsed"
                      MouseDoubleClick="ResultList_MouseDoubleClick">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="ソースノート" Width="150" DisplayMemberBinding="{Binding SourceNoteTitle}"/>
                        <GridViewColumn Header="リンク名"     Width="150" DisplayMemberBinding="{Binding LinkName}"/>
                        <GridViewColumn Header="行"           Width="45"  DisplayMemberBinding="{Binding LineNumber}"/>
                        <GridViewColumn Header="行の内容"     Width="180" DisplayMemberBinding="{Binding LineExcerpt}"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </Grid>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="NavigateButton"
                    AutomationProperties.AutomationId="Dialog.NavigateButton"
                    AutomationProperties.Name="Dialog.NavigateButton"
                    Content="このノートへ移動"
                    Width="130"
                    Margin="0,0,8,0"
                    IsDefault="True"
                    Click="Navigate_Click"
                    Background="#2B5CE6"
                    Foreground="White"
                    BorderThickness="0"
                    Padding="6,4"/>
            <Button Content="閉じる"
                    AutomationProperties.AutomationId="Dialog.CloseButton"
                    AutomationProperties.Name="Dialog.CloseButton"
                    Width="80"
                    IsCancel="True"
                    Click="Close_Click"
                    Padding="6,4"/>
        </StackPanel>
    </Grid>
</Window>
