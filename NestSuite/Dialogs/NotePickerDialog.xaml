<Window x:Class="NestSuite.Dialogs.NotePickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ノートリンク挿入"
        Width="400" Height="360"
        MinWidth="300" MinHeight="240"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="6"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="6"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="リンク先のノートを選択してください:" FontSize="13"/>

        <!-- L2: ノートタイトル絞り込み TextBox -->
        <Grid Grid.Row="2">
            <TextBox x:Name="NoteFilterBox"
                     AutomationProperties.AutomationId="Dialog.NoteFilterBox"
                     AutomationProperties.Name="Dialog.NoteFilterBox"
                     FontSize="12" Padding="6,4"
                     TextChanged="NoteFilter_TextChanged"/>
            <TextBlock Text="ノートを絞り込む..."
                       IsHitTestVisible="False"
                       FontSize="12"
                       Foreground="Gray"
                       Margin="8,0,0,0"
                       VerticalAlignment="Center">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Text, ElementName=NoteFilterBox}" Value="">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Grid>

        <ListBox Grid.Row="4" x:Name="NoteList"
                 AutomationProperties.AutomationId="Dialog.NoteList"
                 AutomationProperties.Name="Dialog.NoteList"
                 DisplayMemberPath="DisplayText"
                 FontSize="13"
                 MouseDoubleClick="NoteList_MouseDoubleClick"/>

        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" Width="80" Margin="0,0,8,0" IsDefault="True"
                    AutomationProperties.AutomationId="Dialog.OkButton"
                    AutomationProperties.Name="Dialog.OkButton"
                    Click="OK_Click"
                    Background="#2B5CE6" Foreground="White" BorderThickness="0" Padding="6,4"/>
            <Button Content="キャンセル" Width="88" IsCancel="True"
                    AutomationProperties.AutomationId="Dialog.CancelButton"
                    AutomationProperties.Name="Dialog.CancelButton"
                    Click="Cancel_Click" Padding="6,4"/>
        </StackPanel>
    </Grid>
</Window>
