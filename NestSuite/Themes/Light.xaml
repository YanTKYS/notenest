<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- layout / structure -->
    <SolidColorBrush x:Key="SidebarBg"      Color="#F5F5F5"/>
    <SolidColorBrush x:Key="PaneBorder"     Color="#E0E0E0"/>
    <SolidColorBrush x:Key="GroupHeaderBg"  Color="#EFEFEF"/>
    <SolidColorBrush x:Key="SelectedNoteBg" Color="#DCE8FF"/>
    <SolidColorBrush x:Key="AccentBlue"     Color="#2B5CE6"/>

    <!-- marker types -->
    <SolidColorBrush x:Key="TodoBrush"      Color="#E67E22"/>
    <SolidColorBrush x:Key="FixmeBrush"     Color="#E74C3C"/>
    <SolidColorBrush x:Key="NoteBrush"      Color="#27AE60"/>

    <!-- task comment mode -->
    <SolidColorBrush x:Key="TaskCommentEditorBg"  Color="#FFFDE7"/>
    <SolidColorBrush x:Key="TaskCommentTitleBg"   Color="#FFF8E1"/>
    <SolidColorBrush x:Key="TaskCommentIndicator" Color="#5B9BD5"/>
    <SolidColorBrush x:Key="CommentBadgeBg"       Color="#FFE082"/>
    <SolidColorBrush x:Key="CommentBadgeFg"       Color="#8C6100"/>

    <!-- unsaved state -->
    <SolidColorBrush x:Key="UnsavedBrush"        Color="#E65100"/>
    <SolidColorBrush x:Key="UnsavedWarningBrush" Color="#CC0000"/>
    <SolidColorBrush x:Key="UnsavedSaveBtnBg"    Color="#FFE0B2"/>

    <!-- sample project banner -->
    <SolidColorBrush x:Key="SampleBannerBg"     Color="#FFF8DC"/>
    <SolidColorBrush x:Key="SampleBannerBorder" Color="#D4B800"/>
    <SolidColorBrush x:Key="SampleBannerFg"     Color="#7A6000"/>

    <!-- line number gutter -->
    <SolidColorBrush x:Key="LineNumberBg"            Color="#F8F8F8"/>
    <SolidColorBrush x:Key="LineNumberFg"            Color="#AAAAAA"/>
    <SolidColorBrush x:Key="LineNumberCurrentLineBg" Color="#DDE8F5"/>

    <!-- task states -->
    <SolidColorBrush x:Key="TaskCompletedFg" Color="#AAAAAA"/>

    <!-- marker list -->
    <SolidColorBrush x:Key="MarkerHoverBg" Color="#F0F4FF"/>

    <!-- text hierarchy -->
    <SolidColorBrush x:Key="SubtleFg"    Color="#777777"/>
    <SolidColorBrush x:Key="MutedFg"     Color="#888888"/>
    <SolidColorBrush x:Key="SecondaryFg" Color="#666666"/>
    <SolidColorBrush x:Key="PrimaryFg"   Color="#555555"/>
    <SolidColorBrush x:Key="FaintFg"     Color="#999999"/>
    <SolidColorBrush x:Key="HintFg"      Color="#BBBBBB"/>

    <!-- chrome / panes -->
    <SolidColorBrush x:Key="StatusBarBg"     Color="#F0F0F0"/>
    <SolidColorBrush x:Key="RightPaneBg"     Color="#FAFAFA"/>
    <SolidColorBrush x:Key="ItemBorderBrush" Color="#EEEEEE"/>

    <!-- sample banner action buttons -->
    <SolidColorBrush x:Key="BannerPrimaryBg"       Color="#E6C800"/>
    <SolidColorBrush x:Key="BannerPrimaryBorder"   Color="#B09600"/>
    <SolidColorBrush x:Key="BannerPrimaryFg"       Color="#3A2B00"/>
    <SolidColorBrush x:Key="BannerSecondaryBg"     Color="#4A90D9"/>
    <SolidColorBrush x:Key="BannerSecondaryBorder" Color="#2E6DA4"/>
    <SolidColorBrush x:Key="BannerSecondaryFg"     Color="White"/>

    <!-- icon button -->
    <SolidColorBrush x:Key="IconButtonHoverBg" Color="#E8EEFF"/>

    <!-- window / editor -->
    <SolidColorBrush x:Key="AppBg"    Color="White"/>
    <SolidColorBrush x:Key="AppFg"    Color="#111111"/>
    <SolidColorBrush x:Key="EditorBg" Color="White"/>

    <!-- SH-10 semantic theme resources -->
    <SolidColorBrush x:Key="AppBackgroundBrush" Color="White"/>
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#F5F5F5"/>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="White"/>
    <SolidColorBrush x:Key="EditorBackgroundBrush" Color="White"/>
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="#111111"/>
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="#666666"/>
    <SolidColorBrush x:Key="MutedTextBrush" Color="#888888"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#E0E0E0"/>
    <SolidColorBrush x:Key="AccentBrush" Color="#2B5CE6"/>
    <SolidColorBrush x:Key="HoverBackgroundBrush" Color="#EFEFEF"/>
    <SolidColorBrush x:Key="FocusBorderBrush" Color="#2B5CE6"/>
    <SolidColorBrush x:Key="SelectionBackgroundBrush" Color="#DCE8FF"/>
    <SolidColorBrush x:Key="SearchHighlightBrush" Color="#FFF8A6"/>
    <SolidColorBrush x:Key="WarningBrush" Color="#E65100"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="#CC0000"/>
    <SolidColorBrush x:Key="UnsavedIndicatorBrush" Color="#E65100"/>
    <SolidColorBrush x:Key="InputBackgroundBrush" Color="White"/>
    <SolidColorBrush x:Key="ButtonHoverBackgroundBrush" Color="#E8EEFF"/>
    <SolidColorBrush x:Key="ChatSearchBarBackgroundBrush" Color="#ECEFF1"/>
    <SolidColorBrush x:Key="ChatMessageTextBrush" Color="#212121"/>
    <SolidColorBrush x:Key="ChatInputPanelBackgroundBrush" Color="White"/>
    <SolidColorBrush x:Key="ChatChipBackgroundBrush" Color="#F0F0F0"/>
    <SolidColorBrush x:Key="ChatCopyButtonBackgroundBrush" Color="#EEEEEE"/>
    <SolidColorBrush x:Key="ChatCopyButtonHoverBackgroundBrush" Color="#E0E0E0"/>
    <SolidColorBrush x:Key="ChatCopyButtonPressedBackgroundBrush" Color="#BDBDBD"/>
    <SolidColorBrush x:Key="OverlayCardBackgroundBrush" Color="White"/>
    <SolidColorBrush x:Key="IdeaAppBackgroundBrush" Color="#F6F7F9"/>
    <SolidColorBrush x:Key="IdeaSurfaceBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="IdeaBorderBrush" Color="#E5E7EB"/>
    <SolidColorBrush x:Key="IdeaTextPrimaryBrush" Color="#1F2937"/>
    <SolidColorBrush x:Key="IdeaTextSecondaryBrush" Color="#6B7280"/>
    <SolidColorBrush x:Key="IdeaAccentBrush" Color="#E8773A"/>
    <SolidColorBrush x:Key="IdeaAccentHoverBrush" Color="#D6652A"/>
    <SolidColorBrush x:Key="IdeaAccentPressedBrush" Color="#B85320"/>
    <SolidColorBrush x:Key="IdeaChipBackgroundBrush" Color="#EEF2F7"/>
    <SolidColorBrush x:Key="IdeaChipForegroundBrush" Color="#475569"/>
    <SolidColorBrush x:Key="IdeaHoverOverlayBrush" Color="#F3F4F6"/>
    <SolidColorBrush x:Key="IdeaCardHoverBorderBrush" Color="#9CA3AF"/>

</ResourceDictionary>
