<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- layout / structure -->
    <SolidColorBrush x:Key="SidebarBg"      Color="#252526"/>
    <SolidColorBrush x:Key="PaneBorder"     Color="#3E3E42"/>
    <SolidColorBrush x:Key="GroupHeaderBg"  Color="#2D2D30"/>
    <SolidColorBrush x:Key="SelectedNoteBg" Color="#094771"/>
    <SolidColorBrush x:Key="AccentBlue"     Color="#6B9FFF"/>

    <!-- marker types -->
    <SolidColorBrush x:Key="TodoBrush"      Color="#E6903A"/>
    <SolidColorBrush x:Key="FixmeBrush"     Color="#FF6B6B"/>
    <SolidColorBrush x:Key="NoteBrush"      Color="#4EC97A"/>

    <!-- task comment mode -->
    <SolidColorBrush x:Key="TaskCommentEditorBg"  Color="#252218"/>
    <SolidColorBrush x:Key="TaskCommentTitleBg"   Color="#2D2920"/>
    <SolidColorBrush x:Key="TaskCommentIndicator" Color="#5B9BD5"/>
    <SolidColorBrush x:Key="CommentBadgeBg"       Color="#7A5500"/>
    <SolidColorBrush x:Key="CommentBadgeFg"       Color="#FFD580"/>

    <!-- unsaved state -->
    <SolidColorBrush x:Key="UnsavedBrush"        Color="#FF8C42"/>
    <SolidColorBrush x:Key="UnsavedWarningBrush" Color="#FF5555"/>
    <SolidColorBrush x:Key="UnsavedSaveBtnBg"    Color="#3D2800"/>

    <!-- sample project banner -->
    <SolidColorBrush x:Key="SampleBannerBg"     Color="#2D2800"/>
    <SolidColorBrush x:Key="SampleBannerBorder" Color="#A08800"/>
    <SolidColorBrush x:Key="SampleBannerFg"     Color="#FFD740"/>

    <!-- line number gutter -->
    <SolidColorBrush x:Key="LineNumberBg"            Color="#1E1E1E"/>
    <SolidColorBrush x:Key="LineNumberFg"            Color="#555555"/>
    <SolidColorBrush x:Key="LineNumberCurrentLineBg" Color="#252D3E"/>

    <!-- H3b: marker line highlight (TODO / FIXME / HACK) -->
    <SolidColorBrush x:Key="MarkerLineHighlightBrush" Color="#663A2F12"/>

    <!-- task states -->
    <SolidColorBrush x:Key="TaskCompletedFg" Color="#555555"/>

    <!-- marker list -->
    <SolidColorBrush x:Key="MarkerHoverBg" Color="#1A2540"/>

    <!-- text hierarchy -->
    <SolidColorBrush x:Key="SubtleFg"    Color="#999999"/>
    <SolidColorBrush x:Key="MutedFg"     Color="#888888"/>
    <SolidColorBrush x:Key="SecondaryFg" Color="#AAAAAA"/>
    <SolidColorBrush x:Key="PrimaryFg"   Color="#CCCCCC"/>
    <SolidColorBrush x:Key="FaintFg"     Color="#666666"/>
    <SolidColorBrush x:Key="HintFg"      Color="#505050"/>

    <!-- chrome / panes -->
    <SolidColorBrush x:Key="StatusBarBg"     Color="#1E1E1E"/>
    <SolidColorBrush x:Key="RightPaneBg"     Color="#252526"/>
    <SolidColorBrush x:Key="ItemBorderBrush" Color="#3E3E42"/>

    <!-- sample banner action buttons -->
    <SolidColorBrush x:Key="BannerPrimaryBg"       Color="#A08800"/>
    <SolidColorBrush x:Key="BannerPrimaryBorder"   Color="#806600"/>
    <SolidColorBrush x:Key="BannerPrimaryFg"       Color="#FFD740"/>
    <SolidColorBrush x:Key="BannerSecondaryBg"     Color="#2A5F9A"/>
    <SolidColorBrush x:Key="BannerSecondaryBorder" Color="#1A4A7A"/>
    <SolidColorBrush x:Key="BannerSecondaryFg"     Color="White"/>

    <!-- icon button -->
    <SolidColorBrush x:Key="IconButtonHoverBg" Color="#2A3A5F"/>

    <!-- window / editor -->
    <SolidColorBrush x:Key="AppBg"    Color="#1E1E1E"/>
    <SolidColorBrush x:Key="AppFg"    Color="#E0E0E0"/>
    <SolidColorBrush x:Key="EditorBg" Color="#1E1E1E"/>

    <!-- SH-10 semantic theme resources -->
    <SolidColorBrush x:Key="AppBackgroundBrush" Color="#1E1E1E"/>
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#252526"/>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#2D2D30"/>
    <SolidColorBrush x:Key="EditorBackgroundBrush" Color="#1E1E1E"/>
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="#E0E0E0"/>
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="#AAAAAA"/>
    <SolidColorBrush x:Key="MutedTextBrush" Color="#888888"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#3E3E42"/>
    <SolidColorBrush x:Key="AccentBrush" Color="#6B9FFF"/>
    <SolidColorBrush x:Key="HoverBackgroundBrush" Color="#333337"/>
    <SolidColorBrush x:Key="FocusBorderBrush" Color="#6B9FFF"/>
    <SolidColorBrush x:Key="SelectionBackgroundBrush" Color="#094771"/>
    <SolidColorBrush x:Key="SearchHighlightBrush" Color="#6B4F00"/>
    <SolidColorBrush x:Key="WarningBrush" Color="#FFB86C"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="#FF5555"/>
    <SolidColorBrush x:Key="UnsavedIndicatorBrush" Color="#FF8C42"/>
    <SolidColorBrush x:Key="InputBackgroundBrush" Color="#252526"/>
    <SolidColorBrush x:Key="ButtonHoverBackgroundBrush" Color="#2A3A5F"/>
    <SolidColorBrush x:Key="ChatSearchBarBackgroundBrush" Color="#252D33"/>
    <SolidColorBrush x:Key="ChatMessageTextBrush" Color="#E6E6E6"/>
    <SolidColorBrush x:Key="ChatInputPanelBackgroundBrush" Color="#252526"/>
    <SolidColorBrush x:Key="ChatChipBackgroundBrush" Color="#333337"/>
    <SolidColorBrush x:Key="ChatCopyButtonBackgroundBrush" Color="#333337"/>
    <SolidColorBrush x:Key="ChatCopyButtonHoverBackgroundBrush" Color="#3E3E42"/>
    <SolidColorBrush x:Key="ChatCopyButtonPressedBackgroundBrush" Color="#4A4A50"/>
    <SolidColorBrush x:Key="OverlayCardBackgroundBrush" Color="#2D2D30"/>
    <SolidColorBrush x:Key="IdeaAppBackgroundBrush" Color="#1E1E1E"/>
    <SolidColorBrush x:Key="IdeaSurfaceBrush" Color="#2D2D30"/>
    <SolidColorBrush x:Key="IdeaBorderBrush" Color="#3E3E42"/>
    <SolidColorBrush x:Key="IdeaTextPrimaryBrush" Color="#E0E0E0"/>
    <SolidColorBrush x:Key="IdeaTextSecondaryBrush" Color="#AAAAAA"/>
    <SolidColorBrush x:Key="IdeaAccentBrush" Color="#FF9A5C"/>
    <SolidColorBrush x:Key="IdeaAccentHoverBrush" Color="#E8773A"/>
    <SolidColorBrush x:Key="IdeaAccentPressedBrush" Color="#C8612F"/>
    <SolidColorBrush x:Key="IdeaChipBackgroundBrush" Color="#333337"/>
    <SolidColorBrush x:Key="IdeaChipForegroundBrush" Color="#D0D0D0"/>
    <SolidColorBrush x:Key="IdeaHoverOverlayBrush" Color="#333337"/>
    <SolidColorBrush x:Key="IdeaCardTextPrimaryBrush" Color="#1F2937"/>
    <SolidColorBrush x:Key="IdeaCardTextSecondaryBrush" Color="#6B7280"/>
    <SolidColorBrush x:Key="ChatBubbleTextBrush" Color="#212121"/>
    <SolidColorBrush x:Key="IdeaCardHoverBorderBrush" Color="#6B7280"/>

</ResourceDictionary>
